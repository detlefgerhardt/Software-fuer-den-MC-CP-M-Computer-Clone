  233 0245  FE 05       	CP	ERRLMT		;
  234 0247  38 C4       	JR	C,SEOT		;
  235 0249  CD 01C5     	CALL	ERXIT		;
  236 024C  0D 0A 0A    	DEFB	13,10,10	;
  237 024F  4E 6F 20 41 	DEFB	'No ACK received on EOT, but transfer is complete.',13,10,'$'
