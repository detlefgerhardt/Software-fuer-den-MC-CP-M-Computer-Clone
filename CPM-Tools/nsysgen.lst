  135                   
  136 019A  7E          OUTMSG:	LD A,(HL)
  137 019B  B7          	OR A
  138 019C  C8          	RET Z
  139                   	; MESSAGE NOT YET COMPLETED
  140 019D  E5          	PUSH HL
  141 019E  CD 0183     	CALL PUTCHAR
  142 01A1  E1          	POP HL
  143 01A2  23          	INC HL
  144 01A3  C3 019A     	JP	OUTMSG
