   80                   ; UTILITY SUBROUTINES
   81                   
   82 016A              MULTSEC:
   83                   	;MULTIPLY THE SECTOR NUMBER IN A BY THE SECTOR SIZE
   84 016A  6F          	LD L,A
   85 016B  26 00       	LD H,0 ;SECTOR NUMBER IN HL
   86                   	REPT LOG2SEC	;LOG 2 OF SECTOR SIZE
   87                   	ADD HL,HL
   88                   	ENDM
    1 016D  29          	ADD HL,HL
    1 016E  29          	ADD HL,HL
    1 016F  29          	ADD HL,HL
    1 0170  29          	ADD HL,HL
    1 0171  29          	ADD HL,HL
    1 0172  29          	ADD HL,HL
    1 0173  29          	ADD HL,HL
   89 0174  C9          	RET ;WITH HL = SECTOR * SECTOR SIZE
   90                   
   91                   ;-----------------------------------------------------------------------------
   92                   ; READ CONSOLE CHARACTER TO REGISTER A
   93                   
   94 0175              GETCHAR:
   95 0175  0E 01       	LD C,CONI
   96 0177  CD 0005     	CALL BDOS
   97                   	
   98                   ;	CONVERT TO UPPER CASE BEFORE RETURN
   99 017A  FE 61       	CP 'A' OR 20H
  100 017C  D8          	RET C	;RETURN IF BELOW LOWER CASE A
  101                   	
  102 017D  FE 7B       	CP ('Z' OR 20H) + 1
  103 017F  D0          	RET NC	;RETURN IF ABOVE LOWER CASE Z
  104                   	
