   60 012A              TRAN:			;BASE OF TRANSLATE TABLE
   61         0001      TRELT	DEFL	1	;FIRST/NEXT TRAN ELEMENT
   62         0001      TRBASE	DEFL	1	;BASE FOR WRAPAROUND
   63                   	REPT	NSECTS	;ONCE FOR EACH SECTOR ON A TRACK
   64                   	DB	TRELT	;GENERATE FIRST/NEXT SECTOR
   65                   TRELT	DEFL	TRELT+SKEW
   66                   	IF	TRELT GT NSECTS
   67                   TRBASE	DEFL	TRBASE+1
   68                   TRELT	DEFL	TRBASE
   69                   	ENDIF
   70                   	ENDM
