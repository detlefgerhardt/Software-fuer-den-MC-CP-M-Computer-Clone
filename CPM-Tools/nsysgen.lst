  108                   ;-----------------------------------------------------------------------------
  109                   ; WRITE CHARACTER FROM A TO CONSOLE
  110                   
  111 0183              PUTCHAR:
  112 0183  5F          	LD E,A
  113 0184  0E 02       	LD C,CONO
  114 0186  CD 0005     	CALL BDOS
  115 0189  C9          	RET
