   11         001A      NSECTS	EQU	26	;NO. OF SECTORS PER TRACK	SYSGEN80
   12         0002      NTRKS	EQU	2	;NO. OF OPERATING SYSTEM TRACKS	SYSGEN80
   13         0002      NDISKS	EQU	2	;NUMBER OF DISK DRIVES
   14         0100      SECSIZ	EQU	256	;SIZE OF EACH SECTOR
   15         0007      LOG2SEC	EQU	7	;LOG 2 SECSIZ			SYSGEN80
   16         0001      SKEW	EQU	1	;SECTOR SKEW FACTOR
   17                   ;
   18         005C      FCB	EQU	005CH	;DEFAULT FCB LOCATION
   19         007C      FCBCR	EQU	FCB+32	;CURRENT RECORD LOCATION
   20         0100      TPA	EQU	0100H	;TRANSIENT PROGRAM AREA
   21         0900      LOADP	EQU	900H	;LOAD POINT FOR SYSTEM DURING LOAD/STORE
   22         0005      BDOS	EQU	5H	;DOS ENTRY POINT
   23         0000      BOOT	EQU	0	;JP TO 'BOOT' TO REBOOT SYSTEM
   24         0001      CONI	EQU	1	;CONSOLE INPUT FUNCTION
   25         0002      CONO	EQU	2	;CONSOLE OUTPUT FUNCTION
   26         000E      SELF	EQU	14	;SELECT DISK
   27         000F      OPENF	EQU	15	;DISK OPEN FUNCTION
   28         0014      DREADF	EQU	20	;DISK READ FUNCTION
   29                   ;
   30         000A      MAXTRY	EQU	10	;MAXIMUM NUMBER OF RETRIES ON EACH READ/WRITE
   31         000D      CR	EQU	0DH	;CARRIAGE RETURN
   32         000A      LF	EQU	0AH	;LINE FEED
   33         0010      STACKSIZE	EQU	16	;SIZE OF LOCAL STACK
   34                   ;
   35         0001      WBOOT	EQU	1	;ADDRESS OF WARM BOOT (OTHER PATCH ENTRY
   36                   ;			POINTS ARE COMPUTED RELATIVE TO WBOOT)
   37         0018      SELDSK	EQU	24	;WBOOT+24 FOR DISK SELECT
   38         0021      SETTRK	EQU	33; 27	;WBOOT+27 FOR SET TRACK FUNCTION	SYSGEN80
   39         001E      SETSEC	EQU	30	;WBOOT+30 FOR SET SECTOR FUNCTION
   40         0021      SETDMA	EQU	33	;WBOOT+33 FOR SET DMA ADDRESS
   41         0024      READF	EQU	36	;WBOOT+36 FOR READ FUNCTION
   42         0027      WRITF	EQU	39	;WBOOT+39 FOR WRITE FUNCTION
