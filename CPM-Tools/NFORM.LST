  117 0157  3A 18C6     	LD A,(USESSO)
  118 015A  B7          	OR A
  119 015B  CA 0163     	JP Z,FORM2	; -> no SSO
  120                   	
  121                   	; SSO
  122 015E  3E 80       	LD A,80H 
  123 0160  32 18C5     	LD (SIDESEL),A 	; setzen
  124                   
  125 0163  CD 02E3     FORM2:	CALL GENTRK
  126 0166  CD 0674     	CALL FRMTRK
  127 0169  CD 0245     	CALL ERRCHK
  128                   	
  129                   	; set side 0
  130 016C  3A 18C4     	LD A,(DRIVE)
  131 016F  E6 7F       	AND 7FH
