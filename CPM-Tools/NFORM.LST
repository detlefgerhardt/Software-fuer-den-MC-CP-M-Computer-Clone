  214                   ;-----------------------------------------------------------------------------
  215                   ; Set ECMA70 format
  216                   
  217 01F3              ECMACHK:
  218 01F3  3A 18BB     	LD A,(ECMA)	; 1=ECMA70
  219 01F6  B7          	OR A
  220 01F7  C8          	RET Z  		; no ECMA70
  221                   	
  222 01F8  AF          	XOR A
  223 01F9  32 18BA     	LD (MINMAX),A 	; always mini drive
  224                   	
  225 01FC  3A 18C7     	LD A,(CURTRK)
  226 01FF  B7          	OR A
  227 0200  C2 0225     	JP NZ,ECMAC1	; -> not track 0
  228                   	
  229                   	; track 0, format single-density
  230 0203  21 0080     	LD HL,128
  231 0206  22 18BC     	LD (BYTCNT),HL
  232                    	
