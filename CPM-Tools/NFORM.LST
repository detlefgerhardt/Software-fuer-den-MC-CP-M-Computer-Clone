  233 0209  3E 00       	LD A,0 		; single density
  234 020B  32 18BF     	LD (DENSITY),A 	;
  235 020E  3E 00       	LD A,0		; single-sided
  236 0210  32 18C2     	LD (SSDS),A
  237 0213  3E 10       	LD A,16		; 16 sectors
  238 0215  32 18C3     	LD (SECCNT),A
  239 0218  3E 1B       	LD A,27
  240 021A  32 18C0     	LD (GAPLEN),A
  241 021D  3E 28       	LD A,40		; 40 tracks
  242 021F  32 18C1     	LD (TRKCNT),A
  243 0222  C3 0244     	JP ECMAC2
  244                   	
  245 0225              ECMAC1:	; not track 0, format double density
  246 0225  21 0100     	LD HL,256
  247 0228  22 18BC     	LD (BYTCNT),HL
  248                   	
  249 022B  3E 01       	LD A,1		; double density
  250 022D  32 18BF     	LD (DENSITY),A
  251 0230  3E 00       	LD A,0 		; single-sided
  252 0232  32 18C2     	LD (SSDS),A
  253 0235  3E 10       	LD A,16 	; 16 sectors
  254 0237  32 18C3     	LD (SECCNT),A
  255 023A  3E 36       	LD A,54
  256 023C  32 18C0     	LD (GAPLEN),A 	; STD Gap
  257 023F  3E 28       	LD A,40 	; 40 tracks
  258 0241  32 18C1     	LD (TRKCNT),A
  259                   
  260 0244  C9          ECMAC2:	RET
  261                   
  262                   ;-----------------------------------------------------------------------------
  263                   ; General error check routine
  264                   
  265                   ; error code in A
  266                   ;   bit 2 = CPU to slow
  267                   ;   bit 3 = CRC error
  268                   ;   bit 4 = record not found
  269                   ;   bit 5 = wrong record type
  270                   ;   bit 6 = write protected
  271                   
  272 0245  B7          ERRCHK:	OR A
  273 0246  C8          	RET Z  	; =0? -> Status ok
  274                   	
  275                   	; TRACK, Spur ausgeben
  276 0247  F5          	PUSH AF 	; save error code
  277 0248  21 1721     	LD HL,TKMSG
  278 024B  CD 0B99     	CALL PRNMSG
  279 024E  3A 18C7     	LD A,(CURTRK)
  280 0251  6F          	LD L,A
  281 0252  26 00       	LD H,0 
  282 0254  CD 02AE     	CALL PRNTHL
  283 0257  21 172C     	LD HL,SKMSG
  284 025A  CD 0B99     	CALL PRNMSG
  285 025D  3A 18C8     	LD A,(CURSEC)
  286 0260  6F          	LD L,A
  287 0261  26 00       	LD H,0
  288 0263  CD 02AE     	CALL PRNTHL
  289 0266  CD 0D50     	CALL CRLF
  290                   
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   6
NFORM   Z80

  291 0269  F1          	POP AF  	; restore error code
  292                   	
  293                   	; check bit 2
  294 026A  CB 57       	BIT 2,A
  295 026C  21 16ED     	LD HL,F0MSG 	; error message
  296 026F  CA 0275     	JP Z,ERRC1	; -> bit 2 not set
  297                   	
  298                   	; bit 2, CPU too slow
  299 0272  21 167B     	LD HL,F2MSG
  300                   
  301 0275              ERRC1:	; check bit 3
  302 0275  CB 5F       	BIT 3,A
  303 0277  CA 027D     	JP Z,ERRC2	; -> bit 3 not set
  304                   
  305                   	; bit 3, CRC errror
  306 027A  21 1643     	LD HL,F3MSG
  307                   
  308 027D              ERRC2:	; check bit 4
  309 027D  CB 67       	BIT 4,A
  310 027F  CA 0285     	JP Z,ERRC3	; -> bit 4 not set
  311                   	
  312                   	; bit 4, record not found
  313 0282  21 160C     	LD HL,F4MSG
  314                   	
  315 0285              ERRC3:	; check bit 5
  316 0285  CB 6F       	BIT 5,A
  317 0287  CA 028D     	JP Z,ERRC4	; -> bit 5 not set
  318                   
  319                   	; bit 5, wrong record type
  320 028A  21 15D5     	LD HL,F5MSG
  321                   
  322 028D              ERRC4:	; check bit 6
  323 028D  CB 77       	BIT 6,A
  324 028F  CA 0295     	JP Z,ERRC5	; -> bit 6 not set
  325                   
  326                   	; bit 6, write protected
  327 0292  21 159E     	LD HL,F6MSG
  328                   	
  329 0295              ERRC5:	; check bit 7
  330 0295  CA 029B     	JP Z,ERRC6
  331                   	
  332                   	; bit 7, write protected
  333 0298  21 159E     	LD HL,F6MSG 	; dominant is write proteced error
  334                   
  335 029B  CD 0B99     ERRC6:	CALL PRNMSG
  336                   
  337 029E              ERRC7:	; wait for 'W' or 'w'
  338 029E  CD 0106     	CALL CONIN
  339 02A1  FE 57       	CP 'W'
  340 02A3  CA 02AB     	JP Z,ERRC8
  341 02A6  FE 77       	CP 'w'
  342 02A8  C2 029E     	JP NZ,ERRC7
  343                   
  344 02AB  C3 070E     ERRC8:	JP START 	; no stack adjust needed
  345                   	
