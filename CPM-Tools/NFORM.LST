    1                   	.z80
    2                   
    3                   ;*****************************************************************************
    4                   ; NFORM.Z80  Universal Formatierer fuer Mini/Maxi
    5                   ;
    6                   ; Boot loader for MC CP/M-Computer Mini drive with FLO2 contoller
    7                   ;
    8                   ; based on UFORMAT Rev 1.22 (C) 1984 Rolf-Dieter Klein / JS
    9                   ;
   10                   ;*****************************************************************************
   11                   ; works directly on Monitor and FLO2 hardware, does not need CP/M or BIOS
   12                   
   13                   ; 80 Spur Laufwerke   1K pro Sektor Boot
   14                   ; das programm wird auf sektor 1 track 0 abgelegt
   15                   ;
   16                   ; PLEASE NOTE THE CHANGED CPM & BIOS START ADDRESS!!!
   17                   ;
   18                   ; Version history
   19                   ;
   20                   ; 31.05.2026 *dg* Source code of version 1.22 retrieved from binary
   21                   ; 10.07.2026 *dg* Renamed to NFORM and reformatted
   22                   
   23                   ; IO ADDESSES FLO1/FLO2 Mini/Maxi
   24         00C0      FLO0	EQU 0C0H	; Status/Command
   25         00C1      FLO1	EQU 0C1H	; Track
   26         00C2      FLO2	EQU 0C2H	; Sector
   27         00C3      FLO3	EQU 0C3H	; Data
   28         00C4      FLO4	EQU 0C4H	; Special FLO-Flags
   29                   
   30                   ; IO ADDESSES FLO1 Maxi
   31         0040      FLOA0	EQU 040H
   32         0041      FLOA1	EQU 041H
   33         0042      FLOA2	EQU 042H
   34         0043      FLOA3	EQU 043H
   35         0044      FLOA4	EQU 044H
   36                   
   37                   ; IO ADDESSES FLO1 Mini
   38         0030      FLOB0	EQU 030H
   39         0031      FLOB1	EQU 031H
   40         0032      FLOB2	EQU 032H
   41         0033      FLOB3	EQU 033H
   42         0034      FLOB4	EQU 034H
   43                   
   44                   ;-----------------------------------------------------------------------------
   45                   
   46         0100      	ORG 100H
   47                   
   48 0100  C3 070E     	JP START 	; Hauptprogramm
   49                   
   50                   ;-----------------------------------------------------------------------------
   51                   
   52 0103  C3 F009     CONOUT:	JP 0F009H 	; Ausgabe eines Zeichens in C
   53                   
   54                   ;-----------------------------------------------------------------------------
   55                   
   56 0106  CD F003     CONIN:	CALL 0F003H 	; Eingabe eines Zeichens nach A
   57 0109  E6 7F       	AND 7FH
   58 010B  C9          	RET
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   2
NFORM   Z80

   59                   
   60                   ;-----------------------------------------------------------------------------
   61                   ; Interrupt routine
   62                   
   63 010C  F1          INTR:	POP AF
   64                   	; reset interrupts
   65 010D  DB 40       	IN A,(FLOA0)
   66 010F  DB 30       	IN A,(FLOB0)
   67 0111  DB C0       	IN A,(FLO0)
   68 0113  FB          	EI
   69 0114  ED 4D       	RETI
   70                   
   71                   ;-----------------------------------------------------------------------------
   72                   ; Universal Formatter
   73                   
   74 0116  21 156C     FORMAT:	LD HL,FMSG 
   75 0119  CD 0B99     	CALL PRNMSG
   76                   	
   77                   	; reset interrupts
   78 011C  DB 40       	IN A,(FLOA0) 	; ggf. bei gemischtem Betrieb auch
   79 011E  DB 30       	IN A,(FLOB0)   	; andere Ports loeschen
   80 0120  DB C0       	IN A,(FLO0) 	; alle Interrupts loeschen
   81                   
   82 0122  ED 56       	IM 1  		; MODE 1, RST-7 verwenden
   83 0124  3E C3       	LD A,0C3H 	; Sprungvektor setzen (JP)
   84 0126  32 0038     	LD (38H),A
   85 0129  21 010C     	LD HL,INTR
   86 012C  22 0039     	LD (39H),HL 	; auf Interruptroutine
   87                   
   88                   	; --- format ---------------------------------------------------------
   89                   
   90 012F  CD 048E     	CALL HOME 	; set head to track 0
   91                   
   92 0132  AF          	XOR A
   93 0133  32 18C7     	LD (CURTRK),A  	; start with track 0
   94 0136  3A 18C1     	LD A,(TRKCNT) 	; number of tracks
   95 0139  47          	LD B,A
   96                   
   97 013A              FORM1:	; format loop (tracks)
   98                   
   99                   	; --- format side 0 ---
  100                   	
  101 013A  C5          	PUSH BC
  102 013B  CD 01F3     	CALL ECMACHK 	; check if track 0 and ECMA70
  103 013E  CD 02E3     	CALL GENTRK 	; create track
  104 0141  CD 0674     	CALL FRMTRK 	; format track
  105 0144  CD 0245     	CALL ERRCHK
  106                   	
  107 0147  3A 18C2     	LD A,(SSDS)
  108 014A  FE 01       	CP 1
  109 014C  C2 0178     	JP NZ,FORM3	; -> single sided
  110                   
  111                   	; --- double-sided,. format side 1 ---
  112                   	
  113 014F  3A 18C4     	LD A,(DRIVE)	; Rueckseite setzen
  114 0152  F6 80       	OR 80H  	; aber kein Side-sel
  115 0154  32 18C4     	LD (DRIVE),A
  116                   
