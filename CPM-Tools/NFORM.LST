  175                   	
  176 01B2  3A 18C4     	LD A,(DRIVE)
  177 01B5  F6 80       	OR 80H
  178 01B7  32 18C4     	LD (DRIVE),A
  179 01BA  3A 18C6     	LD A,(USESSO)
  180 01BD  B7          	OR A
  181 01BE  CA 01C6     	JP Z,FORM6	; -> no SSO
  182                   	
  183                   	; SSO
  184 01C1  3E 80       	LD A,80H
  185 01C3  32 18C5     	LD (SIDESEL),A
  186                   
  187 01C6  CD 0462     FORM6:	CALL VERIFY
  188                   
  189                   	; set side 0
  190 01C9  3A 18C4     	LD A,(DRIVE)
  191 01CC  E6 7F       	AND 7FH
  192 01CE  32 18C4     	LD (DRIVE),A 
  193 01D1  AF          	XOR A
  194 01D2  32 18C5     	LD (SIDESEL),A 	; wieder Seite 0
  195                   
  196 01D5  3A 18C7     FORM7:	LD A,(CURTRK)
  197 01D8  3C          	INC A
  198 01D9  32 18C7     	LD (CURTRK),A
  199 01DC  47          	LD B,A
  200 01DD  3A 18C1     	LD A,(TRKCNT)
  201 01E0  B8          	CP B
  202 01E1  CA 01E7     	JP Z,FORM8	; -> TRKCNT = CURTRK
  203                   
  204 01E4  CD 0546     	CALL STEPIN
  205                   
  206 01E7  0E 56       FORM8:	LD C,'V' 
  207 01E9  CD 0103     	CALL CONOUT 	; VVVVV fuer Verify
  208 01EC  C1          	POP BC
  209 01ED  10 B4       	DJNZ FORM5	; -> verify loop (tracks)
  210                   	
  211 01EF  CD 048E     	CALL HOME 	; set head to track 0
