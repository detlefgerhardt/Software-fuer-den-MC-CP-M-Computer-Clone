  151                   	; verify -------------------------------------------------------------
  152                   	
  153 0192  21 1838     	LD HL,VMSG
  154 0195  CD 0B99     	CALL PRNMSG
  155                   	
  156 0198  CD 048E     	CALL HOME	; set head to track 0
  157                   	
  158 019B  AF          	XOR A
  159 019C  32 18C7     	LD (CURTRK),A  	; start with track 0
  160 019F  3A 18C1     	LD A,(TRKCNT) 	; number of tracks
  161 01A2  47          	LD B,A
  162                   
  163 01A3              FORM5:	; verify loop (tracks)
  164                   
  165                   	; --- verify side 0 ---
  166                   
  167 01A3  C5          	PUSH BC
  168 01A4  CD 01F3     	CALL ECMACHK
  169 01A7  CD 0462     	CALL VERIFY
  170 01AA  3A 18C2     	LD A,(SSDS)
  171 01AD  FE 01       	CP 1
  172 01AF  C2 01D5     	JP NZ,FORM7	; -> single-sided
  173                   
  174                   	; --- double-sided, verify side 1 ---
