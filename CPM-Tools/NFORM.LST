  133 0174  AF          	XOR A
  134 0175  32 18C5     	LD (SIDESEL),A
  135                   
  136 0178  3A 18C7     FORM3:	LD A,(CURTRK)
  137 017B  3C          	INC A
  138 017C  32 18C7     	LD (CURTRK),A
  139 017F  47          	LD B,A
  140 0180  3A 18C1     	LD A,(TRKCNT)
  141 0183  B8          	CP B
  142 0184  CA 018A     	JP Z,FORM4	; AKTRK = TRKCNT
  143                   	
  144 0187  CD 0546     	CALL STEPIN
  145                   	
  146 018A  0E 46       FORM4:	LD C,'F'
