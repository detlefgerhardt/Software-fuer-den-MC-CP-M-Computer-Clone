  374 031C  D3 21       	OUT	(SIOBCR),A	;
  375 031E  3E 15       	LD	A,015H		; Rts on, 8N1
  376 0320  D3 21       	OUT	(SIOBCR),A	;
  377 0322  C9          	RET			;
