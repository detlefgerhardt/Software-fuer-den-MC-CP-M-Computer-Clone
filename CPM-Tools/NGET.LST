  387 03A7  CD 0283     	CALL	ERXIT		;
  388 03AA  0D 0A 0A 54 	DEFB	13,10,10,'Transfer Complete',13,10,'$'
  389                   ;
  390 03C1  CD 0283     ABORT:	CALL	ERXIT		;
