NGET    Z80

  407         0011      SRCHF	EQU	17		;   "	"
  408         0012      SRCHN	EQU	18		;   "	"
  409         0013      ERASE	EQU	19		; NO RET CODE
  410         0014      READ	EQU	20		; 0=OK, 1=EOF
  411         0015      WRITE	EQU	21		; 0=OK, 1=ERR, 2=?, 0FFH=NO DIR SPC
  412         0016      MAKE	EQU	22		; 0FFH=BAD
  413         0017      REN	EQU	23		; 0FFH=BAD
  414         001A      STDMA	EQU	26		;
  415         0005      BDOS	EQU	5		;
  416         0000      REIPL	EQU	0		;
