  401         0001      RDCON	EQU	1		;
  402         0002      WRCON	EQU	2		;
  403         0009      PRINT	EQU	9		;
  404         000B      CONST	EQU	11		; CONSOLE STAT
  405         000F      OPEN	EQU	15		; 0FFH=NOT FOUND
  406         0010      CLOSE	EQU	16		;   "	"
