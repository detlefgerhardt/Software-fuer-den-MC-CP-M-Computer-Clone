  393 03DA    0028      	DEFS	40		; STACK AREA
  394 0402    0002      STACK:	DEFS	2		; STACK POINTER
  395 0404    0001      RSECTNO:DEFS	1		; RECEIVED SECTOR NUMBER
  396 0405    0001      SECTNO:	DEFS	1		; CURRENT SECTOR NUMBER 
  397 0406    0001      FPORTB:	DEFS	1		; Flag to use 2SIO port B instead of A
