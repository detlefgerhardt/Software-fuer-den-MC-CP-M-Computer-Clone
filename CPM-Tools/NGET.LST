NGET    Z80

  349                   ; Use port B
  350                   ;
  351 0301  DB 21       SENDWB:	IN	A,(SIOBCR)	;
  352 0303  E6 01       	AND	XMTMASK		;
  353 0305  FE 01       	CP	XMTRDY		;
  354 0307  C2 0301     	JP	NZ,SENDWB	;
  355 030A  F1          	POP	AF		; GET CHAR
  356 030B  D3 20       	OUT	(SIOBDR),A	;
  357 030D  C9          	RET			;
  358                   ;
  359                   ; INITITIALIZE THE SERIAL PORT
  360                   ;
  361 030E              INIT$ACIA:
  362 030E  3A 0406     	LD	A,(FPORTB)	; Using port B?
  363 0311  B7          	OR	A		;
  364 0312  C2 031A     	JP	NZ,INITB	; Yes
