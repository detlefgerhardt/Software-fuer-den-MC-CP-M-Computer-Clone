  175                   	; SSO
  176 01C1  3E 80       	LD A,80H
  177 01C3  32 18C5     	LD (SIDESEL),A
  178                   
  179 01C6  CD 0462     FORM6:	CALL VERIFY
  180                   
  181                   	; set side 0
  182 01C9  3A 18C4     	LD A,(DRIVE)
  183 01CC  E6 7F       	AND 7FH
  184 01CE  32 18C4     	LD (DRIVE),A 
  185 01D1  AF          	XOR A
  186 01D2  32 18C5     	LD (SIDESEL),A 	; wieder Seite 0
  187                   
  188 01D5  3A 18C7     FORM7:	LD A,(CURTRK)
  189 01D8  3C          	INC A
  190 01D9  32 18C7     	LD (CURTRK),A
  191 01DC  47          	LD B,A
  192 01DD  3A 18C1     	LD A,(TRKCNT)
  193 01E0  B8          	CP B
  194 01E1  CA 01E7     	JP Z,FORM8	; -> TRKCNT = CURTRK
  195                   
  196 01E4  CD 0546     	CALL STEPIN
  197                   
  198 01E7  0E 56       FORM8:	LD C,'V' 
