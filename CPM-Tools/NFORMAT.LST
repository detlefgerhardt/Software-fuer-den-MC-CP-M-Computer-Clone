  339                   ; PRNMSG decimal value in HL
  340                   	
  341 02AE  AF          PRNTHL:	XOR A
  342 02AF  F5          	PUSH AF
  343                   
  344 02B0              PRNTH1:	; digit loop
  345 02B0  3E 10       	LD A,16
  346 02B2  01 000A     	LD BC,10 	; div 10
  347 02B5  11 0000     	LD DE,0 	; Rest
  348 02B8  EB          	EX DE,HL
