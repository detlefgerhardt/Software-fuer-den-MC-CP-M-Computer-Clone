  131 017F  47          	LD B,A
  132 0180  3A 18C1     	LD A,(TRKCNT)
  133 0183  B8          	CP B
  134 0184  CA 018A     	JP Z,FORM4	; AKTRK = TRKCNT
  135                   	
  136 0187  CD 0546     	CALL STEPIN
