  152 019F  3A 18C1     	LD A,(TRKCNT) 	; number of tracks
  153 01A2  47          	LD B,A
  154                   
  155 01A3              FORM5:	; verify loop (tracks)
  156                   
  157                   	; --- verify side 0 ---
  158                   
  159 01A3  C5          	PUSH BC
  160 01A4  CD 01F3     	CALL ECMACHK
  161 01A7  CD 0462     	CALL VERIFY
  162 01AA  3A 18C2     	LD A,(SSDS)
  163 01AD  FE 01       	CP 1
  164 01AF  C2 01D5     	JP NZ,FORM7	; -> single-sided
