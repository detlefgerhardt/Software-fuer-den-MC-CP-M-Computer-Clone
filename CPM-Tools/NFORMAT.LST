  246 0237  32 18C3     	LD (SECCNT),A
  247 023A  3E 36       	LD A,54
  248 023C  32 18C0     	LD (GAPLEN),A 	; STD Gap
  249 023F  3E 28       	LD A,40 	; 40 tracks
  250 0241  32 18C1     	LD (TRKCNT),A
  251                   
  252 0244  C9          ECMAC2:	RET
  253                   
  254                   ;-----------------------------------------------------------------------------
  255                   ; General error check routine
  256                   
  257                   ; error code in A
  258                   ;   bit 2 = CPU to slow
  259                   ;   bit 3 = CRC error
  260                   ;   bit 4 = record not found
  261                   ;   bit 5 = wrong record type
  262                   ;   bit 6 = write protected
  263                   
  264 0245  B7          ERRCHK:	OR A
  265 0246  C8          	RET Z  	; =0? -> Status ok
  266                   	
  267                   	; TRACK, Spur ausgeben
  268 0247  F5          	PUSH AF 	; save error code
  269 0248  21 1721     	LD HL,TKMSG
  270 024B  CD 0B99     	CALL PRNMSG
  271 024E  3A 18C7     	LD A,(CURTRK)
  272 0251  6F          	LD L,A
  273 0252  26 00       	LD H,0 
  274 0254  CD 02AE     	CALL PRNTHL
  275 0257  21 172C     	LD HL,SKMSG
  276 025A  CD 0B99     	CALL PRNMSG
  277 025D  3A 18C8     	LD A,(CURSEC)
  278 0260  6F          	LD L,A
  279 0261  26 00       	LD H,0
  280 0263  CD 02AE     	CALL PRNTHL
  281 0266  CD 0D50     	CALL CRLF
  282                   
  283 0269  F1          	POP AF  	; restore error code
  284                   	
  285                   	; check bit 2
  286 026A  CB 57       	BIT 2,A
  287 026C  21 16ED     	LD HL,F0MSG 	; error message
  288 026F  CA 0275     	JP Z,ERRC1	; -> bit 2 not set
  289                   	
  290                   	; bit 2, CPU too slow
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   6
UFORMAT Z80

  291 0272  21 167B     	LD HL,F2MSG
  292                   
  293 0275              ERRC1:	; check bit 3
  294 0275  CB 5F       	BIT 3,A
  295 0277  CA 027D     	JP Z,ERRC2	; -> bit 3 not set
  296                   
  297                   	; bit 3, CRC errror
  298 027A  21 1643     	LD HL,F3MSG
  299                   
  300 027D              ERRC2:	; check bit 4
  301 027D  CB 67       	BIT 4,A
  302 027F  CA 0285     	JP Z,ERRC3	; -> bit 4 not set
  303                   	
  304                   	; bit 4, record not found
  305 0282  21 160C     	LD HL,F4MSG
  306                   	
  307 0285              ERRC3:	; check bit 5
  308 0285  CB 6F       	BIT 5,A
  309 0287  CA 028D     	JP Z,ERRC4	; -> bit 5 not set
  310                   
  311                   	; bit 5, wrong record type
  312 028A  21 15D5     	LD HL,F5MSG
  313                   
  314 028D              ERRC4:	; check bit 6
  315 028D  CB 77       	BIT 6,A
  316 028F  CA 0295     	JP Z,ERRC5	; -> bit 6 not set
  317                   
  318                   	; bit 6, write protected
  319 0292  21 159E     	LD HL,F6MSG
  320                   	
  321 0295              ERRC5:	; check bit 7
  322 0295  CA 029B     	JP Z,ERRC6
  323                   	
  324                   	; bit 7, write protected
  325 0298  21 159E     	LD HL,F6MSG 	; dominant is write proteced error
  326                   
  327 029B  CD 0B99     ERRC6:	CALL PRNMSG
  328                   
  329 029E              ERRC7:	; wait for 'W' or 'w'
  330 029E  CD 0106     	CALL CONIN
  331 02A1  FE 57       	CP 'W'
  332 02A3  CA 02AB     	JP Z,ERRC8
  333 02A6  FE 77       	CP 'w'
  334 02A8  C2 029E     	JP NZ,ERRC7
  335                   
  336 02AB  C3 070E     ERRC8:	JP START 	; no stack adjust needed
  337                   	
