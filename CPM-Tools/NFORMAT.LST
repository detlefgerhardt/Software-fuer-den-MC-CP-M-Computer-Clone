  200 01EC  C1          	POP BC
  201 01ED  10 B4       	DJNZ FORM5	; -> verify loop (tracks)
  202                   	
  203 01EF  CD 048E     	CALL HOME 	; set head to track 0
  204 01F2  C9          	RET
