   12                   	;*********************************************************************
   13                   
   14                   	; arbeitet unabhaengig vom CP/M - Betriebsystem.
   15                   	; verwendet den Monitor
   16                   
   17                   ; IO ADDESSES FLO1/FLO2 Mini/Maxi
   18         00C0      FLO0	EQU 0C0H	; Status/Command
   19         00C1      FLO1	EQU 0C1H	; Track
   20         00C2      FLO2	EQU 0C2H	; Sector
   21         00C3      FLO3	EQU 0C3H	; Data
   22         00C4      FLO4	EQU 0C4H	; Special FLO-Flags
   23                   
   24                   ; IO ADDESSES FLO1 Maxi
   25         0040      FLOA0	EQU 040H
   26         0041      FLOA1	EQU 041H
   27         0042      FLOA2	EQU 042H
   28         0043      FLOA3	EQU 043H
   29         0044      FLOA4	EQU 044H
   30                   
   31                   ; IO ADDESSES FLO1 Mini
   32         0030      FLOB0	EQU 030H
   33         0031      FLOB1	EQU 031H
   34         0032      FLOB2	EQU 032H
   35         0033      FLOB3	EQU 033H
   36         0034      FLOB4	EQU 034H
   37                   
   38                   ;-----------------------------------------------------------------------------
   39                   
   40 0100  C3 070E     	JP START 	; Hauptprogramm
   41                   
   42                   ;-----------------------------------------------------------------------------
   43                   
   44 0103  C3 F009     CONOUT:	JP 0F009H 	; Ausgabe eines Zeichens in C
   45                   
   46                   ;-----------------------------------------------------------------------------
   47                   
   48 0106  CD F003     CONIN:	CALL 0F003H 	; Eingabe eines Zeichens nach A
   49 0109  E6 7F       	AND 7FH
   50 010B  C9          	RET
   51                   
   52                   ;-----------------------------------------------------------------------------
   53                   ; Interrupt routine
   54                   
   55 010C  F1          INTR:	POP AF
   56                   	; reset interrupts
   57 010D  DB 40       	IN A,(FLOA0)
   58 010F  DB 30       	IN A,(FLOB0)
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   2
UFORMAT Z80

   59 0111  DB C0       	IN A,(FLO0)
   60 0113  FB          	EI
   61 0114  ED 4D       	RETI
   62                   
   63                   ;-----------------------------------------------------------------------------
   64                   ; Universal Formatter
   65                   
   66 0116  21 156C     FORMAT:	LD HL,FMSG 
   67 0119  CD 0B99     	CALL PRNMSG
   68                   	
   69                   	; reset interrupts
   70 011C  DB 40       	IN A,(FLOA0) 	; ggf. bei gemischtem Betrieb auch
   71 011E  DB 30       	IN A,(FLOB0)   	; andere Ports loeschen
   72 0120  DB C0       	IN A,(FLO0) 	; alle Interrupts loeschen
   73                   
   74 0122  ED 56       	IM 1  		; MODE 1, RST-7 verwenden
   75 0124  3E C3       	LD A,0C3H 	; Sprungvektor setzen (JP)
   76 0126  32 0038     	LD (38H),A
   77 0129  21 010C     	LD HL,INTR
   78 012C  22 0039     	LD (39H),HL 	; auf Interruptroutine
   79                   
   80                   	; --- format ---------------------------------------------------------
   81                   
   82 012F  CD 048E     	CALL HOME 	; set head to track 0
   83                   
   84 0132  AF          	XOR A
   85 0133  32 18C7     	LD (CURTRK),A  	; start with track 0
   86 0136  3A 18C1     	LD A,(TRKCNT) 	; number of tracks
   87 0139  47          	LD B,A
   88                   
   89 013A              FORM1:	; format loop (tracks)
   90                   
   91                   	; --- format side 0 ---
   92                   	
   93 013A  C5          	PUSH BC
   94 013B  CD 01F3     	CALL ECMACHK 	; check if track 0 and ECMA70
   95 013E  CD 02E3     	CALL GENTRK 	; create track
   96 0141  CD 0674     	CALL FRMTRK 	; format track
   97 0144  CD 0245     	CALL ERRCHK
   98                   	
   99 0147  3A 18C2     	LD A,(SSDS)
  100 014A  FE 01       	CP 1
  101 014C  C2 0178     	JP NZ,FORM3	; -> single sided
  102                   
  103                   	; --- double-sided,. format side 1 ---
  104                   	
  105 014F  3A 18C4     	LD A,(DRIVE)	; Rueckseite setzen
  106 0152  F6 80       	OR 80H  	; aber kein Side-sel
  107 0154  32 18C4     	LD (DRIVE),A
  108                   
  109 0157  3A 18C6     	LD A,(USESSO)
  110 015A  B7          	OR A
  111 015B  CA 0163     	JP Z,FORM2	; -> no SSO
  112                   	
  113                   	; SSO
  114 015E  3E 80       	LD A,80H 
  115 0160  32 18C5     	LD (SIDESEL),A 	; setzen
  116                   
