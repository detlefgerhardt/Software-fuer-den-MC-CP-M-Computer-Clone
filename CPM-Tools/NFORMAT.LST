  143                   	; verify -------------------------------------------------------------
  144                   	
  145 0192  21 1838     	LD HL,VMSG
  146 0195  CD 0B99     	CALL PRNMSG
  147                   	
  148 0198  CD 048E     	CALL HOME	; set head to track 0
  149                   	
  150 019B  AF          	XOR A
