Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   1
NBOOT   Z80

    1                   	.Z80
    2                   	
    3                   ;*****************************************************************************
    4                   ; NBOOT.Z80
    5                   ;
    6                   ; Boot loader for MC CP/M-Computer Mini drive
    7                   ;
    8                   ; based on BOOZ80 by Rolf-Dieter Klein 841204 1.0
    9                   ;
   10                   ;*****************************************************************************
   11                   ; 80 Spur Laufwerke   1K pro Sektor Boot        *
   12                   ; das programm wird auf sektor 1 track 0 abgelegt
   13                   ;
   14                   ; PLEASE NOTE THE CHANGED CPM & BIOS START ADDRESS!!!
   15                   ;
   16                   ; Version history
   17                   ;
   18                   ; 10.07.2026 *dg* Renamed to NBOOT and reformatted source code
   19                   ; 11.07.2026 *dg* Use new floppy routine 0F021h in Monitor
   20                   
   21                   
   22         9800      OFFSET	EQU 0A000H-800H		; damit BIOS Start bei E200h
   23         CC00      CPMB	EQU 03400H+OFFSET	; start CP/M
   24         E200      BIOS	EQU 04A00H+OFFSET	; start BIOS
   25                   
   26                   ; sector count (1024 byte sectors)
   27                   ; on a mini disk 4 tracks are reserved: 5 * 4 - 1 = 19 sectors
   28         0009      SECCNT	EQU (0F000h-CPMB)/1024
   29                   ;SECCNT	EQU 7
   30                   
   31                   ; Monitor functions
   32         F01E      RSTRT	EQU 0F01EH	; restart
   33         F021      FLOP	EQU 0F021H	; Montior Floppy routine
   34         F027      MINI	EQU 0F027H	; Old MINI routine in Monitor (obsolete)
   35                   
   36                   ;-----------------------------------------------------------------------------
   37                   
   38         0080      	ORG 080H	; boot loader is loaded to this address
   39                   
   40 0080  31 0100     BOOT:	LD SP,100H	; start of stack
   41                   
   42 0083  21 CC00     	LD HL,CPMB	; CP/M start address
   43 0086  06 09       	LD B,SECCNT
   44                   	
   45                   	; start with track 0 and sector 2 (sector 1 is boot sector)
   46 0088  16 00       	LD D,0		; track
   47 008A  1E 02       	LD E,2		; sector
   48                   
   49 008C  E5          BOOT1:	PUSH HL
   50 008D  D5          	PUSH DE
   51 008E  C5          	PUSH BC
   52                   	;LD C,11010000B	; drive 0 double dense mini
   53                   	;LD B,1		; 1 = read 
   54                   	;CALL MINI	; Monitor Einsprung Mini Laufwerk
   55                   	; use new floppy routine instead
   56 008F  0E 21       	LD C,00100001B	; drive 0, dd, mini
   57 0091  06 01       	LD B,1		; 1 = read
   58 0093  CD F021     	CALL FLOP	; -> read sector
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   2
NBOOT   Z80

   59 0096  C1          	POP BC
   60 0097  D1          	POP DE
   61 0098  E1          	POP HL
   62 0099  DA F01E     	JP C,RSTRT	; call Monitor if error (Restart)
   63                   
   64 009C  D5          	PUSH DE		; NEXT ADRESSE
   65 009D  11 0400     	LD DE,1024	; double dense bloecke
   66 00A0  19          	ADD HL,DE
   67 00A1  D1          	POP DE
   68 00A2  1C          	INC E		; SEKTORANZAHL + 1
   69 00A3  7B          	LD A,E
   70 00A4  FE 06       	CP 5+1		; 1..5  erst bei 6 neue Spur (4 max)
   71 00A6  DA 00AC     	JP C,BOOT2
   72                   
   73                   	; new track
   74 00A9  1E 01       	LD E,1		; start again with sector 1
   75 00AB  14          	INC D
   76                   
   77 00AC  05          BOOT2:	DEC B
   78 00AD  C2 008C     	JP NZ,BOOT1	; solange bis fertig
   79                   	
   80 00B0  C3 E200     	JP BIOS		; start coldbios
   81                   
   82                   ;-----------------------------------------------------------------------------
   83                   
   84                   	END
 0 Error(s) Detected.
 128 Absolute Bytes. 10 Symbols Detected.
(Restart)
   63                   
   64 009C  D5          	PUSH DE		; NEXT ADRESSE
