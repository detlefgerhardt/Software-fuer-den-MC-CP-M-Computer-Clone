Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   1
BOOT80  Z80

    1                   	.Z80
    2                   ;*************************************************
    3                   ;* Cold - Boot Programm fuer Minilaufwerke       *
    4                   ;* Rolf-Dieter Klein 841204    1.0               *
    5                   ;* 80 Spur Laufwerke   1K pro Sektor Boot        *
    6                   ;*************************************************
    7                   
    8                   ; das programm wird auf sektor 1 track 0 abgelegt
    9                   
   10                   		
   11                   
   12         9800      OFFSET		EQU	09800H		;damit BIOS Start bei E200h
   13         CC00      CPMB		EQU	03400H+OFFSET	;start cp/m
   14         E200      BIOS		EQU	04A00H+OFFSET	;start bios
   15                   
   16         0080      		ORG	080H			;Ladeadresse
   17 0080              WBOOT0:
   18                   ;
   19 0080  31 0100     		LD	SP,100H		;start of stack
   20                   ;
   21 0083  21 CC00     		LD	HL,CPMB		;START ADRESSE
   22 0086  06 07       		LD	B,7			;ANZAHL DER SEKTOREN  A 1024 BYTES
   23                   						; fuellt genau bis 0EFFF
   24                   						;1c00h bytes (groesser als std 34h/8)
   25 0088  16 00       		LD	D,0			;START BEI TRACK 0 Sektor 2, da 1 bootsektor
   26 008A  1E 02       		LD	E,2			;1..5 SEKTOR
   27 008C              RDSEC:
   28 008C  E5          		PUSH	HL
   29 008D  D5          		PUSH	DE
   30 008E  C5          		PUSH	BC
   31 008F  0E D0       		LD	C,11010000B	;laufwerk 0 double dense mini
   32 0091  06 01       		LD	B,1			;read  bei sysgen 2 setzen
   33 0093  CD F027     		CALL	0F027H		;Monitor Einsprung Mini Laufwerk
   34 0096  C1          		POP	BC
   35 0097  D1          		POP	DE
   36 0098  E1          		POP	HL
   37 0099  DA F01E     		JP	C,0F01EH		;monitor aufrufen bei fehler (Restart)
   38 009C  D5          		PUSH	DE			;NEXT ADRESSE
   39 009D  11 0400     		LD	DE,1024		;double dense bloecke
   40 00A0  19          		ADD	HL,DE
   41 00A1  D1          		POP	DE
   42 00A2  1C          		INC	E			;SEKTORANZAHL + 1
   43 00A3  7B          		LD	A,E
   44 00A4  FE 06       		CP	5+1			;1..5  erst bei 6 neue Spur (4 max)
   45 00A6  DA 00AC     		JP	C,RD1
   46 00A9  1E 01       		LD	E,1			;START OVER
   47 00AB  14          		INC	D
   48 00AC  05          RD1:		DEC	B
   49 00AD  C2 008C     		JP	NZ,RDSEC		;solange bis fertig
   50 00B0  C3 E200     		JP	BIOS			;start coldbios
   51                   
   52                   		END
