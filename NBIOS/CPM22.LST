  465 D683  FE 3A       	CP	':'
  466 D685  CA 0000#    	JP	Z,CONVRT2
  467 D688  1B          	DEC	DE		;nope, move pointer back to the start of the line.
  468 D689  3A 0000#    CONVRT1:LD	A,(CDRIVE)
  469 D68C  77          	LD	(HL),A
  470 D68D  C3 0000#    	JP	CONVRT3
  471 D690  78          CONVRT2:LD	A,B
  472 D691  32 0000#    	LD	(CHGDRV),A	;set change in drives flag.
  473 D694  70          	LD	(HL),B
  474 D695  13          	INC	DE
  475                   ;
  476                   ;   Convert the basic file name.
  477                   ;
  478 D696  06 08       CONVRT3:LD	B,08H
  479 D698  CD D630     CONVRT4:CALL	CHECK
  480 D69B  CA 0000#    	JP	Z,CONVRT8
  481 D69E  23          	INC	HL
  482 D69F  FE 2A       	CP	'*'		;note that an '*' will fill the remaining
  483 D6A1  C2 0000#    	JP	NZ,CONVRT5	;field with '?'.
  484 D6A4  36 3F       	LD	(HL),'?'
  485 D6A6  C3 0000#    	JP	CONVRT6
  486 D6A9  77          CONVRT5:LD	(HL),A
  487 D6AA  13          	INC	DE
  488 D6AB  05          CONVRT6:DEC	B
  489 D6AC  C2 D698     	JP	NZ,CONVRT4
  490 D6AF  CD D630     CONVRT7:CALL	CHECK		;get next delimiter.
  491 D6B2  CA 0000#    	JP	Z,GETEXT
  492 D6B5  13          	INC	DE
  493 D6B6  C3 D6AF     	JP	CONVRT7
  494 D6B9  23          CONVRT8:INC	HL		;blank fill the file name.
  495 D6BA  36 20       	LD	(HL),' '
  496 D6BC  05          	DEC	B
  497 D6BD  C2 D6B9     	JP	NZ,CONVRT8
  498                   ;
  499                   ;   Get the extension and convert it.
  500                   ;
  501 D6C0  06 03       GETEXT:	LD	B,03H
  502 D6C2  FE 2E       	CP	'.'
  503 D6C4  C2 0000#    	JP	NZ,GETEXT5
  504 D6C7  13          	INC	DE
  505 D6C8  CD D630     GETEXT1:CALL	CHECK
  506 D6CB  CA 0000#    	JP	Z,GETEXT5
  507 D6CE  23          	INC	HL
  508 D6CF  FE 2A       	CP	'*'
  509 D6D1  C2 0000#    	JP	NZ,GETEXT2
  510 D6D4  36 3F       	LD	(HL),'?'
  511 D6D6  C3 0000#    	JP	GETEXT3
  512 D6D9  77          GETEXT2:LD	(HL),A
  513 D6DA  13          	INC	DE
  514 D6DB  05          GETEXT3:DEC	B
  515 D6DC  C2 D6C8     	JP	NZ,GETEXT1
  516 D6DF  CD D630     GETEXT4:CALL	CHECK
  517 D6E2  CA 0000#    	JP	Z,GETEXT6
  518 D6E5  13          	INC	DE
  519 D6E6  C3 D6DF     	JP	GETEXT4
  520 D6E9  23          GETEXT5:INC	HL
  521 D6EA  36 20       	LD	(HL),' '
  522 D6EC  05          	DEC	B
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  10
CPM22   Z80

  523 D6ED  C2 D6E9     	JP	NZ,GETEXT5
  524 D6F0  06 03       GETEXT6:LD	B,3
  525 D6F2  23          GETEXT7:INC	HL
  526 D6F3  36 00       	LD	(HL),0
  527 D6F5  05          	DEC	B
  528 D6F6  C2 D6F2     	JP	NZ,GETEXT7
  529 D6F9  EB          	EX	DE,HL
  530 D6FA  22 D488     	LD	(INPOINT),HL	;save input line pointer.
  531 D6FD  E1          	POP	HL
  532                   ;
  533                   ;   Check to see if this is an ambigeous file name specification.
  534                   ; Set the (A) register to non zero if it is.
  535                   ;
  536 D6FE  01 000B     	LD	BC,11		;set name length.
  537 D701  23          GETEXT8:INC	HL
  538 D702  7E          	LD	A,(HL)
  539 D703  FE 3F       	CP	'?'		;any question marks?
  540 D705  C2 0000#    	JP	NZ,GETEXT9
  541 D708  04          	INC	B		;count them.
  542 D709  0D          GETEXT9:DEC	C
  543 D70A  C2 D701     	JP	NZ,GETEXT8
  544 D70D  78          	LD	A,B
  545 D70E  B7          	OR	A
  546 D70F  C9          	RET	
  547                   ;
  548                   ;   CP/M command table. Note commands can be either 3 or 4 characters long.
  549                   ;
  550         0006      NUMCMDS: EQU	6		;number of commands
  551 D710  44 49 52 20 CMDTBL:	DEFM	"DIR "
  552 D714  45 52 41 20 	DEFM	"ERA "
  553 D718  54 59 50 45 	DEFM	"TYPE"
  554 D71C  53 41 56 45 	DEFM	"SAVE"
  555 D720  52 45 4E 20 	DEFM	"REN "
  556 D724  55 53 45 52 	DEFM	"USER"
  557                   ;
  558                   ;   The following six bytes must agree with those at (PATTRN2)
  559                   ; or cp/m will HALT. Why?
  560                   ;
  561 D728  00 16 00 00 PATTRN1:DB	0,22,0,0,0,0	;(* serial number bytes *).
  562                   ;
  563                   ;   Search the command table for a match with what has just
  564                   ; been entered. If a match is found, then we jump to the
  565                   ; proper section. Else jump to (UNKNOWN).
  566                   ; On return, the (C) register is set to the command number
  567                   ; that matched (or NUMCMDS+1 if no match).
  568                   ;
  569 D72E  21 D710     SEARCH:	LD	HL,CMDTBL
  570 D731  0E 00       	LD	C,0
  571 D733  79          SEARCH1:LD	A,C
  572 D734  FE 06       	CP	NUMCMDS		;this commands exists.
  573 D736  D0          	RET	NC
  574 D737  11 ????     	LD	DE,FCB+1	;check this one.
  575 D73A  06 04       	LD	B,4		;max command length.
  576 D73C  1A          SEARCH2:LD	A,(DE)
  577 D73D  BE          	CP	(HL)
  578 D73E  C2 0000#    	JP	NZ,SEARCH3	;not a match.
  579 D741  13          	INC	DE
  580 D742  23          	INC	HL
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  11
CPM22   Z80

  581 D743  05          	DEC	B
  582 D744  C2 D73C     	JP	NZ,SEARCH2
  583 D747  1A          	LD	A,(DE)		;allow a 3 character command to match.
  584 D748  FE 20       	CP	' '
  585 D74A  C2 0000#    	JP	NZ,SEARCH4
  586 D74D  79          	LD	A,C		;set return register for this command.
  587 D74E  C9          	RET	
  588 D74F  23          SEARCH3:INC	HL
  589 D750  05          	DEC	B
  590 D751  C2 D74F     	JP	NZ,SEARCH3
  591 D754  0C          SEARCH4:INC	C
  592 D755  C3 D733     	JP	SEARCH1
  593                   ;
  594                   ;   Set the input buffer to empty and then start the command
  595                   ; processor (ccp).
  596                   ;
  597 D758  AF          CLEARBUF: XOR	A
  598 D759  32 D407     	LD	(INBUFF+1),A	;second byte is actual length.
  599                   ;
  600                   ;**************************************************************
  601                   ;*
  602                   ;*
  603                   ;* C C P  -   C o n s o l e   C o m m a n d   P r o c e s s o r
  604                   ;*
  605                   ;**************************************************************
  606                   ;*
  607 D75C  31 0000#    COMMAND:LD	SP,CCPSTACK	;setup stack area.
  608 D75F  C5          	PUSH	BC		;note that (C) should be equal to:
  609 D760  79          	LD	A,C		;(uuuudddd) where 'uuuu' is the user number
  610 D761  1F          	RRA			;and 'dddd' is the drive number.
  611 D762  1F          	RRA	
  612 D763  1F          	RRA	
  613 D764  1F          	RRA	
  614 D765  E6 0F       	AND	0FH		;isolate the user number.
  615 D767  5F          	LD	E,A
  616 D768  CD D515     	CALL	GETSETUC	;and set it.
  617 D76B  CD D4B8     	CALL	RESDSK		;reset the disk system.
  618 D76E  32 0000#    	LD	(BATCH),A	;clear batch mode flag.
  619 D771  C1          	POP	BC
  620 D772  79          	LD	A,C
  621 D773  E6 0F       	AND	0FH		;isolate the drive number.
  622 D775  32 0000#    	LD	(CDRIVE),A	;and save.
  623 D778  CD D4BD     	CALL	DSKSEL		;...and select.
  624 D77B  3A D407     	LD	A,(INBUFF+1)
  625 D77E  B7          	OR	A		;anything in input buffer already?
  626 D77F  C2 0000#    	JP	NZ,CMMND2	;yes, we just process it.
  627                   ;
  628                   ;   Entry point to get a command line from the console.
  629                   ;
  630 D782  31 0000#    CMMND1:	LD	SP,CCPSTACK	;set stack straight.
  631 D785  CD D498     	CALL	CRLF		;start a new line on the screen.
  632 D788  CD D5D0     	CALL	GETDSK		;get current drive.
  633 D78B  C6 41       	ADD	A,'A'
  634 D78D  CD D48C     	CALL	PRINT		;print current drive.
  635 D790  3E 3E       	LD	A,'>'
  636 D792  CD D48C     	CALL	PRINT		;and add prompt.
  637 D795  CD D539     	CALL	GETINP		;get line from user.
  638                   ;
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  12
CPM22   Z80

  639                   ;   Process command line here.
  640                   ;
  641 D798  11 0080     CMMND2:	LD	DE,TBUFF
  642 D79B  CD D5D8     	CALL	DMASET		;set standard dma address.
  643 D79E  CD D5D0     	CALL	GETDSK
  644 D7A1  32 0000#    	LD	(CDRIVE),A	;set current drive.
  645 D7A4  CD D65E     	CALL	CONVFST		;convert name typed in.
  646 D7A7  C4 D609     	CALL	NZ,SYNERR	;wild cards are not allowed.
  647 D7AA  3A 0000#    	LD	A,(CHGDRV)	;if a change in drives was indicated,
  648 D7AD  B7          	OR	A		;then treat this as an unknown command
  649 D7AE  C2 0000#    	JP	NZ,UNKNOWN	;which gets executed.
  650 D7B1  CD D72E     	CALL	SEARCH		;else search command table for a match.
  651                   ;
  652                   ;   Note that an unknown command returns
  653                   ; with (A) pointing to the last address
  654                   ; in our table which is (UNKNOWN).
  655                   ;
  656 D7B4  21 0000#    	LD	HL,CMDADR	;now, look thru our address table for command (A).
  657 D7B7  5F          	LD	E,A		;set (DE) to command number.
  658 D7B8  16 00       	LD	D,0
  659 D7BA  19          	ADD	HL,DE
  660 D7BB  19          	ADD	HL,DE		;(HL)=(CMDADR)+2*(command number).
  661 D7BC  7E          	LD	A,(HL)		;now pick out this address.
  662 D7BD  23          	INC	HL
  663 D7BE  66          	LD	H,(HL)
  664 D7BF  6F          	LD	L,A
  665 D7C0  E9          	JP	(HL)		;now execute it.
  666                   ;
  667                   ;   CP/M command address table.
  668                   ;
  669 D7C1  0000# 0000# CMDADR:	DW	DIRECT,ERASE,TYPE,SAVE
  670 D7C9  0000# 0000# 	DW	RENAME,USER,UNKNOWN
  671                   ;
  672                   ;   Halt the system. Reason for this is unknown at present.
  673                   ;
  674 D7CF  21 76F3     HALT:	LD	HL,76F3H	;'DI HLT' instructions.
  675 D7D2  22 D400     	LD	(CBASE),HL
  676 D7D5  21 D400     	LD	HL,CBASE
  677 D7D8  E9          	JP	(HL)
  678                   ;
  679                   ;   Read error while TYPEing a file.
  680                   ;
  681 D7D9  01 0000#    RDERROR:LD	BC,RDERR
  682 D7DC  C3 D4A7     	JP	PLINE
  683 D7DF  52 65 61 64 RDERR:	DEFM	"Read error"
  684 D7E9  00          	DB	0
  685                   ;
  686                   ;   Required file was not located.
  687                   ;
  688 D7EA  01 0000#    NONE:	LD	BC,NOFILE
  689 D7ED  C3 D4A7     	JP	PLINE
  690 D7F0  4E 6F 20 66 NOFILE:	DEFM	"No file"
  691 D7F7  00          	DB	0
  692                   ;
  693                   ;   Decode a command of the form 'A>filename number{ filename}.
  694                   ; Note that a drive specifier is not allowed on the first file
  695                   ; name. On return, the number is in register (A). Any error
  696                   ; causes 'filename?' to be printed and the command is aborted.
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  13
CPM22   Z80

  697                   ;
  698 D7F8  CD D65E     DECODE:	CALL	CONVFST		;convert filename.
  699 D7FB  3A 0000#    	LD	A,(CHGDRV)	;do not allow a drive to be specified.
  700 D7FE  B7          	OR	A
  701 D7FF  C2 D609     	JP	NZ,SYNERR
  702 D802  21 ????     	LD	HL,FCB+1	;convert number now.
  703 D805  01 000B     	LD	BC,11		;(B)=sum register, (C)=max digit count.
  704 D808  7E          DECODE1:LD	A,(HL)
  705 D809  FE 20       	CP	' '		;a space terminates the numeral.
  706 D80B  CA 0000#    	JP	Z,DECODE3
  707 D80E  23          	INC	HL
  708 D80F  D6 30       	SUB	'0'		;make binary from ascii.
  709 D811  FE 0A       	CP	10		;legal digit?
  710 D813  D2 D609     	JP	NC,SYNERR
  711 D816  57          	LD	D,A		;yes, save it in (D).
  712 D817  78          	LD	A,B		;compute (B)=(B)*10 and check for overflow.
  713 D818  E6 E0       	AND	0E0H
  714 D81A  C2 D609     	JP	NZ,SYNERR
  715 D81D  78          	LD	A,B
  716 D81E  07          	RLCA	
  717 D81F  07          	RLCA	
  718 D820  07          	RLCA			;(A)=(B)*8
  719 D821  80          	ADD	A,B		;.......*9
  720 D822  DA D609     	JP	C,SYNERR
  721 D825  80          	ADD	A,B		;.......*10
  722 D826  DA D609     	JP	C,SYNERR
  723 D829  82          	ADD	A,D		;add in new digit now.
  724 D82A  DA D609     DECODE2:JP	C,SYNERR
  725 D82D  47          	LD	B,A		;and save result.
  726 D82E  0D          	DEC	C		;only look at 11 digits.
  727 D82F  C2 D808     	JP	NZ,DECODE1
  728 D832  C9          	RET	
  729 D833  7E          DECODE3:LD	A,(HL)		;spaces must follow (why?).
  730 D834  FE 20       	CP	' '
  731 D836  C2 D609     	JP	NZ,SYNERR
  732 D839  23          	INC	HL
  733 D83A  0D          DECODE4:DEC	C
  734 D83B  C2 D833     	JP	NZ,DECODE3
  735 D83E  78          	LD	A,B		;set (A)=the numeric value entered.
  736 D83F  C9          	RET	
  737                   ;
  738                   ;   Move 3 bytes from (HL) to (DE). Note that there is only
  739                   ; one reference to this at (A2D5h).
  740                   ;
  741 D840  06 03       MOVE3:	LD	B,3
  742                   ;
  743                   ;   Move (B) bytes from (HL) to (DE).
  744                   ;
  745 D842  7E          HL2DE:	LD	A,(HL)
  746 D843  12          	LD	(DE),A
  747 D844  23          	INC	HL
  748 D845  13          	INC	DE
  749 D846  05          	DEC	B
  750 D847  C2 D842     	JP	NZ,HL2DE
  751 D84A  C9          	RET	
  752                   ;
  753                   ;   Compute (HL)=(TBUFF)+(A)+(C) and get the byte that's here.
  754                   ;
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  14
CPM22   Z80

  755 D84B  21 0080     EXTRACT:LD	HL,TBUFF
  756 D84E  81          	ADD	A,C
  757 D84F  CD D659     	CALL	ADDHL
  758 D852  7E          	LD	A,(HL)
  759 D853  C9          	RET	
  760                   ;
  761                   ;  Check drive specified. If it means a change, then the new
  762                   ; drive will be selected. In any case, the drive byte of the
  763                   ; fcb will be set to null (means use current drive).
  764                   ;
  765 D854  AF          DSELECT:XOR	A		;null out first byte of fcb.
  766 D855  32 0000#    	LD	(FCB),A
  767 D858  3A 0000#    	LD	A,(CHGDRV)	;a drive change indicated?
  768 D85B  B7          	OR	A
  769 D85C  C8          	RET	Z
  770 D85D  3D          	DEC	A		;yes, is it the same as the current drive?
  771 D85E  21 0000#    	LD	HL,CDRIVE
  772 D861  BE          	CP	(HL)
  773 D862  C8          	RET	Z
  774 D863  C3 D4BD     	JP	DSKSEL		;no. Select it then.
  775                   ;
  776                   ;   Check the drive selection and reset it to the previous
  777                   ; drive if it was changed for the preceeding command.
  778                   ;
  779 D866  3A 0000#    RESETDR:LD	A,(CHGDRV)	;drive change indicated?
  780 D869  B7          	OR	A
  781 D86A  C8          	RET	Z
  782 D86B  3D          	DEC	A		;yes, was it a different drive?
  783 D86C  21 0000#    	LD	HL,CDRIVE
  784 D86F  BE          	CP	(HL)
  785 D870  C8          	RET	Z
  786 D871  3A 0000#    	LD	A,(CDRIVE)	;yes, re-select our old drive.
  787 D874  C3 D4BD     	JP	DSKSEL
  788                   ;
  789                   ;**************************************************************
  790                   ;*
  791                   ;*           D I R E C T O R Y   C O M M A N D
  792                   ;*
  793                   ;**************************************************************
  794                   ;
  795 D877  CD D65E     DIRECT:	CALL	CONVFST		;convert file name.
  796 D87A  CD D854     	CALL	DSELECT		;select indicated drive.
  797 D87D  21 ????     	LD	HL,FCB+1	;was any file indicated?
  798 D880  7E          	LD	A,(HL)
  799 D881  FE 20       	CP	' '
  800 D883  C2 0000#    	JP	NZ,DIRECT2
  801 D886  06 0B       	LD	B,11		;no. Fill field with '?' - same as *.*.
  802 D888  36 3F       DIRECT1:LD	(HL),'?'
  803 D88A  23          	INC	HL
  804 D88B  05          	DEC	B
  805 D88C  C2 D888     	JP	NZ,DIRECT1
  806 D88F  1E 00       DIRECT2:LD	E,0		;set initial cursor position.
  807 D891  D5          	PUSH	DE
  808 D892  CD D4E9     	CALL	SRCHFCB		;get first file name.
  809 D895  CC D7EA     	CALL	Z,NONE		;none found at all?
  810 D898  CA 0000#    DIRECT3:JP	Z,DIRECT9	;terminate if no more names.
  811 D89B  3A 0000#    	LD	A,(RTNCODE)	;get file's position in segment (0-3).
  812 D89E  0F          	RRCA	
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  15
CPM22   Z80

  813 D89F  0F          	RRCA	
  814 D8A0  0F          	RRCA	
  815 D8A1  E6 60       	AND	60H		;(A)=position*32
  816 D8A3  4F          	LD	C,A
  817 D8A4  3E 0A       	LD	A,10
  818 D8A6  CD D84B     	CALL	EXTRACT		;extract the tenth entry in fcb.
  819 D8A9  17          	RLA			;check system file status bit.
  820 D8AA  DA 0000#    	JP	C,DIRECT8	;we don't list them.
  821 D8AD  D1          	POP	DE
  822 D8AE  7B          	LD	A,E		;bump name count.
  823 D8AF  1C          	INC	E
  824 D8B0  D5          	PUSH	DE
  825 D8B1  E6 03       	AND	03H		;at end of line?
  826 D8B3  F5          	PUSH	AF
  827 D8B4  C2 0000#    	JP	NZ,DIRECT4
  828 D8B7  CD D498     	CALL	CRLF		;yes, end this line and start another.
  829 D8BA  C5          	PUSH	BC
  830 D8BB  CD D5D0     	CALL	GETDSK		;start line with ('A:').
  831 D8BE  C1          	POP	BC
  832 D8BF  C6 41       	ADD	A,'A'
  833 D8C1  CD D492     	CALL	PRINTB
  834 D8C4  3E 3A       	LD	A,':'
  835 D8C6  CD D492     	CALL	PRINTB
  836 D8C9  C3 0000#    	JP	DIRECT5
  837 D8CC  CD D4A2     DIRECT4:CALL	SPACE		;add seperator between file names.
  838 D8CF  3E 3A       	LD	A,':'
  839 D8D1  CD D492     	CALL	PRINTB
  840 D8D4  CD D4A2     DIRECT5:CALL	SPACE
  841 D8D7  06 01       	LD	B,1		;'extract' each file name character at a time.
  842 D8D9  78          DIRECT6:LD	A,B
  843 D8DA  CD D84B     	CALL	EXTRACT
  844 D8DD  E6 7F       	AND	7FH		;strip bit 7 (status bit).
  845 D8DF  FE 20       	CP	' '		;are we at the end of the name?
  846 D8E1  C2 0000#    	JP	NZ,DRECT65
  847 D8E4  F1          	POP	AF		;yes, don't print spaces at the end of a line.
  848 D8E5  F5          	PUSH	AF
  849 D8E6  FE 03       	CP	3
  850 D8E8  C2 0000#    	JP	NZ,DRECT63
  851 D8EB  3E 09       	LD	A,9		;first check for no extension.
  852 D8ED  CD D84B     	CALL	EXTRACT
  853 D8F0  E6 7F       	AND	7FH
  854 D8F2  FE 20       	CP	' '
  855 D8F4  CA 0000#    	JP	Z,DIRECT7	;don't print spaces.
  856 D8F7  3E 20       DRECT63:LD	A,' '		;else print them.
  857 D8F9  CD D492     DRECT65:CALL	PRINTB
  858 D8FC  04          	INC	B		;bump to next character psoition.
  859 D8FD  78          	LD	A,B
  860 D8FE  FE 0C       	CP	12		;end of the name?
  861 D900  D2 0000#    	JP	NC,DIRECT7
  862 D903  FE 09       	CP	9		;nope, starting extension?
  863 D905  C2 D8D9     	JP	NZ,DIRECT6
  864 D908  CD D4A2     	CALL	SPACE		;yes, add seperating space.
  865 D90B  C3 D8D9     	JP	DIRECT6
  866 D90E  F1          DIRECT7:POP	AF		;get the next file name.
  867 D90F  CD D5C2     DIRECT8:CALL	CHKCON		;first check console, quit on anything.
  868 D912  C2 0000#    	JP	NZ,DIRECT9
  869 D915  CD D4E4     	CALL	SRCHNXT		;get next name.
  870 D918  C3 D898     	JP	DIRECT3		;and continue with our list.
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  16
CPM22   Z80

  871 D91B  D1          DIRECT9:POP	DE		;restore the stack and return to command level.
  872 D91C  C3 0000#    	JP	GETBACK
  873                   ;
  874                   ;**************************************************************
  875                   ;*
  876                   ;*                E R A S E   C O M M A N D
  877                   ;*
  878                   ;**************************************************************
  879                   ;
  880 D91F  CD D65E     ERASE:	CALL	CONVFST		;convert file name.
  881 D922  FE 0B       	CP	11		;was '*.*' entered?
  882 D924  C2 0000#    	JP	NZ,ERASE1
  883 D927  01 0000#    	LD	BC,YESNO	;yes, ask for confirmation.
  884 D92A  CD D4A7     	CALL	PLINE
  885 D92D  CD D539     	CALL	GETINP
  886 D930  21 D407     	LD	HL,INBUFF+1
  887 D933  35          	DEC	(HL)		;must be exactly 'y'.
  888 D934  C2 D782     	JP	NZ,CMMND1
  889 D937  23          	INC	HL
  890 D938  7E          	LD	A,(HL)
  891 D939  FE 59       	CP	'Y'
  892 D93B  C2 D782     	JP	NZ,CMMND1
  893 D93E  23          	INC	HL
  894 D93F  22 D488     	LD	(INPOINT),HL	;save input line pointer.
  895 D942  CD D854     ERASE1:	CALL	DSELECT		;select desired disk.
  896 D945  11 0000#    	LD	DE,FCB
  897 D948  CD D4EF     	CALL	DELETE		;delete the file.
  898 D94B  3C          	INC	A
  899 D94C  CC D7EA     	CALL	Z,NONE		;not there?
  900 D94F  C3 0000#    	JP	GETBACK		;return to command level now.
  901 D952  41 6C 6C 20 YESNO:	DEFM	"All (y/n)?"
  902 D95C  00          	DB	0
  903                   ;
  904                   ;**************************************************************
  905                   ;*
  906                   ;*            T Y P E   C O M M A N D
  907                   ;*
  908                   ;**************************************************************
  909                   ;
  910 D95D  CD D65E     TYPE:	CALL	CONVFST		;convert file name.
  911 D960  C2 D609     	JP	NZ,SYNERR	;wild cards not allowed.
  912 D963  CD D854     	CALL	DSELECT		;select indicated drive.
  913 D966  CD D4D0     	CALL	OPENFCB		;open the file.
  914 D969  CA 0000#    	JP	Z,TYPE5		;not there?
  915 D96C  CD D498     	CALL	CRLF		;ok, start a new line on the screen.
  916 D96F  21 0000#    	LD	HL,NBYTES	;initialize byte counter.
  917 D972  36 FF       	LD	(HL),0FFH	;set to read first sector.
  918 D974  21 0000#    TYPE1:	LD	HL,NBYTES
  919 D977  7E          TYPE2:	LD	A,(HL)		;have we written the entire sector?
  920 D978  FE 80       	CP	128
  921 D97A  DA 0000#    	JP	C,TYPE3
  922 D97D  E5          	PUSH	HL		;yes, read in the next one.
  923 D97E  CD D4FE     	CALL	READFCB
  924 D981  E1          	POP	HL
  925 D982  C2 0000#    	JP	NZ,TYPE4	;end or error?
  926 D985  AF          	XOR	A		;ok, clear byte counter.
  927 D986  77          	LD	(HL),A
  928 D987  34          TYPE3:	INC	(HL)		;count this byte.
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  17
CPM22   Z80

  929 D988  21 0080     	LD	HL,TBUFF	;and get the (A)th one from the buffer (TBUFF).
  930 D98B  CD D659     	CALL	ADDHL
  931 D98E  7E          	LD	A,(HL)
  932 D98F  FE 1A       	CP	CNTRLZ		;end of file mark?
  933 D991  CA 0000#    	JP	Z,GETBACK
  934 D994  CD D48C     	CALL	PRINT		;no, print it.
  935 D997  CD D5C2     	CALL	CHKCON		;check console, quit if anything ready.
  936 D99A  C2 0000#    	JP	NZ,GETBACK
  937 D99D  C3 D974     	JP	TYPE1
  938                   ;
  939                   ;   Get here on an end of file or read error.
  940                   ;
  941 D9A0  3D          TYPE4:	DEC	A		;read error?
  942 D9A1  CA 0000#    	JP	Z,GETBACK
  943 D9A4  CD D7D9     	CALL	RDERROR		;yes, print message.
  944 D9A7  CD D866     TYPE5:	CALL	RESETDR		;and reset proper drive
  945 D9AA  C3 D609     	JP	SYNERR		;now print file name with problem.
  946                   ;
  947                   ;**************************************************************
  948                   ;*
  949                   ;*            S A V E   C O M M A N D
  950                   ;*
  951                   ;**************************************************************
  952                   ;
  953 D9AD  CD D7F8     SAVE:	CALL	DECODE		;get numeric number that follows SAVE.
  954 D9B0  F5          	PUSH	AF		;save number of pages to write.
  955 D9B1  CD D65E     	CALL	CONVFST		;convert file name.
  956 D9B4  C2 D609     	JP	NZ,SYNERR	;wild cards not allowed.
  957 D9B7  CD D854     	CALL	DSELECT		;select specified drive.
  958 D9BA  11 0000#    	LD	DE,FCB		;now delete this file.
  959 D9BD  D5          	PUSH	DE
  960 D9BE  CD D4EF     	CALL	DELETE
  961 D9C1  D1          	POP	DE
  962 D9C2  CD D509     	CALL	CREATE		;and create it again.
  963 D9C5  CA 0000#    	JP	Z,SAVE3		;can't create?
  964 D9C8  AF          	XOR	A		;clear record number byte.
  965 D9C9  32 ????     	LD	(FCB+32),A
  966 D9CC  F1          	POP	AF		;convert pages to sectors.
  967 D9CD  6F          	LD	L,A
  968 D9CE  26 00       	LD	H,0
  969 D9D0  29          	ADD	HL,HL		;(HL)=number of sectors to write.
  970 D9D1  11 0100     	LD	DE,TBASE	;and we start from here.
  971 D9D4  7C          SAVE1:	LD	A,H		;done yet?
  972 D9D5  B5          	OR	L
  973 D9D6  CA 0000#    	JP	Z,SAVE2
  974 D9D9  2B          	DEC	HL		;nope, count this and compute the start
  975 D9DA  E5          	PUSH	HL		;of the next 128 byte sector.
  976 D9DB  21 0080     	LD	HL,128
  977 D9DE  19          	ADD	HL,DE
  978 D9DF  E5          	PUSH	HL		;save it and set the transfer address.
  979 D9E0  CD D5D8     	CALL	DMASET
  980 D9E3  11 0000#    	LD	DE,FCB		;write out this sector now.
  981 D9E6  CD D504     	CALL	WRTREC
  982 D9E9  D1          	POP	DE		;reset (DE) to the start of the last sector.
  983 D9EA  E1          	POP	HL		;restore sector count.
  984 D9EB  C2 0000#    	JP	NZ,SAVE3	;write error?
  985 D9EE  C3 D9D4     	JP	SAVE1
  986                   ;
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  18
CPM22   Z80

  987                   ;   Get here after writing all of the file.
  988                   ;
  989 D9F1  11 0000#    SAVE2:	LD	DE,FCB		;now close the file.
  990 D9F4  CD D4DA     	CALL	CLOSE
  991 D9F7  3C          	INC	A		;did it close ok?
  992 D9F8  C2 0000#    	JP	NZ,SAVE4
  993                   ;
  994                   ;   Print out error message (no space).
  995                   ;
  996 D9FB  01 0000#    SAVE3:	LD	BC,NOSPACE
  997 D9FE  CD D4A7     	CALL	PLINE
  998 DA01  CD D5D5     SAVE4:	CALL	STDDMA		;reset the standard dma address.
  999 DA04  C3 0000#    	JP	GETBACK
