   11                   
   12         0000      FALSE	EQU 0
   13         FFFF      TRUE	EQU NOT FALSE
   14                   
   15         0000      DG01	EQU FALSE
   16                   
   17                   ;
   18                   ; Set memory limit here. This is the amount of contigeous
   19                   ; ram starting from 0000. CP/M will reside at the end of this space.
   20                   ; Origin D400H
   21                   ;
   22         0003      IOBYTE:	EQU	3		;i/o definition byte.
   23         0004      TDRIVE:	EQU	4		;current drive name and user number.
   24         0005      ENTRY:	EQU	5		;entry point for the cp/m bdos.
   25         005C      TFCB:	EQU	5CH			;default file control block.
   26         0080      TBUFF:	EQU	80H		;i/o buffer and command line storage.
   27         0100      TBASE:	EQU	100H		;transiant program storage area.
   28                   ;
   29                   ;   Set control character equates.
   30                   ;
   31         0003      CNTRLC:	EQU	3		;control-c
   32         0005      CNTRLE:	EQU	05H		;control-e
   33         0008      BS:	EQU	08H		;backspace
   34         0009      TAB:	EQU	09H		;tab
   35         000A      LF:	EQU	0AH		;line feed
   36         000C      FF:	EQU	0CH		;form feed
   37         000D      CR:	EQU	0DH		;carriage return
   38         0010      CNTRLP:	EQU	10H		;control-p
   39         0012      CNTRLR:	EQU	12H		;control-r
   40         0013      CNTRLS:	EQU	13H		;control-s
   41         0015      CNTRLU:	EQU	15H		;control-u
   42         0018      CNTRLX:	EQU	18H		;control-x
   43         001A      CNTRLZ:	EQU	1AH		;control-z (end-of-file mark)
   44         007F      DEL:	EQU	7FH		;rubout
   45                   ;
   46                   ;   Set origin for CP/M
   47                   ;
   48         CC00      	ORG	0D400H-800H
   49                   ;
   50 CC00  C3 CF5C     CBASE:	JP	COMMAND		;execute command processor (ccp).
   51 CC03  C3 CF58     	JP	CLEARBUF	;entry to empty input buffer before starting ccp.
   52                   
   53                   ;
   54                   ;   Standard cp/m ccp input buffer. Format is (max length),
   55                   ; (actual length), (char #1), (char #2), (char #3), etc.
   56                   ;
   57 CC06  7F          INBUFF:	DB	127		;length of input buffer.
   58 CC07  00          	DB	0		;current length of contents.
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   2
