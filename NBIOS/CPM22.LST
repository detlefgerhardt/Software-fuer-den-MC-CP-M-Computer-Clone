 3440                   ;   Function to return the current cp/m version number.
 3441                   ;
 3442 E880  3E 22       GETVER:	LD	A,022H		;version 2.2
 3443 E882  C3 DF03     	JP	SETSTAT
 3444                   ;
 3445                   ;   Function to reset the disk system.
 3446                   ;
 3447 E885  21 0000     RSTDSK:	LD	HL,0		;clear write protect status and log
 3448 E888  22 0000#    	LD	(WRTPRT),HL	;in vector.
 3449 E88B  22 0000#    	LD	(LOGIN),HL
