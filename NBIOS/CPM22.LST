 1004                   ;*
 1005                   ;*           R E N A M E   C O M M A N D
 1006                   ;*
 1007                   ;**************************************************************
 1008                   ;
 1009 DA10  CD D65E     RENAME:	CALL	CONVFST		;convert first file name.
 1010 DA13  C2 D609     	JP	NZ,SYNERR	;wild cards not allowed.
 1011 DA16  3A 0000#    	LD	A,(CHGDRV)	;remember any change in drives specified.
 1012 DA19  F5          	PUSH	AF
 1013 DA1A  CD D854     	CALL	DSELECT		;and select this drive.
 1014 DA1D  CD D4E9     	CALL	SRCHFCB		;is this file present?
 1015 DA20  C2 0000#    	JP	NZ,RENAME6	;yes, print error message.
 1016 DA23  21 0000#    	LD	HL,FCB		;yes, move this name into second slot.
 1017 DA26  11 ????     	LD	DE,FCB+16
 1018 DA29  06 10       	LD	B,16
 1019 DA2B  CD D842     	CALL	HL2DE
 1020 DA2E  2A D488     	LD	HL,(INPOINT)	;get input pointer.
 1021 DA31  EB          	EX	DE,HL
 1022 DA32  CD D64F     	CALL	NONBLANK	;get next non blank character.
 1023 DA35  FE 3D       	CP	'='		;only allow an '=' or '_' seperator.
 1024 DA37  CA 0000#    	JP	Z,RENAME1
 1025 DA3A  FE 5F       	CP	'_'
 1026 DA3C  C2 0000#    	JP	NZ,RENAME5
 1027 DA3F  EB          RENAME1:EX	DE,HL
 1028 DA40  23          	INC	HL		;ok, skip seperator.
 1029 DA41  22 D488     	LD	(INPOINT),HL	;save input line pointer.
 1030 DA44  CD D65E     	CALL	CONVFST		;convert this second file name now.
 1031 DA47  C2 0000#    	JP	NZ,RENAME5	;again, no wild cards.
 1032 DA4A  F1          	POP	AF		;if a drive was specified, then it
 1033 DA4B  47          	LD	B,A		;must be the same as before.
 1034 DA4C  21 0000#    	LD	HL,CHGDRV
 1035 DA4F  7E          	LD	A,(HL)
 1036 DA50  B7          	OR	A
 1037 DA51  CA 0000#    	JP	Z,RENAME2
 1038 DA54  B8          	CP	B
 1039 DA55  70          	LD	(HL),B
 1040 DA56  C2 0000#    	JP	NZ,RENAME5	;they were different, error.
 1041 DA59  70          RENAME2:LD	(HL),B		;	reset as per the first file specification.
 1042 DA5A  AF          	XOR	A
 1043 DA5B  32 0000#    	LD	(FCB),A		;clear the drive byte of the fcb.
 1044 DA5E  CD D4E9     RENAME3:CALL	SRCHFCB		;and go look for second file.
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  19
