 3017 E62C  32 0000#    	LD	(RELBLOCK),A	;and save.
 3018 E62F  01 0000     	LD	BC,0		;start looking for space from the start
 3019 E632  B7          	OR	A		;if none allocated as yet.
 3020 E633  CA 0000#    	JP	Z,WTSEQ2
 3021 E636  4F          	LD	C,A		;extract previous block number from fcb
 3022 E637  0B          	DEC	BC		;so we can be closest to it.
 3023 E638  CD E060     	CALL	EXTBLK
 3024 E63B  44          	LD	B,H
 3025 E63C  4D          	LD	C,L
 3026 E63D  CD E3C0     WTSEQ2:	CALL	FNDSPACE	;find the next empty block nearest number (BC).
 3027 E640  7D          	LD	A,L		;check for a zero number.
 3028 E641  B4          	OR	H
 3029 E642  C2 0000#    	JP	NZ,WTSEQ3
 3030 E645  3E 02       	LD	A,2		;no more space?
 3031 E647  C3 DF03     	JP	SETSTAT
 3032 E64A  22 0000#    WTSEQ3:	LD	(BLKNMBR),HL	;save block number to access.
 3033 E64D  EB          	EX	DE,HL		;put block number into (DE).
 3034 E64E  2A DF45     	LD	HL,(PARAMS)	;now we must update the fcb for this
 3035 E651  01 0010     	LD	BC,16		;newly allocated block.
 3036 E654  09          	ADD	HL,BC
 3037 E655  3A 0000#    	LD	A,(BIGDISK)	;8 or 16 bit block numbers?
 3038 E658  B7          	OR	A
 3039 E659  3A 0000#    	LD	A,(RELBLOCK)	;(* update this entry *)
 3040 E65C  CA 0000#    	JP	Z,WTSEQ4	;zero means 16 bit ones.
 3041 E65F  CD E166     	CALL	ADDA2HL		;(HL)=(HL)+(A)
 3042 E662  73          	LD	(HL),E		;store new block number.
 3043 E663  C3 0000#    	JP	WTSEQ5
