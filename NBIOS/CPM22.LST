  988 D1DF  E5          	PUSH	HL		;save it and set the transfer address.
  989 D1E0  CD CDD8     	CALL	DMASET
  990 D1E3  11 D3CD     	LD	DE,FCB		;write out this sector now.
  991 D1E6  CD CD04     	CALL	WRTREC
  992 D1E9  D1          	POP	DE		;reset (DE) to the start of the last sector.
  993 D1EA  E1          	POP	HL		;restore sector count.
  994 D1EB  C2 D1FB     	JP	NZ,SAVE3	;write error?
  995 D1EE  C3 D1D4     	JP	SAVE1
  996                   ;
  997                   ;   Get here after writing all of the file.
  998                   ;
  999 D1F1  11 D3CD     SAVE2:	LD	DE,FCB		;now close the file.
 1000 D1F4  CD CCDA     	CALL	CLOSE
 1001 D1F7  3C          	INC	A		;did it close ok?
 1002 D1F8  C2 D201     	JP	NZ,SAVE4
 1003                   ;
 1004                   ;   Print out error message (no space).
 1005                   ;
 1006 D1FB  01 D207     SAVE3:	LD	BC,NOSPACE
 1007 D1FE  CD CCA7     	CALL	PLINE
 1008 D201  CD CDD5     SAVE4:	CALL	STDDMA		;reset the standard dma address.
 1009 D204  C3 D386     	JP	GETBACK
 1010 D207  4E 6F 20 73 NOSPACE:DEFM	"No space"
 1011 D20F  00          	DB	0
 1012                   ;
