 3532 E0EE  CD D974     FCREATE:CALL	CLEARS2		;clear the 's2' byte on all creates.
 3533 E0F1  CD E053     	CALL	AUTOSEL		;select proper drive and get the next
 3534 E0F4  C3 DD26     	JP	GETEMPTY	;empty directory space.
