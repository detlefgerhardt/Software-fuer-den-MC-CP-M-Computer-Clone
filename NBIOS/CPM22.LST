 3624 E97A  CA 0000#    	JP	Z,GOBACK1
 3625 E97D  2A DF45     	LD	HL,(PARAMS)	;yes, but was a change made?
 3626 E980  36 00       	LD	(HL),0		;(* reset first byte of fcb *)
 3627 E982  3A 0000#    	LD	A,(AUTOFLAG)
 3628 E985  B7          	OR	A
 3629 E986  CA 0000#    	JP	Z,GOBACK1
 3630 E989  77          	LD	(HL),A		;yes, reset first byte properly.
 3631 E98A  3A 0000#    	LD	A,(OLDDRV)	;and get the old drive and select it.
 3632 E98D  32 0000#    	LD	(EPARAM),A
 3633 E990  CD E847     	CALL	SETDSK
 3634 E993  2A DF11     GOBACK1:LD	HL,(USRSTACK)	;reset the users stack pointer.
 3635 E996  F9          	LD	SP,HL
 3636 E997  2A DF47     	LD	HL,(STATUS)	;get return status.
 3637 E99A  7D          	LD	A,L		;force version 1.4 compatability.
 3638 E99B  44          	LD	B,H
 3639 E99C  C9          	RET			;and go back to user.
 3640                   ;
 3641                   ;   Function #40. This is a special entry to do random i/o.
 3642                   ; For the case where we are writing to unused disk space, this
 3643                   ; space will be zeroed out first. This must be a M/PM special
 3644                   ; purpose function, because why would any normal program even
 3645                   ; care about the previous contents of a sector about to be
 3646                   ; written over.
 3647                   ;
 3648 E99D  CD E853     WTSPECL:CALL	AUTOSEL		;select proper drive.
 3649 E9A0  3E 02       	LD	A,2		;use special write mode.
 3650 E9A2  32 0000#    	LD	(MODE),A
 3651 E9A5  0E 00       	LD	C,0		;set write indicator.
 3652 E9A7  CD E709     	CALL	POSITN1		;position the file.
 3653 E9AA  CC E605     	CALL	Z,WTSEQ1	;and write (if no errors).
 3654 E9AD  C9          	RET	
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  64
CPM22   Z80

 3655                   ;
 3656                   ;**************************************************************
 3657                   ;*
 3658                   ;*     BDOS data storage pool.
 3659                   ;*
 3660                   ;**************************************************************
 3661                   ;
 3662 E9AE  E5          EMPTYFCB: DB	0E5H		;empty directory segment indicator.
 3663 E9AF  0000        WRTPRT:	DW	0		;write protect status for all 16 drives.
 3664 E9B1  0000        LOGIN:	DW	0		;drive active word (1 bit per drive).
 3665 E9B3  0080        USERDMA:DW	080H		;user's dma address (defaults to 80h).
 3666                   ;
 3667                   ;   Scratch areas from parameter block.
 3668                   ;
 3669 E9B5  0000        SCRATCH1: DW	0		;relative position within dir segment for file (0-3).
 3670 E9B7  0000        SCRATCH2: DW	0		;last selected track number.
 3671 E9B9  0000        SCRATCH3: DW	0		;last selected sector number.
 3672                   ;
 3673                   ;   Disk storage areas from parameter block.
 3674                   ;
 3675 E9BB  0000        DIRBUF:	DW	0		;address of directory buffer to use.
 3676 E9BD  0000        DISKPB:	DW	0		;contains address of disk parameter block.
 3677 E9BF  0000        CHKVECT:DW	0		;address of check vector.
 3678 E9C1  0000        ALOCVECT: DW	0		;address of allocation vector (bit map).
 3679                   ;
 3680                   ;   Parameter block returned from the bios.
 3681                   ;
 3682 E9C3  0000        SECTORS:DW	0		;sectors per track from bios.
 3683 E9C5  00          BLKSHFT:DB	0		;block shift.
 3684 E9C6  00          BLKMASK:DB	0		;block mask.
 3685 E9C7  00          EXTMASK:DB	0		;extent mask.
 3686 E9C8  0000        DSKSIZE:DW	0		;disk size from bios (number of blocks-1).
 3687 E9CA  0000        DIRSIZE:DW	0		;directory size.
 3688 E9CC  0000        ALLOC0:	DW	0		;storage for first bytes of bit map (dir space used).
 3689 E9CE  0000        ALLOC1:	DW	0
 3690 E9D0  0000        OFFSET:	DW	0		;first usable track number.
 3691 E9D2  0000        XLATE:	DW	0		;sector translation table address.
 3692                   ;
 3693                   ;
 3694 E9D4  00          CLOSEFLG: DB	0		;close flag (=0ffh is extent written ok).
 3695 E9D5  00          RDWRTFLG: DB	0		;read/write flag (0ffh=read, 0=write).
 3696 E9D6  00          FNDSTAT:DB	0		;filename found status (0=found first entry).
 3697 E9D7  00          MODE:	DB	0		;I/o mode select (0=random, 1=sequential, 2=special random).
 3698 E9D8  00          EPARAM:	DB	0		;storage for register (E) on entry to bdos.
 3699 E9D9  00          RELBLOCK: DB	0		;relative position within fcb of block number written.
 3700 E9DA  00          COUNTER:DB	0		;byte counter for directory name searches.
 3701 E9DB  0000  0000  SAVEFCB:DW	0,0		;save space for address of fcb (for directory searches).
 3702 E9DF  00          BIGDISK:DB	0		;if =0 then disk is > 256 blocks long.
 3703 E9E0  00          AUTO:	DB	0		;if non-zero, then auto select activated.
 3704 E9E1  00          OLDDRV:	DB	0		;on auto select, storage for previous drive.
 3705 E9E2  00          AUTOFLAG: DB	0		;if non-zero, then auto select changed drives.
 3706 E9E3  00          SAVNXT:	DB	0		;storage for next record number to access.
 3707 E9E4  00          SAVEXT:	DB	0		;storage for extent number of file.
 3708 E9E5  0000        SAVNREC:DW	0		;storage for number of records in file.
 3709 E9E7  0000        BLKNMBR:DW	0		;block number (physical sector) used within a file or logical sect
 3710 E9E9  0000        LOGSECT:DW	0		;starting logical (128 byte) sector of block (physical sector).
 3711 E9EB  00          FCBPOS:	DB	0		;relative position within buffer for fcb of file of interest.
 3712 E9EC  0000        FILEPOS:DW	0		;files position within directory (0 to max entries -1).
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  65
