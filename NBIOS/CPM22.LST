 3456                   ;
 3457                   ;   Function to open a specified file.
 3458                   ;
 3459 E89E  CD E174     OPENFIL:CALL	CLEARS2		;clear 's2' byte.
 3460 E8A1  CD E853     	CALL	AUTOSEL		;select proper disk.
 3461 E8A4  C3 E453     	JP	OPENIT		;and open the file.
 3462                   ;
 3463                   ;   Function to close a specified file.
 3464                   ;
 3465 E8A7  CD E853     CLOSEFIL: CALL	AUTOSEL		;select proper disk.
 3466 E8AA  C3 E4A4     	JP	CLOSEIT		;and close the file.
 3467                   ;
 3468                   ;   Function to return the first occurence of a specified file
 3469                   ; name. If the first byte of the fcb is '?' then the name will
 3470                   ; not be checked (get the first entry no matter what).
 3471                   ;
 3472 E8AD  0E 00       GETFST:	LD	C,0		;prepare for special search.
 3473 E8AF  EB          	EX	DE,HL
 3474 E8B0  7E          	LD	A,(HL)		;is first byte a '?'?
 3475 E8B1  FE 3F       	CP	'?'
 3476 E8B3  CA 0000#    	JP	Z,GETFST1	;yes, just get very first entry (zero length match).
 3477 E8B6  CD E0A8     	CALL	SETEXT		;get the extension byte from fcb.
 3478 E8B9  7E          	LD	A,(HL)		;is it '?'? if yes, then we want
 3479 E8BA  FE 3F       	CP	'?'		;an entry with a specific 's2' byte.
 3480 E8BC  C4 E174     	CALL	NZ,CLEARS2	;otherwise, look for a zero 's2' byte.
