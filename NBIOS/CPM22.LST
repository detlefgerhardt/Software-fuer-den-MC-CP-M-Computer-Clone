 1018                   ;
 1019 D210  CD CE5E     RENAME:	CALL	CONVFST		;convert first file name.
 1020 D213  C2 CE09     	JP	NZ,SYNERR	;wild cards not allowed.
 1021 D216  3A D3F0     	LD	A,(CHGDRV)	;remember any change in drives specified.
 1022 D219  F5          	PUSH	AF
 1023 D21A  CD D054     	CALL	DSELECT		;and select this drive.
 1024 D21D  CD CCE9     	CALL	SRCHFCB		;is this file present?
 1025 D220  C2 D279     	JP	NZ,RENAME6	;yes, print error message.
 1026 D223  21 D3CD     	LD	HL,FCB		;yes, move this name into second slot.
 1027 D226  11 D3DD     	LD	DE,FCB+16
 1028 D229  06 10       	LD	B,16
 1029 D22B  CD D042     	CALL	HL2DE
 1030 D22E  2A CC88     	LD	HL,(INPOINT)	;get input pointer.
 1031 D231  EB          	EX	DE,HL
 1032 D232  CD CE4F     	CALL	NONBLANK	;get next non blank character.
 1033 D235  FE 3D       	CP	'='		;only allow an '=' or '_' seperator.
 1034 D237  CA D23F     	JP	Z,RENAME1
 1035 D23A  FE 5F       	CP	'_'
 1036 D23C  C2 D273     	JP	NZ,RENAME5
 1037 D23F  EB          RENAME1:EX	DE,HL
 1038 D240  23          	INC	HL		;ok, skip seperator.
 1039 D241  22 CC88     	LD	(INPOINT),HL	;save input line pointer.
 1040 D244  CD CE5E     	CALL	CONVFST		;convert this second file name now.
 1041 D247  C2 D273     	JP	NZ,RENAME5	;again, no wild cards.
 1042 D24A  F1          	POP	AF		;if a drive was specified, then it
 1043 D24B  47          	LD	B,A		;must be the same as before.
 1044 D24C  21 D3F0     	LD	HL,CHGDRV
 1045 D24F  7E          	LD	A,(HL)
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  19
