  930 D178  FE 80       	CP	128
  931 D17A  DA D187     	JP	C,TYPE3
  932 D17D  E5          	PUSH	HL		;yes, read in the next one.
  933 D17E  CD CCFE     	CALL	READFCB
  934 D181  E1          	POP	HL
  935 D182  C2 D1A0     	JP	NZ,TYPE4	;end or error?
  936 D185  AF          	XOR	A		;ok, clear byte counter.
  937 D186  77          	LD	(HL),A
  938 D187  34          TYPE3:	INC	(HL)		;count this byte.
  939 D188  21 0080     	LD	HL,TBUFF	;and get the (A)th one from the buffer (TBUFF).
  940 D18B  CD CE59     	CALL	ADDHL
  941 D18E  7E          	LD	A,(HL)
  942 D18F  FE 1A       	CP	CNTRLZ		;end of file mark?
  943 D191  CA D386     	JP	Z,GETBACK
  944 D194  CD CC8C     	CALL	PRINT		;no, print it.
  945 D197  CD CDC2     	CALL	CHKCON		;check console, quit if anything ready.
  946 D19A  C2 D386     	JP	NZ,GETBACK
  947 D19D  C3 D174     	JP	TYPE1
  948                   ;
  949                   ;   Get here on an end of file or read error.
  950                   ;
  951 D1A0  3D          TYPE4:	DEC	A		;read error?
  952 D1A1  CA D386     	JP	Z,GETBACK
  953 D1A4  CD CFD9     	CALL	RDERROR		;yes, print message.
  954 D1A7  CD D066     TYPE5:	CALL	RESETDR		;and reset proper drive
  955 D1AA  C3 CE09     	JP	SYNERR		;now print file name with problem.
  956                   ;
  957                   ;**************************************************************
  958                   ;*
  959                   ;*            S A V E   C O M M A N D
  960                   ;*
  961                   ;**************************************************************
  962                   ;
  963 D1AD  CD CFF8     SAVE:	CALL	DECODE		;get numeric number that follows SAVE.
  964 D1B0  F5          	PUSH	AF		;save number of pages to write.
  965 D1B1  CD CE5E     	CALL	CONVFST		;convert file name.
  966 D1B4  C2 CE09     	JP	NZ,SYNERR	;wild cards not allowed.
  967 D1B7  CD D054     	CALL	DSELECT		;select specified drive.
  968 D1BA  11 D3CD     	LD	DE,FCB		;now delete this file.
  969 D1BD  D5          	PUSH	DE
  970 D1BE  CD CCEF     	CALL	DELETE
  971 D1C1  D1          	POP	DE
  972 D1C2  CD CD09     	CALL	CREATE		;and create it again.
  973 D1C5  CA D1FB     	JP	Z,SAVE3		;can't create?
  974 D1C8  AF          	XOR	A		;clear record number byte.
  975 D1C9  32 D3ED     	LD	(FCB+32),A
  976 D1CC  F1          	POP	AF		;convert pages to sectors.
  977 D1CD  6F          	LD	L,A
  978 D1CE  26 00       	LD	H,0
  979 D1D0  29          	ADD	HL,HL		;(HL)=number of sectors to write.
  980 D1D1  11 0100     	LD	DE,TBASE	;and we start from here.
  981 D1D4  7C          SAVE1:	LD	A,H		;done yet?
  982 D1D5  B5          	OR	L
  983 D1D6  CA D1F1     	JP	Z,SAVE2
  984 D1D9  2B          	DEC	HL		;nope, count this and compute the start
  985 D1DA  E5          	PUSH	HL		;of the next 128 byte sector.
  986 D1DB  21 0080     	LD	HL,128
  987 D1DE  19          	ADD	HL,DE
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  18
