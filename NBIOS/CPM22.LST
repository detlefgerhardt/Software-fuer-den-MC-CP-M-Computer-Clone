   59 D488  D408        INPOINT:DW	INBUFF+2	;input line pointer
   60 D48A  0000        NAMEPNT:DW	0		;input line pointer used for error message. Points to
   61                   ;			;start of name in error.
   62                   ;
   63                   ;   Routine to print (A) on the console. All registers used.
   64                   ;
   65 D48C  5F          PRINT:	LD	E,A		;setup bdos call.
   66 D48D  0E 02       	LD	C,2
   67 D48F  C3 0005     	JP	ENTRY
   68                   ;
   69                   ;   Routine to print (A) on the console and to save (BC).
   70                   ;
   71 D492  C5          PRINTB:	PUSH	BC
   72 D493  CD D48C     	CALL	PRINT
   73 D496  C1          	POP	BC
   74 D497  C9          	RET	
   75                   ;
   76                   ;   Routine to send a carriage return, line feed combination
   77                   ; to the console.
   78                   ;
   79 D498  3E 0D       CRLF:	LD	A,CR
   80 D49A  CD D492     	CALL	PRINTB
   81 D49D  3E 0A       	LD	A,LF
   82 D49F  C3 D492     	JP	PRINTB
   83                   ;
   84                   ;   Routine to send one space to the console and save (BC).
   85                   ;
   86 D4A2  3E 20       SPACE:	LD	A,' '
   87 D4A4  C3 D492     	JP	PRINTB
   88                   ;
   89                   ;   Routine to print character string pointed to be (BC) on the
   90                   ; console. It must terminate with a null byte.
   91                   ;
   92 D4A7  C5          PLINE:	PUSH	BC
   93 D4A8  CD D498     	CALL	CRLF
   94 D4AB  E1          	POP	HL
   95 D4AC  7E          PLINE2:	LD	A,(HL)
   96 D4AD  B7          	OR	A
   97 D4AE  C8          	RET	Z
   98 D4AF  23          	INC	HL
   99 D4B0  E5          	PUSH	HL
  100 D4B1  CD D48C     	CALL	PRINT
  101 D4B4  E1          	POP	HL
  102 D4B5  C3 D4AC     	JP	PLINE2
  103                   ;
  104                   ;   Routine to reset the disk system.
  105                   ;
  106 D4B8  0E 0D       RESDSK:	LD	C,13
  107 D4BA  C3 0005     	JP	ENTRY
  108                   ;
  109                   ;   Routine to select disk (A).
  110                   ;
  111 D4BD  5F          DSKSEL:	LD	E,A
  112 D4BE  0E 0E       	LD	C,14
  113 D4C0  C3 0005     	JP	ENTRY
  114                   ;
  115                   ;   Routine to call bdos and save the return code. The zero
  116                   ; flag is set on a return of 0ffh.
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   3
CPM22   Z80

  117                   ;
  118 D4C3  CD 0005     ENTRY1:	CALL	ENTRY
  119 D4C6  32 0000#    	LD	(RTNCODE),A	;save return code.
  120 D4C9  3C          	INC	A		;set zero if 0ffh returned.
  121 D4CA  C9          	RET	
  122                   ;
  123                   ;   Routine to open a file. (DE) must point to the FCB.
  124                   ;
  125 D4CB  0E 0F       OPEN:	LD	C,15
  126 D4CD  C3 D4C3     	JP	ENTRY1
  127                   ;
  128                   ;   Routine to open file at (FCB).
  129                   ;
  130 D4D0  AF          OPENFCB:XOR	A		;clear the record number byte at fcb+32
  131 D4D1  32 ????     	LD	(FCB+32),A
  132 D4D4  11 0000#    	LD	DE,FCB
  133 D4D7  C3 D4CB     	JP	OPEN
  134                   ;
  135                   ;   Routine to close a file. (DE) points to FCB.
  136                   ;
  137 D4DA  0E 10       CLOSE:	LD	C,16
  138 D4DC  C3 D4C3     	JP	ENTRY1
  139                   ;
  140                   ;   Routine to search for the first file with ambigueous name
  141                   ; (DE).
  142                   ;
  143 D4DF  0E 11       SRCHFST:LD	C,17
  144 D4E1  C3 D4C3     	JP	ENTRY1
  145                   ;
  146                   ;   Search for the next ambigeous file name.
  147                   ;
  148 D4E4  0E 12       SRCHNXT:LD	C,18
  149 D4E6  C3 D4C3     	JP	ENTRY1
  150                   ;
  151                   ;   Search for file at (FCB).
  152                   ;
  153 D4E9  11 0000#    SRCHFCB:LD	DE,FCB
  154 D4EC  C3 D4DF     	JP	SRCHFST
  155                   ;
  156                   ;   Routine to delete a file pointed to by (DE).
  157                   ;
  158 D4EF  0E 13       DELETE:	LD	C,19
  159 D4F1  C3 0005     	JP	ENTRY
  160                   ;
  161                   ;   Routine to call the bdos and set the zero flag if a zero
  162                   ; status is returned.
  163                   ;
  164 D4F4  CD 0005     ENTRY2:	CALL	ENTRY
  165 D4F7  B7          	OR	A		;set zero flag if appropriate.
  166 D4F8  C9          	RET	
  167                   ;
  168                   ;   Routine to read the next record from a sequential file.
  169                   ; (DE) points to the FCB.
  170                   ;
  171 D4F9  0E 14       RDREC:	LD	C,20
  172 D4FB  C3 D4F4     	JP	ENTRY2
  173                   ;
  174                   ;   Routine to read file at (FCB).
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   4
CPM22   Z80

  175                   ;
  176 D4FE  11 0000#    READFCB:LD	DE,FCB
  177 D501  C3 D4F9     	JP	RDREC
  178                   ;
  179                   ;   Routine to write the next record of a sequential file.
  180                   ; (DE) points to the FCB.
  181                   ;
  182 D504  0E 15       WRTREC:	LD	C,21
  183 D506  C3 D4F4     	JP	ENTRY2
  184                   ;
  185                   ;   Routine to create the file pointed to by (DE).
  186                   ;
  187 D509  0E 16       CREATE:	LD	C,22
  188 D50B  C3 D4C3     	JP	ENTRY1
  189                   ;
  190                   ;   Routine to rename the file pointed to by (DE). Note that
  191                   ; the new name starts at (DE+16).
  192                   ;
  193 D50E  0E 17       RENAM:	LD	C,23
  194 D510  C3 0005     	JP	ENTRY
  195                   ;
  196                   ;   Get the current user code.
  197                   ;
  198 D513  1E FF       GETUSR:	LD	E,0FFH
  199                   ;
  200                   ;   Routne to get or set the current user code.
  201                   ; If (E) is FF then this is a GET, else it is a SET.
  202                   ;
  203 D515  0E 20       GETSETUC: LD	C,32
  204 D517  C3 0005     	JP	ENTRY
  205                   ;
  206                   ;   Routine to set the current drive byte at (TDRIVE).
  207                   ;
  208 D51A  CD D513     SETCDRV:CALL	GETUSR		;get user number
  209 D51D  87          	ADD	A,A		;and shift into the upper 4 bits.
  210 D51E  87          	ADD	A,A
  211 D51F  87          	ADD	A,A
  212 D520  87          	ADD	A,A
  213 D521  21 0000#    	LD	HL,CDRIVE	;now add in the current drive number.
  214 D524  B6          	OR	(HL)
  215 D525  32 0004     	LD	(TDRIVE),A	;and save.
  216 D528  C9          	RET	
  217                   ;
  218                   ;   Move currently active drive down to (TDRIVE).
  219                   ;
  220 D529  3A 0000#    MOVECD:	LD	A,(CDRIVE)
  221 D52C  32 0004     	LD	(TDRIVE),A
  222 D52F  C9          	RET	
  223                   ;
  224                   ;   Routine to convert (A) into upper case ascii. Only letters
  225                   ; are affected.
  226                   ;
  227 D530  FE 61       UPPER:	CP	'a'		;check for letters in the range of 'a' to 'z'.
  228 D532  D8          	RET	C
  229 D533  FE 7B       	CP	'{'
  230 D535  D0          	RET	NC
  231 D536  E6 5F       	AND	5FH		;convert it if found.
  232 D538  C9          	RET	
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   5
CPM22   Z80

  233                   ;
  234                   ;   Routine to get a line of input. We must check to see if the
  235                   ; user is in (BATCH) mode. If so, then read the input from file
  236                   ; ($$$.SUB). At the end, reset to console input.
  237                   ;
  238 D539  3A 0000#    GETINP:	LD	A,(BATCH)	;if =0, then use console input.
  239 D53C  B7          	OR	A
  240 D53D  CA 0000#    	JP	Z,GETINP1
  241                   ;
  242                   ;   Use the submit file ($$$.sub) which is prepared by a
  243                   ; SUBMIT run. It must be on drive (A) and it will be deleted
  244                   ; if and error occures (like eof).
  245                   ;
  246 D540  3A 0000#    	LD	A,(CDRIVE)	;select drive 0 if need be.
  247 D543  B7          	OR	A
  248 D544  3E 00       	LD	A,0		;always use drive A for submit.
  249 D546  C4 D4BD     	CALL	NZ,DSKSEL	;select it if required.
  250 D549  11 0000#    	LD	DE,BATCHFCB
  251 D54C  CD D4CB     	CALL	OPEN		;look for it.
  252 D54F  CA 0000#    	JP	Z,GETINP1	;if not there, use normal input.
  253 D552  3A ????     	LD	A,(BATCHFCB+15)	;get last record number+1.
  254 D555  3D          	DEC	A
  255 D556  32 ????     	LD	(BATCHFCB+32),A
  256 D559  11 0000#    	LD	DE,BATCHFCB
  257 D55C  CD D4F9     	CALL	RDREC		;read last record.
  258 D55F  C2 0000#    	JP	NZ,GETINP1	;quit on end of file.
  259                   ;
  260                   ;   Move this record into input buffer.
  261                   ;
  262 D562  11 D407     	LD	DE,INBUFF+1
  263 D565  21 0080     	LD	HL,TBUFF	;data was read into buffer here.
  264 D568  06 80       	LD	B,128		;all 128 characters may be used.
  265 D56A  CD 0000#    	CALL	HL2DE		;(HL) to (DE), (B) bytes.
  266 D56D  21 ????     	LD	HL,BATCHFCB+14
  267 D570  36 00       	LD	(HL),0		;zero out the 's2' byte.
  268 D572  23          	INC	HL		;and decrement the record count.
  269 D573  35          	DEC	(HL)
  270 D574  11 0000#    	LD	DE,BATCHFCB	;close the batch file now.
  271 D577  CD D4DA     	CALL	CLOSE
  272 D57A  CA 0000#    	JP	Z,GETINP1	;quit on an error.
  273 D57D  3A 0000#    	LD	A,(CDRIVE)	;re-select previous drive if need be.
  274 D580  B7          	OR	A
  275 D581  C4 D4BD     	CALL	NZ,DSKSEL	;don't do needless selects.
  276                   ;
  277                   ;   Print line just read on console.
  278                   ;
  279 D584  21 D408     	LD	HL,INBUFF+2
  280 D587  CD D4AC     	CALL	PLINE2
  281 D58A  CD 0000#    	CALL	CHKCON		;check console, quit on a key.
  282 D58D  CA 0000#    	JP	Z,GETINP2	;jump if no key is pressed.
  283                   ;
  284                   ;   Terminate the submit job on any keyboard input. Delete this
  285                   ; file such that it is not re-started and jump to normal keyboard
  286                   ; input section.
  287                   ;
  288 D590  CD 0000#    	CALL	DELBATCH	;delete the batch file.
  289 D593  C3 0000#    	JP	CMMND1		;and restart command input.
  290                   ;
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   6
CPM22   Z80

  291                   ;   Get here for normal keyboard input. Delete the submit file
  292                   ; incase there was one.
  293                   ;
  294 D596  CD 0000#    GETINP1:CALL	DELBATCH	;delete file ($$$.sub).
  295 D599  CD D51A     	CALL	SETCDRV		;reset active disk.
  296 D59C  0E 0A       	LD	C,10		;get line from console device.
  297 D59E  11 D406     	LD	DE,INBUFF
  298 D5A1  CD 0005     	CALL	ENTRY
  299 D5A4  CD D529     	CALL	MOVECD		;reset current drive (again).
  300                   ;
  301                   ;   Convert input line to upper case.
  302                   ;
  303 D5A7  21 D407     GETINP2:LD	HL,INBUFF+1
  304 D5AA  46          	LD	B,(HL)		;(B)=character counter.
  305 D5AB  23          GETINP3:INC	HL
  306 D5AC  78          	LD	A,B		;end of the line?
  307 D5AD  B7          	OR	A
  308 D5AE  CA 0000#    	JP	Z,GETINP4
  309 D5B1  7E          	LD	A,(HL)		;convert to upper case.
  310 D5B2  CD D530     	CALL	UPPER
  311 D5B5  77          	LD	(HL),A
  312 D5B6  05          	DEC	B		;adjust character count.
  313 D5B7  C3 D5AB     	JP	GETINP3
  314 D5BA  77          GETINP4:LD	(HL),A		;add trailing null.
  315 D5BB  21 D408     	LD	HL,INBUFF+2
  316 D5BE  22 D488     	LD	(INPOINT),HL	;reset input line pointer.
  317 D5C1  C9          	RET	
  318                   ;
  319                   ;   Routine to check the console for a key pressed. The zero
  320                   ; flag is set is none, else the character is returned in (A).
  321                   ;
  322 D5C2  0E 0B       CHKCON:	LD	C,11		;check console.
  323 D5C4  CD 0005     	CALL	ENTRY
  324 D5C7  B7          	OR	A
  325 D5C8  C8          	RET	Z		;return if nothing.
  326 D5C9  0E 01       	LD	C,1		;else get character.
  327 D5CB  CD 0005     	CALL	ENTRY
  328 D5CE  B7          	OR	A		;clear zero flag and return.
  329 D5CF  C9          	RET	
  330                   ;
  331                   ;   Routine to get the currently active drive number.
  332                   ;
  333 D5D0  0E 19       GETDSK:	LD	C,25
  334 D5D2  C3 0005     	JP	ENTRY
  335                   ;
  336                   ;   Set the stabdard dma address.
  337                   ;
  338 D5D5  11 0080     STDDMA:	LD	DE,TBUFF
  339                   ;
  340                   ;   Routine to set the dma address to (DE).
  341                   ;
  342 D5D8  0E 1A       DMASET:	LD	C,26
  343 D5DA  C3 0005     	JP	ENTRY
  344                   ;
  345                   ;  Delete the batch file created by SUBMIT.
  346                   ;
  347 D5DD  21 0000#    DELBATCH: LD	HL,BATCH	;is batch active?
  348 D5E0  7E          	LD	A,(HL)
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   7
CPM22   Z80

  349 D5E1  B7          	OR	A
  350 D5E2  C8          	RET	Z
  351 D5E3  36 00       	LD	(HL),0		;yes, de-activate it.
  352 D5E5  AF          	XOR	A
  353 D5E6  CD D4BD     	CALL	DSKSEL		;select drive 0 for sure.
  354 D5E9  11 0000#    	LD	DE,BATCHFCB	;and delete this file.
  355 D5EC  CD D4EF     	CALL	DELETE
  356 D5EF  3A 0000#    	LD	A,(CDRIVE)	;reset current drive.
  357 D5F2  C3 D4BD     	JP	DSKSEL
  358                   ;
  359                   ;   Check to two strings at (PATTRN1) and (PATTRN2). They must be
  360                   ; the same or we halt....
  361                   ;
  362 D5F5  11 0000#    VERIFY:	LD	DE,PATTRN1	;these are the serial number bytes.
  363 D5F8  21 0000#    	LD	HL,PATTRN2	;ditto, but how could they be different?
  364 D5FB  06 06       	LD	B,6		;6 bytes each.
  365 D5FD  1A          VERIFY1:LD	A,(DE)
  366 D5FE  BE          	CP	(HL)
  367 D5FF  C2 0000#    	JP	NZ,HALT		;jump to halt routine.
  368 D602  13          	INC	DE
  369 D603  23          	INC	HL
  370 D604  05          	DEC	B
  371 D605  C2 D5FD     	JP	NZ,VERIFY1
  372 D608  C9          	RET	
  373                   ;
  374                   ;   Print back file name with a '?' to indicate a syntax error.
  375                   ;
  376 D609  CD D498     SYNERR:	CALL	CRLF		;end current line.
  377 D60C  2A D48A     	LD	HL,(NAMEPNT)	;this points to name in error.
  378 D60F  7E          SYNERR1:LD	A,(HL)		;print it until a space or null is found.
  379 D610  FE 20       	CP	' '
  380 D612  CA 0000#    	JP	Z,SYNERR2
  381 D615  B7          	OR	A
  382 D616  CA 0000#    	JP	Z,SYNERR2
  383 D619  E5          	PUSH	HL
  384 D61A  CD D48C     	CALL	PRINT
  385 D61D  E1          	POP	HL
  386 D61E  23          	INC	HL
  387 D61F  C3 D60F     	JP	SYNERR1
  388 D622  3E 3F       SYNERR2:LD	A,'?'		;add trailing '?'.
  389 D624  CD D48C     	CALL	PRINT
  390 D627  CD D498     	CALL	CRLF
  391 D62A  CD D5DD     	CALL	DELBATCH	;delete any batch file.
  392 D62D  C3 0000#    	JP	CMMND1		;and restart from console input.
  393                   ;
  394                   ;   Check character at (DE) for legal command input. Note that the
  395                   ; zero flag is set if the character is a delimiter.
  396                   ;
  397 D630  1A          CHECK:	LD	A,(DE)
  398 D631  B7          	OR	A
  399 D632  C8          	RET	Z
  400 D633  FE 20       	CP	' '		;control characters are not legal here.
  401 D635  DA D609     	JP	C,SYNERR
  402 D638  C8          	RET	Z		;check for valid delimiter.
  403 D639  FE 3D       	CP	'='
  404 D63B  C8          	RET	Z
  405 D63C  FE 5F       	CP	'_'
  406 D63E  C8          	RET	Z
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   8
CPM22   Z80

  407 D63F  FE 2E       	CP	'.'
  408 D641  C8          	RET	Z
  409 D642  FE 3A       	CP	03Ah	;':'
  410 D644  C8          	RET	Z
  411 D645  FE 3B       	CP	03BH ; ';'
  412 D647  C8          	RET	Z
  413 D648  FE 3C       	CP	'<'
  414 D64A  C8          	RET	Z
  415 D64B  FE 3E       	CP	'>'
  416 D64D  C8          	RET	Z
  417 D64E  C9          	RET	
  418                   ;
  419                   ;   Get the next non-blank character from (DE).
  420                   ;
  421 D64F  1A          NONBLANK: LD	A,(DE)
  422 D650  B7          	OR	A		;string ends with a null.
  423 D651  C8          	RET	Z
  424 D652  FE 20       	CP	' '
  425 D654  C0          	RET	NZ
  426 D655  13          	INC	DE
  427 D656  C3 D64F     	JP	NONBLANK
  428                   ;
  429                   ;   Add (HL)=(HL)+(A)
  430                   ;
  431 D659  85          ADDHL:	ADD	A,L
  432 D65A  6F          	LD	L,A
  433 D65B  D0          	RET	NC		;take care of any carry.
  434 D65C  24          	INC	H
  435 D65D  C9          	RET	
  436                   ;
  437                   ;   Convert the first name in (FCB).
  438                   ;
  439 D65E  3E 00       CONVFST:LD	A,0
  440                   ;
  441                   ;   Format a file name (convert * to '?', etc.). On return,
  442                   ; (A)=0 is an unambigeous name was specified. Enter with (A) equal to
  443                   ; the position within the fcb for the name (either 0 or 16).
  444                   ;
  445 D660  21 0000#    CONVERT:LD	HL,FCB
  446 D663  CD D659     	CALL	ADDHL
  447 D666  E5          	PUSH	HL
  448 D667  E5          	PUSH	HL
  449 D668  AF          	XOR	A
  450 D669  32 0000#    	LD	(CHGDRV),A	;initialize drive change flag.
  451 D66C  2A D488     	LD	HL,(INPOINT)	;set (HL) as pointer into input line.
  452 D66F  EB          	EX	DE,HL
  453 D670  CD D64F     	CALL	NONBLANK	;get next non-blank character.
  454 D673  EB          	EX	DE,HL
  455 D674  22 D48A     	LD	(NAMEPNT),HL	;save pointer here for any error message.
  456 D677  EB          	EX	DE,HL
  457 D678  E1          	POP	HL
  458 D679  1A          	LD	A,(DE)		;get first character.
  459 D67A  B7          	OR	A
  460 D67B  CA 0000#    	JP	Z,CONVRT1
  461 D67E  DE 40       	SBC	A,'A'-1		;might be a drive name, convert to binary.
  462 D680  47          	LD	B,A		;and save.
  463 D681  13          	INC	DE		;check next character for a ':'.
  464 D682  1A          	LD	A,(DE)
