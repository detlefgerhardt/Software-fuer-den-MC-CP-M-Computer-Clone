 1046 D250  B7          	OR	A
 1047 D251  CA D259     	JP	Z,RENAME2
 1048 D254  B8          	CP	B
 1049 D255  70          	LD	(HL),B
 1050 D256  C2 D273     	JP	NZ,RENAME5	;they were different, error.
 1051 D259  70          RENAME2:LD	(HL),B		;	reset as per the first file specification.
 1052 D25A  AF          	XOR	A
 1053 D25B  32 D3CD     	LD	(FCB),A		;clear the drive byte of the fcb.
 1054 D25E  CD CCE9     RENAME3:CALL	SRCHFCB		;and go look for second file.
 1055 D261  CA D26D     	JP	Z,RENAME4	;doesn't exist?
 1056 D264  11 D3CD     	LD	DE,FCB
 1057 D267  CD CD0E     	CALL	RENAM		;ok, rename the file.
 1058 D26A  C3 D386     	JP	GETBACK
 1059                   ;
 1060                   ;   Process rename errors here.
 1061                   ;
 1062 D26D  CD CFEA     RENAME4:CALL	NONE		;file not there.
 1063 D270  C3 D386     	JP	GETBACK
 1064 D273  CD D066     RENAME5:CALL	RESETDR		;bad command format.
 1065 D276  C3 CE09     	JP	SYNERR
 1066 D279  01 D282     RENAME6:LD	BC,EXISTS	;destination file already exists.
 1067 D27C  CD CCA7     	CALL	PLINE
 1068 D27F  C3 D386     	JP	GETBACK
 1069 D282  46 69 6C 65 EXISTS:	DEFM	"File exists"
 1070 D28D  00          	DB	0
 1071                   ;
 1072                   ;**************************************************************
 1073                   ;*
 1074                   ;*             U S E R   C O M M A N D
 1075                   ;*
 1076                   ;**************************************************************
 1077                   ;
 1078 D28E  CD CFF8     USER:	CALL	DECODE		;get numeric value following command.
 1079 D291  FE 10       	CP	16		;legal user number?
 1080 D293  D2 CE09     	JP	NC,SYNERR
 1081 D296  5F          	LD	E,A		;yes but is there anything else?
 1082 D297  3A D3CE     	LD	A,(FCB+1)
 1083 D29A  FE 20       	CP	' '
 1084 D29C  CA CE09     	JP	Z,SYNERR	;yes, that is not allowed.
 1085 D29F  CD CD15     	CALL	GETSETUC	;ok, set user code.
 1086 D2A2  C3 D389     	JP	GETBACK1
 1087                   ;
 1088                   ;**************************************************************
 1089                   ;*
 1090                   ;*        T R A N S I A N T   P R O G R A M   C O M M A N D
 1091                   ;*
 1092                   ;**************************************************************
 1093                   ;
 1094 D2A5  CD CDF5     UNKNOWN:CALL	VERIFY		;check for valid system (why?).
 1095 D2A8  3A D3CE     	LD	A,(FCB+1)	;anything to execute?
 1096 D2AB  FE 20       	CP	' '
 1097 D2AD  C2 D2C4     	JP	NZ,UNKWN1
 1098 D2B0  3A D3F0     	LD	A,(CHGDRV)	;nope, only a drive change?
 1099 D2B3  B7          	OR	A
 1100 D2B4  CA D389     	JP	Z,GETBACK1	;neither???
 1101 D2B7  3D          	DEC	A
 1102 D2B8  32 D3EF     	LD	(CDRIVE),A	;ok, store new drive.
