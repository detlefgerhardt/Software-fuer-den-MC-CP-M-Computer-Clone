  466 CE77  EB          	EX	DE,HL
  467 CE78  E1          	POP	HL
  468 CE79  1A          	LD	A,(DE)		;get first character.
  469 CE7A  B7          	OR	A
  470 CE7B  CA CE89     	JP	Z,CONVRT1
  471 CE7E  DE 40       	SBC	A,'A'-1		;might be a drive name, convert to binary.
  472 CE80  47          	LD	B,A		;and save.
  473 CE81  13          	INC	DE		;check next character for a ':'.
  474 CE82  1A          	LD	A,(DE)
  475 CE83  FE 3A       	CP	':'
  476 CE85  CA CE90     	JP	Z,CONVRT2
  477 CE88  1B          	DEC	DE		;nope, move pointer back to the start of the line.
  478 CE89  3A D3EF     CONVRT1:LD	A,(CDRIVE)
  479 CE8C  77          	LD	(HL),A
  480 CE8D  C3 CE96     	JP	CONVRT3
  481 CE90  78          CONVRT2:LD	A,B
  482 CE91  32 D3F0     	LD	(CHGDRV),A	;set change in drives flag.
  483 CE94  70          	LD	(HL),B
  484 CE95  13          	INC	DE
  485                   ;
  486                   ;   Convert the basic file name.
  487                   ;
  488 CE96  06 08       CONVRT3:LD	B,08H
  489 CE98  CD CE30     CONVRT4:CALL	CHECK
  490 CE9B  CA CEB9     	JP	Z,CONVRT8
  491 CE9E  23          	INC	HL
  492 CE9F  FE 2A       	CP	'*'		;note that an '*' will fill the remaining
  493 CEA1  C2 CEA9     	JP	NZ,CONVRT5	;field with '?'.
  494 CEA4  36 3F       	LD	(HL),'?'
  495 CEA6  C3 CEAB     	JP	CONVRT6
  496 CEA9  77          CONVRT5:LD	(HL),A
  497 CEAA  13          	INC	DE
  498 CEAB  05          CONVRT6:DEC	B
  499 CEAC  C2 CE98     	JP	NZ,CONVRT4
  500 CEAF  CD CE30     CONVRT7:CALL	CHECK		;get next delimiter.
  501 CEB2  CA CEC0     	JP	Z,GETEXT
  502 CEB5  13          	INC	DE
  503 CEB6  C3 CEAF     	JP	CONVRT7
  504 CEB9  23          CONVRT8:INC	HL		;blank fill the file name.
  505 CEBA  36 20       	LD	(HL),' '
  506 CEBC  05          	DEC	B
  507 CEBD  C2 CEB9     	JP	NZ,CONVRT8
  508                   ;
  509                   ;   Get the extension and convert it.
  510                   ;
  511 CEC0  06 03       GETEXT:	LD	B,03H
  512 CEC2  FE 2E       	CP	'.'
  513 CEC4  C2 CEE9     	JP	NZ,GETEXT5
  514 CEC7  13          	INC	DE
  515 CEC8  CD CE30     GETEXT1:CALL	CHECK
  516 CECB  CA CEE9     	JP	Z,GETEXT5
  517 CECE  23          	INC	HL
  518 CECF  FE 2A       	CP	'*'
  519 CED1  C2 CED9     	JP	NZ,GETEXT2
  520 CED4  36 3F       	LD	(HL),'?'
  521 CED6  C3 CEDB     	JP	GETEXT3
  522 CED9  77          GETEXT2:LD	(HL),A
  523 CEDA  13          	INC	DE
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  10
CPM22   Z80

  524 CEDB  05          GETEXT3:DEC	B
  525 CEDC  C2 CEC8     	JP	NZ,GETEXT1
  526 CEDF  CD CE30     GETEXT4:CALL	CHECK
  527 CEE2  CA CEF0     	JP	Z,GETEXT6
  528 CEE5  13          	INC	DE
  529 CEE6  C3 CEDF     	JP	GETEXT4
  530 CEE9  23          GETEXT5:INC	HL
  531 CEEA  36 20       	LD	(HL),' '
  532 CEEC  05          	DEC	B
  533 CEED  C2 CEE9     	JP	NZ,GETEXT5
  534 CEF0  06 03       GETEXT6:LD	B,3
  535 CEF2  23          GETEXT7:INC	HL
  536 CEF3  36 00       	LD	(HL),0
  537 CEF5  05          	DEC	B
  538 CEF6  C2 CEF2     	JP	NZ,GETEXT7
  539 CEF9  EB          	EX	DE,HL
  540 CEFA  22 CC88     	LD	(INPOINT),HL	;save input line pointer.
  541 CEFD  E1          	POP	HL
  542                   ;
  543                   ;   Check to see if this is an ambigeous file name specification.
  544                   ; Set the (A) register to non zero if it is.
  545                   ;
  546 CEFE  01 000B     	LD	BC,11		;set name length.
  547 CF01  23          GETEXT8:INC	HL
  548 CF02  7E          	LD	A,(HL)
  549 CF03  FE 3F       	CP	'?'		;any question marks?
  550 CF05  C2 CF09     	JP	NZ,GETEXT9
  551 CF08  04          	INC	B		;count them.
  552 CF09  0D          GETEXT9:DEC	C
  553 CF0A  C2 CF01     	JP	NZ,GETEXT8
  554 CF0D  78          	LD	A,B
  555 CF0E  B7          	OR	A
  556 CF0F  C9          	RET	
  557                   ;
  558                   ;   CP/M command table. Note commands can be either 3 or 4 characters long.
  559                   ;
  560         0006      NUMCMDS: EQU	6		;number of commands
  561 CF10  44 49 52 20 CMDTBL:	DEFM	"DIR "
  562 CF14  45 52 41 20 	DEFM	"ERA "
  563 CF18  54 59 50 45 	DEFM	"TYPE"
  564 CF1C  53 41 56 45 	DEFM	"SAVE"
  565 CF20  52 45 4E 20 	DEFM	"REN "
  566 CF24  55 53 45 52 	DEFM	"USER"
  567                   ;
  568                   ;   The following six bytes must agree with those at (PATTRN2)
  569                   ; or cp/m will HALT. Why?
  570                   ;
  571 CF28  00 16 00 00 PATTRN1:DB	0,22,0,0,0,0	;(* serial number bytes *).
  572                   ;
  573                   ;   Search the command table for a match with what has just
  574                   ; been entered. If a match is found, then we jump to the
  575                   ; proper section. Else jump to (UNKNOWN).
  576                   ; On return, the (C) register is set to the command number
  577                   ; that matched (or NUMCMDS+1 if no match).
  578                   ;
  579 CF2E  21 CF10     SEARCH:	LD	HL,CMDTBL
  580 CF31  0E 00       	LD	C,0
  581 CF33  79          SEARCH1:LD	A,C
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  11
CPM22   Z80

  582 CF34  FE 06       	CP	NUMCMDS		;this commands exists.
  583 CF36  D0          	RET	NC
  584 CF37  11 D3CE     	LD	DE,FCB+1	;check this one.
  585 CF3A  06 04       	LD	B,4		;max command length.
  586 CF3C  1A          SEARCH2:LD	A,(DE)
  587 CF3D  BE          	CP	(HL)
  588 CF3E  C2 CF4F     	JP	NZ,SEARCH3	;not a match.
  589 CF41  13          	INC	DE
  590 CF42  23          	INC	HL
  591 CF43  05          	DEC	B
  592 CF44  C2 CF3C     	JP	NZ,SEARCH2
  593 CF47  1A          	LD	A,(DE)		;allow a 3 character command to match.
  594 CF48  FE 20       	CP	' '
  595 CF4A  C2 CF54     	JP	NZ,SEARCH4
  596 CF4D  79          	LD	A,C		;set return register for this command.
  597 CF4E  C9          	RET	
  598 CF4F  23          SEARCH3:INC	HL
  599 CF50  05          	DEC	B
  600 CF51  C2 CF4F     	JP	NZ,SEARCH3
  601 CF54  0C          SEARCH4:INC	C
  602 CF55  C3 CF33     	JP	SEARCH1
  603                   ;
  604                   ;   Set the input buffer to empty and then start the command
  605                   ; processor (ccp).
  606                   ;
  607 CF58  AF          CLEARBUF: XOR	A
  608 CF59  32 CC07     	LD	(INBUFF+1),A	;second byte is actual length.
  609                   ;
  610                   ;**************************************************************
  611                   ;*
  612                   ;*
  613                   ;* C C P  -   C o n s o l e   C o m m a n d   P r o c e s s o r
  614                   ;*
  615                   ;**************************************************************
  616                   ;*
  617 CF5C  31 D3AB     COMMAND:LD	SP,CCPSTACK	;setup stack area.
  618 CF5F  C5          	PUSH	BC		;note that (C) should be equal to:
  619 CF60  79          	LD	A,C		;(uuuudddd) where 'uuuu' is the user number
  620 CF61  1F          	RRA			;and 'dddd' is the drive number.
  621 CF62  1F          	RRA	
  622 CF63  1F          	RRA	
  623 CF64  1F          	RRA	
  624 CF65  E6 0F       	AND	0FH		;isolate the user number.
  625 CF67  5F          	LD	E,A
  626 CF68  CD CD15     	CALL	GETSETUC	;and set it.
  627 CF6B  CD CCB8     	CALL	RESDSK		;reset the disk system.
  628 CF6E  32 D3AB     	LD	(BATCH),A	;clear batch mode flag.
  629 CF71  C1          	POP	BC
  630 CF72  79          	LD	A,C
  631 CF73  E6 0F       	AND	0FH		;isolate the drive number.
  632 CF75  32 D3EF     	LD	(CDRIVE),A	;and save.
  633 CF78  CD CCBD     	CALL	DSKSEL		;...and select.
  634 CF7B  3A CC07     	LD	A,(INBUFF+1)
  635 CF7E  B7          	OR	A		;anything in input buffer already?
  636 CF7F  C2 CF98     	JP	NZ,CMMND2	;yes, we just process it.
  637                   ;
  638                   ;   Entry point to get a command line from the console.
  639                   ;
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  12
CPM22   Z80

  640 CF82  31 D3AB     CMMND1:	LD	SP,CCPSTACK	;set stack straight.
  641 CF85  CD CC98     	CALL	CRLF		;start a new line on the screen.
  642 CF88  CD CDD0     	CALL	GETDSK		;get current drive.
  643 CF8B  C6 41       	ADD	A,'A'
  644 CF8D  CD CC8C     	CALL	PRINT		;print current drive.
  645 CF90  3E 3E       	LD	A,'>'
  646 CF92  CD CC8C     	CALL	PRINT		;and add prompt.
  647 CF95  CD CD39     	CALL	GETINP		;get line from user.
  648                   ;
  649                   ;   Process command line here.
  650                   ;
  651 CF98  11 0080     CMMND2:	LD	DE,TBUFF
  652 CF9B  CD CDD8     	CALL	DMASET		;set standard dma address.
  653 CF9E  CD CDD0     	CALL	GETDSK
  654 CFA1  32 D3EF     	LD	(CDRIVE),A	;set current drive.
  655 CFA4  CD CE5E     	CALL	CONVFST		;convert name typed in.
  656 CFA7  C4 CE09     	CALL	NZ,SYNERR	;wild cards are not allowed.
  657 CFAA  3A D3F0     	LD	A,(CHGDRV)	;if a change in drives was indicated,
  658 CFAD  B7          	OR	A		;then treat this as an unknown command
  659 CFAE  C2 D2A5     	JP	NZ,UNKNOWN	;which gets executed.
  660 CFB1  CD CF2E     	CALL	SEARCH		;else search command table for a match.
  661                   ;
  662                   ;   Note that an unknown command returns
  663                   ; with (A) pointing to the last address
  664                   ; in our table which is (UNKNOWN).
  665                   ;
  666 CFB4  21 CFC1     	LD	HL,CMDADR	;now, look thru our address table for command (A).
  667 CFB7  5F          	LD	E,A		;set (DE) to command number.
  668 CFB8  16 00       	LD	D,0
  669 CFBA  19          	ADD	HL,DE
  670 CFBB  19          	ADD	HL,DE		;(HL)=(CMDADR)+2*(command number).
  671 CFBC  7E          	LD	A,(HL)		;now pick out this address.
  672 CFBD  23          	INC	HL
  673 CFBE  66          	LD	H,(HL)
  674 CFBF  6F          	LD	L,A
  675 CFC0  E9          	JP	(HL)		;now execute it.
  676                   ;
  677                   ;   CP/M command address table.
  678                   ;
  679 CFC1  D077  D11F  CMDADR:	DW	DIRECT,ERASE,TYPE,SAVE
  680 CFC9  D210  D28E  	DW	RENAME,USER,UNKNOWN
  681                   ;
  682                   ;   Halt the system. Reason for this is unknown at present.
  683                   ;
  684 CFCF  21 76F3     HALT:	LD	HL,76F3H	;'DI HLT' instructions.
  685 CFD2  22 CC00     	LD	(CBASE),HL
  686 CFD5  21 CC00     	LD	HL,CBASE
  687 CFD8  E9          	JP	(HL)
  688                   ;
  689                   ;   Read error while TYPEing a file.
  690                   ;
  691 CFD9  01 CFDF     RDERROR:LD	BC,RDERR
  692 CFDC  C3 CCA7     	JP	PLINE
  693 CFDF  52 65 61 64 RDERR:	DEFM	"Read error"
  694 CFE9  00          	DB	0
  695                   ;
  696                   ;   Required file was not located.
  697                   ;
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  13
CPM22   Z80

  698 CFEA  01 CFF0     NONE:	LD	BC,NOFILE
  699 CFED  C3 CCA7     	JP	PLINE
  700 CFF0  4E 6F 20 66 NOFILE:	DEFM	"No file"
  701 CFF7  00          	DB	0
  702                   ;
  703                   ;   Decode a command of the form 'A>filename number{ filename}.
  704                   ; Note that a drive specifier is not allowed on the first file
  705                   ; name. On return, the number is in register (A). Any error
  706                   ; causes 'filename?' to be printed and the command is aborted.
  707                   ;
  708 CFF8  CD CE5E     DECODE:	CALL	CONVFST		;convert filename.
  709 CFFB  3A D3F0     	LD	A,(CHGDRV)	;do not allow a drive to be specified.
  710 CFFE  B7          	OR	A
  711 CFFF  C2 CE09     	JP	NZ,SYNERR
  712 D002  21 D3CE     	LD	HL,FCB+1	;convert number now.
  713 D005  01 000B     	LD	BC,11		;(B)=sum register, (C)=max digit count.
  714 D008  7E          DECODE1:LD	A,(HL)
  715 D009  FE 20       	CP	' '		;a space terminates the numeral.
  716 D00B  CA D033     	JP	Z,DECODE3
  717 D00E  23          	INC	HL
  718 D00F  D6 30       	SUB	'0'		;make binary from ascii.
  719 D011  FE 0A       	CP	10		;legal digit?
  720 D013  D2 CE09     	JP	NC,SYNERR
  721 D016  57          	LD	D,A		;yes, save it in (D).
  722 D017  78          	LD	A,B		;compute (B)=(B)*10 and check for overflow.
  723 D018  E6 E0       	AND	0E0H
  724 D01A  C2 CE09     	JP	NZ,SYNERR
  725 D01D  78          	LD	A,B
  726 D01E  07          	RLCA	
  727 D01F  07          	RLCA	
  728 D020  07          	RLCA			;(A)=(B)*8
  729 D021  80          	ADD	A,B		;.......*9
  730 D022  DA CE09     	JP	C,SYNERR
  731 D025  80          	ADD	A,B		;.......*10
  732 D026  DA CE09     	JP	C,SYNERR
  733 D029  82          	ADD	A,D		;add in new digit now.
  734 D02A  DA CE09     DECODE2:JP	C,SYNERR
  735 D02D  47          	LD	B,A		;and save result.
  736 D02E  0D          	DEC	C		;only look at 11 digits.
  737 D02F  C2 D008     	JP	NZ,DECODE1
  738 D032  C9          	RET	
  739 D033  7E          DECODE3:LD	A,(HL)		;spaces must follow (why?).
  740 D034  FE 20       	CP	' '
  741 D036  C2 CE09     	JP	NZ,SYNERR
  742 D039  23          	INC	HL
  743 D03A  0D          DECODE4:DEC	C
  744 D03B  C2 D033     	JP	NZ,DECODE3
  745 D03E  78          	LD	A,B		;set (A)=the numeric value entered.
  746 D03F  C9          	RET	
  747                   ;
  748                   ;   Move 3 bytes from (HL) to (DE). Note that there is only
  749                   ; one reference to this at (A2D5h).
  750                   ;
  751 D040  06 03       MOVE3:	LD	B,3
  752                   ;
  753                   ;   Move (B) bytes from (HL) to (DE).
  754                   ;
  755 D042  7E          HL2DE:	LD	A,(HL)
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  14
CPM22   Z80

  756 D043  12          	LD	(DE),A
  757 D044  23          	INC	HL
  758 D045  13          	INC	DE
  759 D046  05          	DEC	B
  760 D047  C2 D042     	JP	NZ,HL2DE
  761 D04A  C9          	RET	
  762                   ;
  763                   ;   Compute (HL)=(TBUFF)+(A)+(C) and get the byte that's here.
  764                   ;
  765 D04B  21 0080     EXTRACT:LD	HL,TBUFF
  766 D04E  81          	ADD	A,C
  767 D04F  CD CE59     	CALL	ADDHL
  768 D052  7E          	LD	A,(HL)
  769 D053  C9          	RET	
  770                   ;
  771                   ;  Check drive specified. If it means a change, then the new
  772                   ; drive will be selected. In any case, the drive byte of the
  773                   ; fcb will be set to null (means use current drive).
  774                   ;
  775 D054  AF          DSELECT:XOR	A		;null out first byte of fcb.
  776 D055  32 D3CD     	LD	(FCB),A
  777 D058  3A D3F0     	LD	A,(CHGDRV)	;a drive change indicated?
  778 D05B  B7          	OR	A
  779 D05C  C8          	RET	Z
  780 D05D  3D          	DEC	A		;yes, is it the same as the current drive?
  781 D05E  21 D3EF     	LD	HL,CDRIVE
  782 D061  BE          	CP	(HL)
  783 D062  C8          	RET	Z
  784 D063  C3 CCBD     	JP	DSKSEL		;no. Select it then.
  785                   ;
  786                   ;   Check the drive selection and reset it to the previous
  787                   ; drive if it was changed for the preceeding command.
  788                   ;
  789 D066  3A D3F0     RESETDR:LD	A,(CHGDRV)	;drive change indicated?
  790 D069  B7          	OR	A
  791 D06A  C8          	RET	Z
  792 D06B  3D          	DEC	A		;yes, was it a different drive?
  793 D06C  21 D3EF     	LD	HL,CDRIVE
  794 D06F  BE          	CP	(HL)
  795 D070  C8          	RET	Z
  796 D071  3A D3EF     	LD	A,(CDRIVE)	;yes, re-select our old drive.
  797 D074  C3 CCBD     	JP	DSKSEL
  798                   ;
  799                   ;**************************************************************
  800                   ;*
  801                   ;*           D I R E C T O R Y   C O M M A N D
  802                   ;*
  803                   ;**************************************************************
  804                   ;
  805 D077  CD CE5E     DIRECT:	CALL	CONVFST		;convert file name.
  806 D07A  CD D054     	CALL	DSELECT		;select indicated drive.
  807 D07D  21 D3CE     	LD	HL,FCB+1	;was any file indicated?
  808 D080  7E          	LD	A,(HL)
  809 D081  FE 20       	CP	' '
  810 D083  C2 D08F     	JP	NZ,DIRECT2
  811 D086  06 0B       	LD	B,11		;no. Fill field with '?' - same as *.*.
  812 D088  36 3F       DIRECT1:LD	(HL),'?'
  813 D08A  23          	INC	HL
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  15
CPM22   Z80

  814 D08B  05          	DEC	B
  815 D08C  C2 D088     	JP	NZ,DIRECT1
  816 D08F  1E 00       DIRECT2:LD	E,0		;set initial cursor position.
  817 D091  D5          	PUSH	DE
  818 D092  CD CCE9     	CALL	SRCHFCB		;get first file name.
  819 D095  CC CFEA     	CALL	Z,NONE		;none found at all?
  820 D098  CA D11B     DIRECT3:JP	Z,DIRECT9	;terminate if no more names.
  821 D09B  3A D3EE     	LD	A,(RTNCODE)	;get file's position in segment (0-3).
  822 D09E  0F          	RRCA	
  823 D09F  0F          	RRCA	
  824 D0A0  0F          	RRCA	
  825 D0A1  E6 60       	AND	60H		;(A)=position*32
  826 D0A3  4F          	LD	C,A
  827 D0A4  3E 0A       	LD	A,10
  828 D0A6  CD D04B     	CALL	EXTRACT		;extract the tenth entry in fcb.
  829 D0A9  17          	RLA			;check system file status bit.
  830 D0AA  DA D10F     	JP	C,DIRECT8	;we don't list them.
  831 D0AD  D1          	POP	DE
  832 D0AE  7B          	LD	A,E		;bump name count.
  833 D0AF  1C          	INC	E
  834 D0B0  D5          	PUSH	DE
  835 D0B1  E6 03       	AND	03H		;at end of line?
  836 D0B3  F5          	PUSH	AF
  837 D0B4  C2 D0CC     	JP	NZ,DIRECT4
  838 D0B7  CD CC98     	CALL	CRLF		;yes, end this line and start another.
  839 D0BA  C5          	PUSH	BC
  840 D0BB  CD CDD0     	CALL	GETDSK		;start line with ('A:').
  841 D0BE  C1          	POP	BC
  842 D0BF  C6 41       	ADD	A,'A'
  843 D0C1  CD CC92     	CALL	PRINTB
  844 D0C4  3E 3A       	LD	A,':'
  845 D0C6  CD CC92     	CALL	PRINTB
  846 D0C9  C3 D0D4     	JP	DIRECT5
  847 D0CC  CD CCA2     DIRECT4:CALL	SPACE		;add seperator between file names.
  848 D0CF  3E 3A       	LD	A,':'
  849 D0D1  CD CC92     	CALL	PRINTB
  850 D0D4  CD CCA2     DIRECT5:CALL	SPACE
  851 D0D7  06 01       	LD	B,1		;'extract' each file name character at a time.
  852 D0D9  78          DIRECT6:LD	A,B
  853 D0DA  CD D04B     	CALL	EXTRACT
  854 D0DD  E6 7F       	AND	7FH		;strip bit 7 (status bit).
  855 D0DF  FE 20       	CP	' '		;are we at the end of the name?
  856 D0E1  C2 D0F9     	JP	NZ,DRECT65
  857 D0E4  F1          	POP	AF		;yes, don't print spaces at the end of a line.
  858 D0E5  F5          	PUSH	AF
  859 D0E6  FE 03       	CP	3
  860 D0E8  C2 D0F7     	JP	NZ,DRECT63
  861 D0EB  3E 09       	LD	A,9		;first check for no extension.
  862 D0ED  CD D04B     	CALL	EXTRACT
  863 D0F0  E6 7F       	AND	7FH
  864 D0F2  FE 20       	CP	' '
  865 D0F4  CA D10E     	JP	Z,DIRECT7	;don't print spaces.
  866 D0F7  3E 20       DRECT63:LD	A,' '		;else print them.
  867 D0F9  CD CC92     DRECT65:CALL	PRINTB
  868 D0FC  04          	INC	B		;bump to next character psoition.
  869 D0FD  78          	LD	A,B
  870 D0FE  FE 0C       	CP	12		;end of the name?
  871 D100  D2 D10E     	JP	NC,DIRECT7
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  16
CPM22   Z80

  872 D103  FE 09       	CP	9		;nope, starting extension?
  873 D105  C2 D0D9     	JP	NZ,DIRECT6
  874 D108  CD CCA2     	CALL	SPACE		;yes, add seperating space.
  875 D10B  C3 D0D9     	JP	DIRECT6
  876 D10E  F1          DIRECT7:POP	AF		;get the next file name.
  877 D10F  CD CDC2     DIRECT8:CALL	CHKCON		;first check console, quit on anything.
  878 D112  C2 D11B     	JP	NZ,DIRECT9
  879 D115  CD CCE4     	CALL	SRCHNXT		;get next name.
  880 D118  C3 D098     	JP	DIRECT3		;and continue with our list.
  881 D11B  D1          DIRECT9:POP	DE		;restore the stack and return to command level.
  882 D11C  C3 D386     	JP	GETBACK
  883                   ;
  884                   ;**************************************************************
  885                   ;*
  886                   ;*                E R A S E   C O M M A N D
  887                   ;*
  888                   ;**************************************************************
  889                   ;
  890 D11F  CD CE5E     ERASE:	CALL	CONVFST		;convert file name.
  891 D122  FE 0B       	CP	11		;was '*.*' entered?
  892 D124  C2 D142     	JP	NZ,ERASE1
  893 D127  01 D152     	LD	BC,YESNO	;yes, ask for confirmation.
  894 D12A  CD CCA7     	CALL	PLINE
  895 D12D  CD CD39     	CALL	GETINP
  896 D130  21 CC07     	LD	HL,INBUFF+1
  897 D133  35          	DEC	(HL)		;must be exactly 'y'.
  898 D134  C2 CF82     	JP	NZ,CMMND1
  899 D137  23          	INC	HL
  900 D138  7E          	LD	A,(HL)
  901 D139  FE 59       	CP	'Y'
  902 D13B  C2 CF82     	JP	NZ,CMMND1
  903 D13E  23          	INC	HL
  904 D13F  22 CC88     	LD	(INPOINT),HL	;save input line pointer.
  905 D142  CD D054     ERASE1:	CALL	DSELECT		;select desired disk.
  906 D145  11 D3CD     	LD	DE,FCB
  907 D148  CD CCEF     	CALL	DELETE		;delete the file.
  908 D14B  3C          	INC	A
  909 D14C  CC CFEA     	CALL	Z,NONE		;not there?
  910 D14F  C3 D386     	JP	GETBACK		;return to command level now.
  911 D152  41 6C 6C 20 YESNO:	DEFM	"All (y/n)?"
  912 D15C  00          	DB	0
  913                   ;
  914                   ;**************************************************************
  915                   ;*
  916                   ;*            T Y P E   C O M M A N D
  917                   ;*
  918                   ;**************************************************************
  919                   ;
  920 D15D  CD CE5E     TYPE:	CALL	CONVFST		;convert file name.
  921 D160  C2 CE09     	JP	NZ,SYNERR	;wild cards not allowed.
  922 D163  CD D054     	CALL	DSELECT		;select indicated drive.
  923 D166  CD CCD0     	CALL	OPENFCB		;open the file.
  924 D169  CA D1A7     	JP	Z,TYPE5		;not there?
  925 D16C  CD CC98     	CALL	CRLF		;ok, start a new line on the screen.
  926 D16F  21 D3F1     	LD	HL,NBYTES	;initialize byte counter.
  927 D172  36 FF       	LD	(HL),0FFH	;set to read first sector.
  928 D174  21 D3F1     TYPE1:	LD	HL,NBYTES
  929 D177  7E          TYPE2:	LD	A,(HL)		;have we written the entire sector?
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  17
