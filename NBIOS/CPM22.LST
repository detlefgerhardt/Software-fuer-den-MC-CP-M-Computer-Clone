 3603                   ;
 3604                   ;   Function to compute the size of a random file.
 3605                   ;
 3606 E14F  CD E053     FILESIZE: CALL	AUTOSEL		;select proper drive and check file length
 3607 E152  C3 DFD4     	JP	RANSIZE
 3608                   ;
 3609                   ;   Function #37. This allows a program to log off any drives.
 3610                   ; On entry, set (DE) to contain a word with bits set for those
 3611                   ; drives that are to be logged off. The log-in vector and the
 3612                   ; write protect vector will be updated. This must be a M/PM
 3613                   ; special function.
 3614                   ;
 3615 E155  2A D745     LOGOFF:	LD	HL,(PARAMS)	;get drives to log off.
 3616 E158  7D          	LD	A,L		;for each bit that is set, we want
 3617 E159  2F          	CPL			;to clear that bit in (LOGIN)
 3618 E15A  5F          	LD	E,A		;and (WRTPRT).
 3619 E15B  7C          	LD	A,H
 3620 E15C  2F          	CPL	
 3621 E15D  2A E1B1     	LD	HL,(LOGIN)	;reset the login vector.
 3622 E160  A4          	AND	H
 3623 E161  57          	LD	D,A
 3624 E162  7D          	LD	A,L
 3625 E163  A3          	AND	E
 3626 E164  5F          	LD	E,A
 3627 E165  2A E1AF     	LD	HL,(WRTPRT)
 3628 E168  EB          	EX	DE,HL
 3629 E169  22 E1B1     	LD	(LOGIN),HL	;and save.
 3630 E16C  7D          	LD	A,L		;now do the write protect vector.
 3631 E16D  A3          	AND	E
 3632 E16E  6F          	LD	L,A
 3633 E16F  7C          	LD	A,H
 3634 E170  A2          	AND	D
 3635 E171  67          	LD	H,A
 3636 E172  22 E1AF     	LD	(WRTPRT),HL	;and save. all done.
 3637 E175  C9          	RET	
 3638                   ;
 3639                   ;   Get here to return to the user.
 3640                   ;
 3641 E176  3A E1E0     GOBACK:	LD	A,(AUTO)	;was auto select activated?
 3642 E179  B7          	OR	A
 3643 E17A  CA E193     	JP	Z,GOBACK1
 3644 E17D  2A D745     	LD	HL,(PARAMS)	;yes, but was a change made?
 3645 E180  36 00       	LD	(HL),0		;(* reset first byte of fcb *)
 3646 E182  3A E1E2     	LD	A,(AUTOFLAG)
 3647 E185  B7          	OR	A
 3648 E186  CA E193     	JP	Z,GOBACK1
 3649 E189  77          	LD	(HL),A		;yes, reset first byte properly.
 3650 E18A  3A E1E1     	LD	A,(OLDDRV)	;and get the old drive and select it.
 3651 E18D  32 E1D8     	LD	(EPARAM),A
 3652 E190  CD E047     	CALL	SETDSK
 3653 E193  2A D711     GOBACK1:LD	HL,(USRSTACK)	;reset the users stack pointer.
 3654 E196  F9          	LD	SP,HL
 3655 E197  2A D747     	LD	HL,(STATUS)	;get return status.
 3656 E19A  7D          	LD	A,L		;force version 1.4 compatability.
 3657 E19B  44          	LD	B,H
 3658 E19C  C9          	RET			;and go back to user.
 3659                   ;
 3660                   ;   Function #40. This is a special entry to do random i/o.
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  64
CPM22   Z80

 3661                   ; For the case where we are writing to unused disk space, this
 3662                   ; space will be zeroed out first. This must be a M/PM special
 3663                   ; purpose function, because why would any normal program even
 3664                   ; care about the previous contents of a sector about to be
 3665                   ; written over.
 3666                   ;
 3667 E19D  CD E053     WTSPECL:CALL	AUTOSEL		;select proper drive.
 3668 E1A0  3E 02       	LD	A,2		;use special write mode.
 3669 E1A2  32 E1D7     	LD	(MODE),A
 3670 E1A5  0E 00       	LD	C,0		;set write indicator.
 3671 E1A7  CD DF09     	CALL	POSITN1		;position the file.
 3672 E1AA  CC DE05     	CALL	Z,WTSEQ1	;and write (if no errors).
 3673 E1AD  C9          	RET	
 3674                   ;
 3675                   ;**************************************************************
 3676                   ;*
 3677                   ;*     BDOS data storage pool.
 3678                   ;*
 3679                   ;**************************************************************
 3680                   ;
 3681 E1AE  E5          EMPTYFCB: DB	0E5H		;empty directory segment indicator.
 3682 E1AF  0000        WRTPRT:	DW	0		;write protect status for all 16 drives.
 3683 E1B1  0000        LOGIN:	DW	0		;drive active word (1 bit per drive).
 3684 E1B3  0080        USERDMA:DW	080H		;user's dma address (defaults to 80h).
 3685                   ;
 3686                   ;   Scratch areas from parameter block.
 3687                   ;
 3688 E1B5  0000        SCRATCH1: DW	0		;relative position within dir segment for file (0-3).
 3689 E1B7  0000        SCRATCH2: DW	0		;last selected track number.
 3690 E1B9  0000        SCRATCH3: DW	0		;last selected sector number.
 3691                   ;
 3692                   ;   Disk storage areas from parameter block.
 3693                   ;
 3694 E1BB  0000        DIRBUF:	DW	0		;address of directory buffer to use.
 3695 E1BD  0000        DISKPB:	DW	0		;contains address of disk parameter block.
 3696 E1BF  0000        CHKVECT:DW	0		;address of check vector.
 3697 E1C1  0000        ALOCVECT: DW	0		;address of allocation vector (bit map).
 3698                   ;
 3699                   ;   Parameter block returned from the bios.
 3700                   ;
 3701 E1C3  0000        SECTORS:DW	0		;sectors per track from bios.
 3702 E1C5  00          BLKSHFT:DB	0		;block shift.
 3703 E1C6  00          BLKMASK:DB	0		;block mask.
 3704 E1C7  00          EXTMASK:DB	0		;extent mask.
 3705 E1C8  0000        DSKSIZE:DW	0		;disk size from bios (number of blocks-1).
 3706 E1CA  0000        DIRSIZE:DW	0		;directory size.
 3707 E1CC  0000        ALLOC0:	DW	0		;storage for first bytes of bit map (dir space used).
 3708 E1CE  0000        ALLOC1:	DW	0
 3709 E1D0  0000        OFFSET:	DW	0		;first usable track number.
 3710 E1D2  0000        XLATE:	DW	0		;sector translation table address.
 3711                   ;
 3712                   ;
 3713 E1D4  00          CLOSEFLG: DB	0		;close flag (=0ffh is extent written ok).
 3714 E1D5  00          RDWRTFLG: DB	0		;read/write flag (0ffh=read, 0=write).
 3715 E1D6  00          FNDSTAT:DB	0		;filename found status (0=found first entry).
 3716 E1D7  00          MODE:	DB	0		;I/o mode select (0=random, 1=sequential, 2=special random).
 3717 E1D8  00          EPARAM:	DB	0		;storage for register (E) on entry to bdos.
 3718 E1D9  00          RELBLOCK: DB	0		;relative position within fcb of block number written.
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  65
CPM22   Z80

 3719 E1DA  00          COUNTER:DB	0		;byte counter for directory name searches.
 3720 E1DB  0000  0000  SAVEFCB:DW	0,0		;save space for address of fcb (for directory searches).
 3721 E1DF  00          BIGDISK:DB	0		;if =0 then disk is > 256 blocks long.
 3722 E1E0  00          AUTO:	DB	0		;if non-zero, then auto select activated.
 3723 E1E1  00          OLDDRV:	DB	0		;on auto select, storage for previous drive.
 3724 E1E2  00          AUTOFLAG: DB	0		;if non-zero, then auto select changed drives.
 3725 E1E3  00          SAVNXT:	DB	0		;storage for next record number to access.
 3726 E1E4  00          SAVEXT:	DB	0		;storage for extent number of file.
 3727 E1E5  0000        SAVNREC:DW	0		;storage for number of records in file.
 3728 E1E7  0000        BLKNMBR:DW	0		;block number (physical sector) used within a file or logical sect
 3729 E1E9  0000        LOGSECT:DW	0		;starting logical (128 byte) sector of block (physical sector).
 3730 E1EB  00          FCBPOS:	DB	0		;relative position within buffer for fcb of file of interest.
 3731 E1EC  0000        FILEPOS:DW	0		;files position within directory (0 to max entries -1).
