	DEFB 'Neustart = Taste W druecken',0dh,0ah,0

VMSG:	DEFB 0dh,0ah
	DEFB 'Diskette wird geprueft ... bitte warten',0dh,0ah
	DEFB 0dh,0ah,0

FIMSG:	DEFB 1ah,0dh,0ah
	DEFB 'Systemdiskette in Laufwerk A einlegen,',0dh,0ah
	DEFB 'dann CR (carriage return) druecken.',0dh,0ah,0

	DEFB 0		; v1.22
	
USER:	DEFB 0  	; 0=FLO1/FLO2 (C0h), 1=FLO1 Maxi, 2=FLO1 Mini
FLOTYP:	DEFB 0    	; 0=FLO2 (C0h), 1=FLO1 (C0h) (only if USER=0)
MINMAX:	DEFB 0  	; 0=Mini, 1=Maxi
ECMA:	DEFB 0  	; 1=ECMA70 format (SD,128 on track 0)
BYTCNT:	DEFW 0  	; Anzahl der Bytes pro Sektor
FILLER:	DEFB 0E5h 	; fill byte std=E5h
DENSITY:DEFB 0  	; 0=single-density, 1=double-density
GAPLEN:	DEFB 0  	; Gap 3 Laenge zwischen Sektoren
TRKCNT:	DEFB 0  	; Anzahl der Spuren
SSDS:	DEFB 0  	; 0=single-sided, 1=double-sided
SECCNT:	DEFB 0  	; Anzahl der Sektoren pro Spur
DRIVE:	DEFB 0  	; drive code (1,2,4,8), Bit7=1: Side 1
SIDESEL:DEFB 0  	; SSO: 0=Seite 0, 80h=Seite 1 (wird nur bei USESSO=1 gesetzt fuer FD1797)
USESSO:	DEFB 0  	; 0=no SSO, 1=use SSO (nur fuer FD1797)
		
CURTRK:	DEFB 0  	; aktuelle Spur
CURSEC:	DEFB 0  	; aktueller Sektor

FORMTAB:	; Formatierbereich, hier wird ein Track gelegt.

	END start
