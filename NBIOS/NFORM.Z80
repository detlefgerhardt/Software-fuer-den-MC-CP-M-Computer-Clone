	DEFB 'Maxilaufwerke (8"    ) = 2',0dh,0ah
	DEFB 'Std  8" SD SD 77 Spur  = 3',0dh,0ah
	DEFB 'ECMA 70 DD SD 40 Spur  = 4',0dh,0ah
	DEFB 'NDR- DD DS 80 Spur     = 5',0dh,0ah
