  150                   	
  151 0192  21 1838     	LD HL,VMSG
  152 0195  CD 0B99     	CALL PRNMSG
  153                   	
  154 0198  CD 048E     	CALL HOME	; set head to track 0
  155                   	
  156 019B  AF          	XOR A
  157 019C  32 18C7     	LD (CURTRK),A  	; start with track 0
