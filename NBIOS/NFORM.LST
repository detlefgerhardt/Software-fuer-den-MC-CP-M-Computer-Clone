  233 020E  3E 00       	LD A,0		; single-sided
  234 0210  32 18C2     	LD (SSDS),A
  235 0213  3E 10       	LD A,16		; 16 sectors
  236 0215  32 18C3     	LD (SECCNT),A
  237 0218  3E 1B       	LD A,27
  238 021A  32 18C0     	LD (GAPLEN),A
  239 021D  3E 28       	LD A,40		; 40 tracks
  240 021F  32 18C1     	LD (TRKCNT),A
  241 0222  C3 0244     	JP ECMAC2
  242                   	
  243 0225              ECMAC1:	; not track 0, format double density
