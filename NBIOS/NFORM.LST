    1                   	.z80
    2                   
    3                   ;*****************************************************************************
    4                   ; NFORM.Z80  Universal Formatierer fuer Mini/Maxi
    5                   ;
    6                   ; Boot loader for MC CP/M-Computer Mini drive with FLO2 contoller
    7                   ;
    8                   ; based on UFORMAT Rev 1.22 (C) 1984 Rolf-Dieter Klein / JS
    9                   ;
   10                   ;*****************************************************************************
   11                   ; works directly on Monitor and FLO2 hardware, does not need CP/M or BIOS
   12                   
   13                   ; 80 Spur Laufwerke   1K pro Sektor Boot
   14                   ; das programm wird auf sektor 1 track 0 abgelegt
   15                   ;
   16                   ; PLEASE NOTE THE CHANGED CPM & BIOS START ADDRESS!!!
   17                   ;
   18                   ; Version history
   19                   ;
   20                   ; 31.05.2026 *dg* Source code of version 1.22 retrieved from binary
   21                   ; 10.07.2026 *dg* Renamed to NFORM and reformatted
   22                   
   23                   ; IO ADDESSES FLO1/FLO2 Mini/Maxi
   24         00C0      FLO0	EQU 0C0H	; Status/Command
   25         00C1      FLO1	EQU 0C1H	; Track
   26         00C2      FLO2	EQU 0C2H	; Sector
   27         00C3      FLO3	EQU 0C3H	; Data
   28         00C4      FLO4	EQU 0C4H	; Special FLO-Flags
   29                   
   30                   ; IO ADDESSES FLO1 Maxi
   31         0040      FLOA0	EQU 040H
   32         0041      FLOA1	EQU 041H
   33         0042      FLOA2	EQU 042H
   34         0043      FLOA3	EQU 043H
   35         0044      FLOA4	EQU 044H
   36                   
   37                   ; IO ADDESSES FLO1 Mini
   38         0030      FLOB0	EQU 030H
   39         0031      FLOB1	EQU 031H
   40         0032      FLOB2	EQU 032H
   41         0033      FLOB3	EQU 033H
   42         0034      FLOB4	EQU 034H
   43                   
   44                   ;-----------------------------------------------------------------------------
   45                   
   46 0100  C3 070E     	JP START 	; Hauptprogramm
   47                   
   48                   ;-----------------------------------------------------------------------------
   49                   
   50 0103  C3 F009     CONOUT:	JP 0F009H 	; Ausgabe eines Zeichens in C
   51                   
   52                   ;-----------------------------------------------------------------------------
   53                   
   54 0106  CD F003     CONIN:	CALL 0F003H 	; Eingabe eines Zeichens nach A
   55 0109  E6 7F       	AND 7FH
   56 010B  C9          	RET
   57                   
   58                   ;-----------------------------------------------------------------------------
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   2
NFORM   Z80

   59                   ; Interrupt routine
   60                   
   61 010C  F1          INTR:	POP AF
   62                   	; reset interrupts
   63 010D  DB 40       	IN A,(FLOA0)
   64 010F  DB 30       	IN A,(FLOB0)
   65 0111  DB C0       	IN A,(FLO0)
   66 0113  FB          	EI
   67 0114  ED 4D       	RETI
   68                   
   69                   ;-----------------------------------------------------------------------------
   70                   ; Universal Formatter
   71                   
   72 0116  21 156C     FORMAT:	LD HL,FMSG 
   73 0119  CD 0B99     	CALL PRNMSG
   74                   	
   75                   	; reset interrupts
   76 011C  DB 40       	IN A,(FLOA0) 	; ggf. bei gemischtem Betrieb auch
   77 011E  DB 30       	IN A,(FLOB0)   	; andere Ports loeschen
   78 0120  DB C0       	IN A,(FLO0) 	; alle Interrupts loeschen
   79                   
   80 0122  ED 56       	IM 1  		; MODE 1, RST-7 verwenden
   81 0124  3E C3       	LD A,0C3H 	; Sprungvektor setzen (JP)
   82 0126  32 0038     	LD (38H),A
   83 0129  21 010C     	LD HL,INTR
   84 012C  22 0039     	LD (39H),HL 	; auf Interruptroutine
   85                   
   86                   	; --- format ---------------------------------------------------------
   87                   
   88 012F  CD 048E     	CALL HOME 	; set head to track 0
   89                   
   90 0132  AF          	XOR A
   91 0133  32 18C7     	LD (CURTRK),A  	; start with track 0
   92 0136  3A 18C1     	LD A,(TRKCNT) 	; number of tracks
   93 0139  47          	LD B,A
   94                   
   95 013A              FORM1:	; format loop (tracks)
   96                   
   97                   	; --- format side 0 ---
   98                   	
   99 013A  C5          	PUSH BC
  100 013B  CD 01F3     	CALL ECMACHK 	; check if track 0 and ECMA70
  101 013E  CD 02E3     	CALL GENTRK 	; create track
  102 0141  CD 0674     	CALL FRMTRK 	; format track
  103 0144  CD 0245     	CALL ERRCHK
  104                   	
  105 0147  3A 18C2     	LD A,(SSDS)
  106 014A  FE 01       	CP 1
  107 014C  C2 0178     	JP NZ,FORM3	; -> single sided
  108                   
  109                   	; --- double-sided,. format side 1 ---
  110                   	
  111 014F  3A 18C4     	LD A,(DRIVE)	; Rueckseite setzen
  112 0152  F6 80       	OR 80H  	; aber kein Side-sel
  113 0154  32 18C4     	LD (DRIVE),A
  114                   
  115 0157  3A 18C6     	LD A,(USESSO)
  116 015A  B7          	OR A
