  245 0228  22 18BC     	LD (BYTCNT),HL
  246                   	
  247 022B  3E 01       	LD A,1		; double density
  248 022D  32 18BF     	LD (DENSITY),A
  249 0230  3E 00       	LD A,0 		; single-sided
  250 0232  32 18C2     	LD (SSDS),A
  251 0235  3E 10       	LD A,16 	; 16 sectors
  252 0237  32 18C3     	LD (SECCNT),A
  253 023A  3E 36       	LD A,54
  254 023C  32 18C0     	LD (GAPLEN),A 	; STD Gap
  255 023F  3E 28       	LD A,40 	; 40 tracks
  256 0241  32 18C1     	LD (TRKCNT),A
  257                   
  258 0244  C9          ECMAC2:	RET
  259                   
  260                   ;-----------------------------------------------------------------------------
  261                   ; General error check routine
  262                   
  263                   ; error code in A
  264                   ;   bit 2 = CPU to slow
  265                   ;   bit 3 = CRC error
  266                   ;   bit 4 = record not found
  267                   ;   bit 5 = wrong record type
  268                   ;   bit 6 = write protected
  269                   
  270 0245  B7          ERRCHK:	OR A
  271 0246  C8          	RET Z  	; =0? -> Status ok
  272                   	
  273                   	; TRACK, Spur ausgeben
  274 0247  F5          	PUSH AF 	; save error code
  275 0248  21 1721     	LD HL,TKMSG
  276 024B  CD 0B99     	CALL PRNMSG
  277 024E  3A 18C7     	LD A,(CURTRK)
  278 0251  6F          	LD L,A
  279 0252  26 00       	LD H,0 
  280 0254  CD 02AE     	CALL PRNTHL
  281 0257  21 172C     	LD HL,SKMSG
  282 025A  CD 0B99     	CALL PRNMSG
  283 025D  3A 18C8     	LD A,(CURSEC)
  284 0260  6F          	LD L,A
  285 0261  26 00       	LD H,0
  286 0263  CD 02AE     	CALL PRNTHL
  287 0266  CD 0D50     	CALL CRLF
  288                   
  289 0269  F1          	POP AF  	; restore error code
  290                   	
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   6
NFORM   Z80

  291                   	; check bit 2
  292 026A  CB 57       	BIT 2,A
  293 026C  21 16ED     	LD HL,F0MSG 	; error message
  294 026F  CA 0275     	JP Z,ERRC1	; -> bit 2 not set
  295                   	
  296                   	; bit 2, CPU too slow
  297 0272  21 167B     	LD HL,F2MSG
  298                   
  299 0275              ERRC1:	; check bit 3
  300 0275  CB 5F       	BIT 3,A
  301 0277  CA 027D     	JP Z,ERRC2	; -> bit 3 not set
  302                   
  303                   	; bit 3, CRC errror
  304 027A  21 1643     	LD HL,F3MSG
  305                   
  306 027D              ERRC2:	; check bit 4
  307 027D  CB 67       	BIT 4,A
  308 027F  CA 0285     	JP Z,ERRC3	; -> bit 4 not set
  309                   	
  310                   	; bit 4, record not found
  311 0282  21 160C     	LD HL,F4MSG
  312                   	
  313 0285              ERRC3:	; check bit 5
  314 0285  CB 6F       	BIT 5,A
  315 0287  CA 028D     	JP Z,ERRC4	; -> bit 5 not set
  316                   
  317                   	; bit 5, wrong record type
  318 028A  21 15D5     	LD HL,F5MSG
  319                   
  320 028D              ERRC4:	; check bit 6
  321 028D  CB 77       	BIT 6,A
  322 028F  CA 0295     	JP Z,ERRC5	; -> bit 6 not set
  323                   
  324                   	; bit 6, write protected
  325 0292  21 159E     	LD HL,F6MSG
  326                   	
  327 0295              ERRC5:	; check bit 7
  328 0295  CA 029B     	JP Z,ERRC6
  329                   	
  330                   	; bit 7, write protected
  331 0298  21 159E     	LD HL,F6MSG 	; dominant is write proteced error
  332                   
  333 029B  CD 0B99     ERRC6:	CALL PRNMSG
  334                   
  335 029E              ERRC7:	; wait for 'W' or 'w'
  336 029E  CD 0106     	CALL CONIN
  337 02A1  FE 57       	CP 'W'
  338 02A3  CA 02AB     	JP Z,ERRC8
  339 02A6  FE 77       	CP 'w'
  340 02A8  C2 029E     	JP NZ,ERRC7
  341                   
  342 02AB  C3 070E     ERRC8:	JP START 	; no stack adjust needed
  343                   	
  344                   ;-----------------------------------------------------------------------------
  345                   ; PRNMSG decimal value in HL
  346                   	
  347 02AE  AF          PRNTHL:	XOR A
  348 02AF  F5          	PUSH AF
