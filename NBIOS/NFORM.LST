  224 01FF  B7          	OR A
  225 0200  C2 0225     	JP NZ,ECMAC1	; -> not track 0
  226                   	
  227                   	; track 0, format single-density
  228 0203  21 0080     	LD HL,128
  229 0206  22 18BC     	LD (BYTCNT),HL
