Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   1
NPUTBOOTZ80

    1                   	.Z80
    2                   ;**********************************************************************
    3                   ;* NPUTBOOT.Z80
    4                   ;*
    5                   ;* Write Bootloader from memory location 1000H to Disk.
    6                   ;* This program is designated to be started from the Monitor.
    7                   ;*
    8                   ;* based on LOAD80.Z80 by U. Haumann 07.05.2026
    9                   ;*
   10                   ;**********************************************************************
   11                   ; Der Boot Loader muss sich an Adresse 1000H befinden							
   12                   ; 80 Spur Laufwerke   1K pro Sektor Boot       
   13                   ;
   14                   ; PLEASE NOTE THE CHANGED CP/M & BIOS START ADDRESS !!!
   15                   ;
   16                   ; Version history
   17                   ;
   18                   ; 10.07.2026 *dg* Renamed to NPUTBOOT and reformatted source code
   19                   ; 11.07.2026 *dg* Use new floppy routine 0F021h in Monitor
   20                   
   21                   ;-----------------------------------------------------------------------------
   22                   
   23         0100      	ORG	0100H		
   24                   
   25         9800      OFFSET	EQU 0A000H-800H		; damit BIOS Start bei E200h
   26         CC00      CPMB	EQU 03400H+OFFSET	; start CP/M
   27         E200      BIOS	EQU 04A00H+OFFSET	; start BIOS
   28                   
   29                   ; Monitor functions
   30         F01E      RSTRT	EQU 0F01EH	; Restart routine in Monitor
   31         F021      FLOP	EQU 0F021H	; Monior Floppy routine
   32         F027      MINI	EQU 0F027H	; Old MINI routine in Monitor (obsolete)
   33                   
   34         1000      MEMADDR	EQU 01000H	; address for boot loader in memory
   35                   
   36                   ;-----------------------------------------------------------------------------
   37                   
   38 0100  31 00FF     WBOOT:	LD SP,0FFH	; set stack
   39                   
   40 0103  21 1000     	LD HL,MEMADDR	; START ADRESSE Boot Loader
   41 0106  16 00       	LD D,0		; write to track 0
   42 0108  1E 01       	LD E,1		; write to sector 1 (first sector)
   43                   
   44 010A  E5          	PUSH HL
   45 010B  D5          	PUSH DE
   46 010C  C5          	PUSH BC
   47                   	;LD C,11010000B	; laufwerk 0 double dense mini
   48                   	;LD B,2		; 1=read, 2=write
   49                   	;CALL MINI	; Monitor Einsprung Mini Laufwerk
   50                   	; use new floppy routine instead
   51 010D  0E 21       	LD C,00100001B	; drive 0, dd, mini
   52 010F  06 02       	LD B,2		; 2 = write
   53 0111  CD F021     	CALL FLOP	; -> read sector
   54 0114  C1          	POP BC
   55 0115  D1          	POP DE
   56 0116  E1          	POP HL
   57 0117  DA F01E     	JP C,RSTRT	; -> error -> call monitor restart
   58                   				
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   2
NPUTBOOTZ80

   59 011A  C3 E200     	JP BIOS		; no error -> CP/M cold boot
   60                   
   61                   ;-----------------------------------------------------------------------------
   62                   
   63                   	END
