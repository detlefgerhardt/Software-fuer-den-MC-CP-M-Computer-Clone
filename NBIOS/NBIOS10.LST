  702                   ;-----------------------------------------------------------------------------
  703                   ; Sector translation (used by BDOS)
  704                   ; sector in C
  705                   ; skew table in DE (or 0)
  706                   
  707 E41F  7A          SECTRAN:LD A,D		; wenn ein SKEW-Faktor verwendet wird,
  708 E420  B3                  OR E		; wie z.B. bei 8 Zoll ueblich.
  709 E421  CA E42E             JP Z,SECTR1	; =0, -> no skew
  710                   
  711 E424  06 00       	LD B,0		; sonst in DE Adresse der Skew-Tabelle
  712 E426  EB          	EX DE,HL	; skew table -> HL
  713 E427  09          	ADD HL,BC	; add BC
  714 E428  7E          	LD A,(HL)	; load skew value
  715 E429  32 E791     	LD (IOS),A	; save in IOS 
  716 E42C  6F          	LD L,A		; and in L
  717 E42D  C9          	RET
  718                   
  719 E42E              SECTR1:	; no skew
  720 E42E  69          	LD L,C		; sonst nur einfache Wert
  721 E42F  79                  LD A,C		; uebernehmen, ohne Umrechnung.
  722 E430  32 E791             LD (IOS),A	; auch merken
  723 E433  26 00               LD H,0		; se 0..255 max
  724 E435  C9                  RET
