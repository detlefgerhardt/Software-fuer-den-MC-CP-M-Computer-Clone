  308                   	; Disk 0 (A) ---------------------------------------------------------
  309                   	
  310                   	; *** DISKDEF BEDEUTUNG DER PARAMETER***
  311                   	; 0 = NUMMER DES LAUFWERKS
  312                   	; 0 = NUMMER DES ERSTEN SEKTORS EINER SPUR
  313                   	; 39 =  NUMMER DES LETZTEN SEKTORS EINER SPUR
  314                   	; 0 = OPTIONALER VERSCHIEBUNGSFAKTOR ZUM
  315                   	;     VERSETZEN ABSPEICHERN DER SEKTOREN
  316                   	; 2048 = GROESSE EINES BLOCKS
  317                   	; SIZEAB = ZAHL DER MAX. MOEGLICHEN BLOECKE
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   4
NBIOS10 Z80

  318                   	; 256 = ZAHL DER DIRECTORY EINTRITTSPUNKTE
  319                   	; 256 = ZAHL DER GEPRUEFTEN EINTRITTSPUNKTE
  320                   	; OFFSAB = ADDITIVE KONSTANTE ZUM ANSPRECHEN DER SPUR 00
  321                   
  322                   	; physical format: 3,5 inch/5.25 inch, DD, DS, 1024 bytes/sector, 5 sectors/track, 80 tracks
  323                   	; DISKDEF 0,0,39,0,2048,SIZEAB,256,256,OFFSAB
  324         E2B3      DPB0	EQU	$		;DISK PARM BLOCK
  325 E2B3  0028        	DW	40		;SEC PER TRACK
  326 E2B5  04          	DB	4		;BLOCK SHIFT
  327 E2B6  0F          	DB	15		;BLOCK MASK
  328 E2B7  00          	DB	0		;EXTNT MASK
  329 E2B8  0184        	DW	388		;DISK SIZE-1
  330 E2BA  00FF        	DW	255		;DIRECTORY MAX
  331 E2BC  F0          	DB	240		;ALLOC0
  332 E2BD  00          	DB	0		;ALLOC1
  333 E2BE  0040        	DW	64		;CHECK SIZE
  334 E2C0  0004        	DW	4		;OFFSET
  335         0000      XLT0	EQU	0		;NO XLATE TABLE
  336                   
  337                   	; Disk 1 (B), same as Disk A -----------------------------------------
  338                   	
  339                   	; DISKDEF 1,0	; LAUFWERK 1 WIE LAUFWERK 0 DEFINIERT
  340         E2B3      DPB1	EQU	DPB0	;EQUIVALENT PARAMETERS
  341                   ;ALS1	EQU	ALS0	;SAME ALLOCATION VECTOR SIZE
  342                   ;CSS1	EQU	CSS0	;SAME CHECKSUM VECTOR SIZE
  343         0000      XLT1	EQU	XLT0	;SAME TRANSLATE TABLE
  344                   
  345                   	; Disk 2 (C), same as Disk A -----------------------------------------
  346                   
  347                   	; DISKDEF 2,0	; LAUFWERK 2 WIE LAUFWERK 0 DEFINIERT
  348         E2B3      DPB2	EQU	DPB0	;EQUIVALENT PARAMETERS
  349                   ;ALS2	EQU	ALS0	;SAME ALLOCATION VECTOR SIZE
  350                   ;CSS2	EQU	CSS0	;SAME CHECKSUM VECTOR SIZE
  351         0000      XLT2	EQU	XLT0	;SAME TRANSLATE TABLE
  352                   
  353                   	; Disk 3 (D) --------------------------------------------------------
  354                   	; physical format: 8 inch, SD, SS, 128 bytes/sector, 26 sectors/track, 77 tracks
  355                   	; DISKDEF 3,1,26,6,1024,243,64,64,2 ; 8 ZOLL DEFINITION
  356                   
  357         E2C2      DPB3	EQU	$		;DISK PARM BLOCK
  358 E2C2  001A         	DW	26		;SEC PER TRACK
  359 E2C4  03           	DB	3		;BLOCK SHIFT
  360 E2C5  07           	DB	7		;BLOCK MASK
  361 E2C6  00           	DB	0		;EXTNT MASK
  362 E2C7  00F2         	DW	242		;DISK SIZE-1
  363 E2C9  003F         	DW	63		;DIRECTORY MAX
  364 E2CB  C0           	DB	192		;ALLOC0
  365 E2CC  00           	DB	0		;ALLOC1
  366 E2CD  0010         	DW	16		;CHECK SIZE
  367 E2CF  0002         	DW	2		;OFFSET
  368                   	
  369         E2D1      XLT3	EQU	$		;TRANSLATE TABLE
  370 E2D1  01           	DB	1		
  371 E2D2  07           	DB	7		
  372 E2D3  0D           	DB	13		
  373 E2D4  13           	DB	19		
  374 E2D5  19           	DB	25		
  375 E2D6  05           	DB	5		
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   5
NBIOS10 Z80

  376 E2D7  0B           	DB	11		
  377 E2D8  11           	DB	17		
  378 E2D9  17           	DB	23		
  379 E2DA  03           	DB	3		
  380 E2DB  09           	DB	9		
  381 E2DC  0F           	DB	15		
  382 E2DD  15           	DB	21		
  383 E2DE  02           	DB	2		
  384 E2DF  08           	DB	8		
  385 E2E0  0E           	DB	14		
  386 E2E1  14           	DB	20		
  387 E2E2  1A            	DB	26		
  388 E2E3  06           	DB	6		
  389 E2E4  0C           	DB	12		
  390 E2E5  12           	DB	18		
  391 E2E6  18           	DB	24		
  392 E2E7  04           	DB	4		
  393 E2E8  0A           	DB	10		
  394 E2E9  10           	DB	16		
  395 E2EA  16           	DB	22	
  396                   
  397                   	; Disk 4 (E), IDE partition 0 ----------------------------------------
  398                   	; 64-sector tracks, numbering starting at zero (sectors 0 to 63)
  399                   	; Block size 2048
  400                   	; Disk size 2 mb, DSM 1023, yields 256 tracks (0 to 255)
  401 E2EB              DPB4:	;disk parameter block for all disks.
  402 E2EB  0040        	DW	64		;sectors per track
  403 E2ED  04          	DB	4		;block shift factor
  404 E2EE  0F          	DB	15		;block mask - with block shift, sets block size to 1024
  405 E2EF  00          	DB	0		;null mask
  406 E2F0  03FF        	DW	1023		;disk size-1 = number of blocks in a disk - 1
  407 E2F2  0100        	DW	256		;directory max = no. directory entries/disk, arbitrary
  408 E2F4  F0          	DB	240		;alloc 0 -- need 4 bits (blocks) for 256 directory entries -- 
  409 E2F5  00          	DB	0		;alloc 1 -- no. bits = (directory max x 32)/block size	
  410 E2F6  0000        	DW	0		;check size -- no checking, so zero
  411 E2F8  0001        	DW	1		;track offset -- first track for system
  412                   
  413                   	; Disk 5 (F), IDE partition 1 ----------------------------------------
  414         E2EB      DPB5	EQU	DPB4	;EQUIVALENT PARAMETERS
  415                   ;ALS3	EQU	ALS2	;SAME ALLOCATION VECTOR SIZE
  416                   ;CSS3	EQU	CSS2	;SAME CHECKSUM VECTOR SIZE
  417                   
  418                   	; Disk 6 (G), IDE partition 2 ----------------------------------------
  419         E2EB      DPB6	EQU	DPB4	;EQUIVALENT PARAMETERS
  420                   ;ALS3	EQU	ALS2	;SAME ALLOCATION VECTOR SIZE
  421                   ;CSS3	EQU	CSS2	;SAME CHECKSUM VECTOR SIZE
  422                   
  423                   	; Disk 7 (H), IDE partition 3 ----------------------------------------
  424         E2EB      DPB7	EQU	DPB4	;EQUIVALENT PARAMETERS
  425                   ;ALS3	EQU	ALS2	;SAME ALLOCATION VECTOR SIZE
  426                   ;CSS3	EQU	CSS2	;SAME CHECKSUM VECTOR SIZE
  427                   
  428                   	ENDIF	; MINI3
  429                   
