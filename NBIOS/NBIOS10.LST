 1018                   
 1019         FC00      PHSBUF	EQU 0FC00H	; Memory area of interactive Monitor for logical sector (1K)
 1020                   
 1021                   ;-----------------------------------------------------------------------------
 1022                   ; Calculates physical drive from DBANK and IOT -> C
 1023                   ; only for Mini disks 0 and 1
 1024                   
 1025                   ; DBANK, IOT     C
 1026                   ;  0     F    -> 0
 1027                   ;  1     F    -> 2
 1028                   ;  0     B    -> 1
 1029                   ;  1     B    -> 3
 1030                   
 1031                   ; muss fuer Minidisk C und D erweitert werden
 1032                   
 1033                   ; calculates physical sector from logical sector, IOS -> E
 1034                   ; logical sector 0..39 -> physical sector 1..5
 1035                   
 1036                   ; calculates logical track from physical track, IOT -> D
 1037                   ; 0..159 -> 0..79 (max 127)
 1038                   
 1039 E502              MINCAL:
 1040                   
 1041         0000      	IF NOT DG01	; ----------
 1080                   	ELSE	; ----------
 1081                   
 1082                   	; logical sector (128 byte) to physical sector
 1083                   	
 1084         0000      	IF FALSE
 1096                   	ELSE
 1097                   	
 1098 E502  3A E6D4     	LD A,(IOS)	; 0..39 IST DER BEREICH (logic sector)
 1099                   	; hier den Maximalwert pruefen
 1100                   
 1101 E505  1E 03       	LD E,SECPOW
 1102 E507  B3          	OR E
 1103 E508  CA E513     	JP Z,MINIC3
 1104                   
 1105 E50B  C5          	PUSH BC
 1106 E50C  43          	LD B,E
 1107                   	
 1108 E50D  0F          MINIC2:	RRCA
 1109 E50E  10 FD       	DJNZ MINIC2
 1110                   
 1111 E510  C1          	POP BC
 1112                   
 1113 E511  E6 07       	AND 00000111b	; important because of rotate command
 1114                   
 1115 E513  3C          MINIC3:	INC A		; sector number starts with 1
 1116 E514  5F          	LD E,A		; save in E
 1117                   
 1118                   	ENDIF
 1119                   
 1120                   	; drive A,B,C -> 001,010,100
 1121 E515  E5          	PUSH HL
 1122 E516  3A E6D0     	LD A,(DBANK)
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  16
