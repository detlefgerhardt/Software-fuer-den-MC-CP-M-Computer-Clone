  706                   ;-----------------------------------------------------------------------------
  707                   ; Sector translation (used by BDOS)
  708                   ; sector in C
  709                   ; skew table in DE (or 0)
  710                   
  711 E42D  7A          SECTRAN:LD A,D		; wenn ein SKEW-Faktor verwendet wird,
  712 E42E  B3                  OR E		; wie z.B. bei 8 Zoll ueblich.
  713 E42F  CA E43C             JP Z,SECTR1	; =0, -> no skew
  714                   
  715 E432  06 00       	LD B,0		; sonst in DE Adresse der Skew-Tabelle
  716 E434  EB          	EX DE,HL	; skew table -> HL
  717 E435  09          	ADD HL,BC	; add BC
  718 E436  7E          	LD A,(HL)	; load skew value
  719 E437  32 E6D4     	LD (IOS),A	; save in IOS 
  720 E43A  6F          	LD L,A		; and in L
  721 E43B  C9          	RET
  722                   
  723 E43C              SECTR1:	; no skew
  724 E43C  69          	LD L,C		; sonst nur einfache Wert
  725 E43D  79                  LD A,C		; uebernehmen, ohne Umrechnung.
  726 E43E  32 E6D4             LD (IOS),A	; auch merken
  727 E441  26 00               LD H,0		; se 0..255 max
  728 E443  C9                  RET
