 1000                   ; Read Mini disk, 80 Spur, DD, DS
 1001                   
 1002                   ;READ und WRITE unter Verwendung von MEXEC
 1003                   ; HL=DMA ADR
 1004                   ; DE=TRACK/SECTOR
 1005                   ; B=0 RSTORE
 1006                   ;   1 READ
 1007                   ;   2 WRITE
 1008                   ; C=DRIVE 0...3  10H,11H,12H,13H  DOUBMIN 0D0H,0D1H,0D2H,0D3H
 1009                   ;                                          A   C    B    D
 1010                   ; 1K BUFFER IN MONITORGEBIET
 1011                   ; WIRD DADURCH TEILWEISE UEBERSCHRIEBEN
 1012                   ; BEI WARMBOOT MUSS BUFFER GELEERT WERDEN
 1013                   ; DEBLOCK WIRD AUS SICHERHEITSGRUENDEN NICHT VERWENDET
 1014                   
 1015         FC00      PHSBUF	EQU 0FC00H	; Memory area of interactive Monitor for logical sector (1K)
 1016                   
