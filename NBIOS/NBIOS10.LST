  814 E46C  3A E79C     ADRERZ:	LD A,(IOT)		; Track holen
  815 E46F  0F           	RRCA 			; und umrechnen
  816 E470  E6 0F        	AND 0FH		; unterer Teil vom MSB
  817 E472  67           	LD H,A
  818 E473  3A E79D      	LD A,(IOS)		; dann Sektor dazu
  819 E476  07           	RLCA
  820 E477  07           	RLCA
  821 E478  07           	RLCA
  822 E479  07           	RLCA
  823 E47A  E6 F0        	AND 0F0H
  824 E47C  B4           	OR H
  825 E47D  67           	LD H,A		; damit sssstttt ok
  826 E47E  3A E79C      	LD A,(IOT)
  827 E481  0F           	RRCA			; txxxxxxx
  828 E482  E6 80        	AND 80H
  829 E484  6F           	LD L,A		; t0000000
  830 E485  3A E79C      	LD A,(IOT)		; nun noch bank bestimmen, in c und b	
  831 E488  07           	RLCA			; und dazu msb-Teil des Tracks verwenden
  832 E489  07           	RLCA			; 0mmttttt
  833 E48A  07           	RLCA			; Banknummer
  834 E48B  E6 03        	AND 03H		; 000000mm
  835 E48D  C6 01       	ADD A,1			; erst ab Bank 1 starten
  836 E48F  47           	LD B,A		; da BANK 0=CP/M RAM und TPA
  837 E490  4F           	LD C,A		; ok beide definiert
