  820                   	; Calculate address for ram disk, source in HL
  821                   	; SEKTOR 0..E,  TRAck 0..5fh
  822                   	; SSSSTTTT T0000000   , adresse fuer RAM-Floppy
  823 E46E  3A E6D3     ADRERZ:	LD A,(IOT)		; Track holen
  824 E471  0F           	RRCA 			; und umrechnen
  825 E472  E6 0F        	AND 0FH		; unterer Teil vom MSB
  826 E474  67           	LD H,A
  827 E475  3A E6D4      	LD A,(IOS)		; dann Sektor dazu
  828 E478  07           	RLCA
  829 E479  07           	RLCA
  830 E47A  07           	RLCA
  831 E47B  07           	RLCA
  832 E47C  E6 F0        	AND 0F0H
  833 E47E  B4           	OR H
  834 E47F  67           	LD H,A		; damit sssstttt ok
  835 E480  3A E6D3      	LD A,(IOT)
  836 E483  0F           	RRCA			; txxxxxxx
  837 E484  E6 80        	AND 80H
  838 E486  6F           	LD L,A		; t0000000
  839 E487  3A E6D3      	LD A,(IOT)		; nun noch bank bestimmen, in c und b	
  840 E48A  07           	RLCA			; und dazu msb-Teil des Tracks verwenden
  841 E48B  07           	RLCA			; 0mmttttt
  842 E48C  07           	RLCA			; Banknummer
  843 E48D  E6 03        	AND 03H		; 000000mm
  844 E48F  C6 01       	ADD A,1			; erst ab Bank 1 starten
  845 E491  47           	LD B,A		; da BANK 0=CP/M RAM und TPA
  846 E492  4F           	LD C,A		; ok beide definiert
  847 E493  C9           	RET
