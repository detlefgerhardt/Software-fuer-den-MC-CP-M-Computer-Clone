  260                   	; size of mini disks A, B, C
  261                   	; TRUNC(5 logical sectors * 1024 logical sector size * (2*80 tracks - 4 offset) / 2048 block size) - 1 = ca. 780 KB
  262                   	; TRUNC (5 * 1024 * (160-4)/2048) - 1 = ca. 780 K
  263         0185      SIZEAB	EQU 389
  264                   
  265                   	; track offset for disk A, B, C
  266         0004      OFFSAB	EQU 4
  267                   
  268                   	;DISKS 8		; define 8 drives (A..H)
  269         0008      NDISKS	EQU	8	
  270                   
  271         E233      DPBASE	EQU	$		;BASE OF DISK PARAMETER BLOCKS
  272                   
  273 E233  0000  0000  DPE0:	DW	XLT0,0000H	;TRANSLATE TABLE
  274 E237  0000  0000  	DW	0000H,0000H	;SCRATCH AREA
  275 E23B  E6D7  E2B3  	DW	DIRBUF,DPB0	;DIR BUFF,PARM BLOCK
  276 E23F  E788  E757  	DW	CSV0,ALV0	;CHECK, ALLOC VECTORS
  277                   	
  278 E243  0000  0000  DPE1:	DW	XLT1,0000H	;TRANSLATE TABLE
  279 E247  0000  0000  	DW	0000H,0000H	;SCRATCH AREA
  280 E24B  E6D7  E2B3  	DW	DIRBUF,DPB1	;DIR BUFF,PARM BLOCK
  281 E24F  E7F9  E7C8  	DW	CSV1,ALV1	;CHECK, ALLOC VECTORS
  282                   	
  283 E253  0000  0000  DPE2:	DW	XLT2,0000H	;TRANSLATE TABLE
  284 E257  0000  0000  	DW	0000H,0000H	;SCRATCH AREA
  285 E25B  E6D7  E2B3  	DW	DIRBUF,DPB2	;DIR BUFF,PARM BLOCK
  286 E25F  E858  E839  	DW	CSV2,ALV2	;CHECK, ALLOC VECTORS
  287                   	
  288 E263  E2D1  0000  DPE3:	DW	XLT3,0000H	;TRANSLATE TABLE
  289 E267  0000  0000  	DW	0000H,0000H	;SCRATCH AREA
  290 E26B  E6D7  E2C2  	DW	DIRBUF,DPB3	;DIR BUFF,PARM BLOCK
  291 E26F  E887  E868  	DW	CSV3,ALV3	;CHECK, ALLOC VECTORS
  292                   	
  293 E273  0000  0000  DPE4:	DW	0000h, 0000h
  294 E277  0000  0000  	DW	0000h, 0000h
  295 E27B  E6D7  E2EB  	DW	DIRBUF, DPB4
  296 E27F  E917  E897  	DW	CSV4, ALV4
  297                   	
  298 E283  0000  0000  DPE5:	DW	0000h, 0000h
  299 E287  0000  0000  	DW	0000h, 0000h
  300 E28B  E6D7  E2EB  	DW	DIRBUF, DPB5
  301 E28F  E998  E918  	DW	CSV5, ALV5
  302                   	
  303 E293  0000  0000  DPE6:	DW	0000h, 0000h
  304 E297  0000  0000  	DW	0000h, 0000h
  305 E29B  E6D7  E2EB  	DW	DIRBUF, DPB6
  306 E29F  EA19  E999  	DW	CSV6, ALV6
  307                   	
  308 E2A3  0000  0000  DPE7:	DW	0000h, 0000h
  309 E2A7  0000  0000  	DW	0000h, 0000h
  310 E2AB  E6D7  E2EB  	DW	DIRBUF, DPB7
  311 E2AF  EA9A  EA1A  	DW	CSV7, ALV7
  312                   
  313                   	; Disk 0 (A) ---------------------------------------------------------
  314                   	
  315                   	; *** DISKDEF BEDEUTUNG DER PARAMETER***
  316                   	; 0 = NUMMER DES LAUFWERKS
  317                   	; 0 = NUMMER DES ERSTEN SEKTORS EINER SPUR
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   4
NBIOS10 Z80

  318                   	; 39 =  NUMMER DES LETZTEN SEKTORS EINER SPUR
  319                   	; 0 = OPTIONALER VERSCHIEBUNGSFAKTOR ZUM
  320                   	;     VERSETZEN ABSPEICHERN DER SEKTOREN
  321                   	; 2048 = GROESSE EINES BLOCKS
  322                   	; SIZEAB = ZAHL DER MAX. MOEGLICHEN BLOECKE
  323                   	; 256 = ZAHL DER DIRECTORY EINTRITTSPUNKTE
  324                   	; 256 = ZAHL DER GEPRUEFTEN EINTRITTSPUNKTE
  325                   	; OFFSAB = ADDITIVE KONSTANTE ZUM ANSPRECHEN DER SPUR 00
  326                   
  327                   	; physical format: 3,5 inch/5.25 inch, DD, DS, 1024 bytes/sector, 5 sectors/track, 80 tracks
  328                   	; DISKDEF 0,0,39,0,2048,SIZEAB,256,256,OFFSAB
  329         E2B3      DPB0	EQU	$		;DISK PARM BLOCK
  330 E2B3  0028        	DW	40		;SEC PER TRACK
  331 E2B5  04          	DB	4		;BLOCK SHIFT
  332 E2B6  0F          	DB	15		;BLOCK MASK
  333 E2B7  00          	DB	0		;EXTNT MASK
  334 E2B8  0184        	DW	388		;DISK SIZE-1
  335 E2BA  00FF        	DW	255		;DIRECTORY MAX
  336 E2BC  F0          	DB	240		;ALLOC0
  337 E2BD  00          	DB	0		;ALLOC1
  338 E2BE  0040        	DW	64		;CHECK SIZE
  339 E2C0  0004        	DW	4		;OFFSET
  340         0000      XLT0	EQU	0		;NO XLATE TABLE
  341                   
  342                   	; Disk 1 (B), same as Disk A -----------------------------------------
  343                   	
  344                   	; DISKDEF 1,0	; LAUFWERK 1 WIE LAUFWERK 0 DEFINIERT
  345         E2B3      DPB1	EQU	DPB0	;EQUIVALENT PARAMETERS
  346                   ;ALS1	EQU	ALS0	;SAME ALLOCATION VECTOR SIZE
  347                   ;CSS1	EQU	CSS0	;SAME CHECKSUM VECTOR SIZE
  348         0000      XLT1	EQU	XLT0	;SAME TRANSLATE TABLE
  349                   
  350                   	; Disk 2 (C), same as Disk A -----------------------------------------
  351                   
  352                   	; DISKDEF 2,0	; LAUFWERK 2 WIE LAUFWERK 0 DEFINIERT
  353         E2B3      DPB2	EQU	DPB0	;EQUIVALENT PARAMETERS
  354                   ;ALS2	EQU	ALS0	;SAME ALLOCATION VECTOR SIZE
  355                   ;CSS2	EQU	CSS0	;SAME CHECKSUM VECTOR SIZE
  356         0000      XLT2	EQU	XLT0	;SAME TRANSLATE TABLE
  357                   
  358                   	; Disk 3 (D) --------------------------------------------------------
  359                   	; physical format: 8 inch, SD, SS, 128 bytes/sector, 26 sectors/track, 77 tracks
  360                   	; DISKDEF 3,1,26,6,1024,243,64,64,2 ; 8 ZOLL DEFINITION
  361                   
  362         E2C2      DPB3	EQU	$		;DISK PARM BLOCK
  363 E2C2  001A         	DW	26		;SEC PER TRACK
  364 E2C4  03           	DB	3		;BLOCK SHIFT
  365 E2C5  07           	DB	7		;BLOCK MASK
  366 E2C6  00           	DB	0		;EXTNT MASK
  367 E2C7  00F2         	DW	242		;DISK SIZE-1
  368 E2C9  003F         	DW	63		;DIRECTORY MAX
  369 E2CB  C0           	DB	192		;ALLOC0
  370 E2CC  00           	DB	0		;ALLOC1
  371 E2CD  0010         	DW	16		;CHECK SIZE
  372 E2CF  0002         	DW	2		;OFFSET
  373                   	
  374         E2D1      XLT3	EQU	$		;TRANSLATE TABLE
  375 E2D1  01           	DB	1		
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   5
