 1327                   ;-----------------------------------------------------------------------------
 1328                   ; Calculates the pointer into PHSBUF based on sector number in IOS
 1329                   ; (PHSBUF + offset) -> DE
 1330                   ; (IOD) -> HL
 1331                   ; 128 -> BC (logical sector length)
 1332                   
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  19
NBIOS10 Z80

 1333         FFFF      	IF DG01
 1334                   
 1335         0003      SECPOW		EQU 3		; (1024 / 128) ^ 3 = 8
 1336                   ;SECPOW		EQU 2		; (1024 / 128) ^ 2 = 4
 1337                   ;SECPOW		EQU 1		; (1024 / 128) ^ 1 = 2
 1338                   ;SECPOW		EQU 0		; (1024 / 128) ^ 0 = 1
 1339                   
 1340                   ; mask for modulo (n = IOS mod mask)
 1341         0007      SECMASK		EQU 00000111B	; phys. sector = 1024, modulo 0..7
 1342                   ;SECMASK	EQU 00000011B	; phys. sector = 512, modulo 0..3
 1343                   ;SECMASK	EQU 00000001B	; phys. sector = 256, modulo 0..1
 1344                   ;SECMASK	EQU 00000000B	; phys. sector = 128, modulo 0
 1345                   
 1346 E5D5              CALCPHS:
 1347 E5D5  3A E791     	LD A,(IOS)	; logical sector number
 1348 E5D8  E6 07       	AND SECMASK
 1349 E5DA  57          	LD D,A		; load to high-byte (mul 256)
 1350 E5DB  1E 00       	LD E,0
 1351 E5DD  CB 2A       	SRA D		; div/2 by shift right
 1352 E5DF  CB 1B       	RR E
 1353                   	; now we have (IOS mod SECSIZE) * 128 in DE
 1354 E5E1  21 FC00     	LD HL,PHSBUF
 1355 E5E4  19          	ADD HL,DE	; pointer into PHSBUF in DE
 1356 E5E5  EB          	EX DE,HL
 1357 E5E6  2A E792     	LD HL,(IOD)
 1358 E5E9  01 0080     	LD BC,128
 1359 E5EC  C9          	RET
 1360                   
 1361                   	;LD HL,PHSBUF
 1362                   	;LD A,(IOS)	; PHSBUF + ((0..39) MOD 8) * 128
 1363                   	;AND 00000111b	; 0..7 (mod 8)
 1364                   	;LD D,A		; * 256 (low byte is written into the high byte)
 1365                   	;LD E,0
 1366                   	;SRA D		; div/2 by shift right
 1367                   	;RR E
 1368                   	;ADD HL,DE	; HL = source (PHSBUF+offset)
 1369                   	;EX DE,HL	; DE = source
 1370                   	;LD HL,(IOD)	; HL = dest (IOD)
 1371                   	;EX DE,HL	; DE = dest, HL = source
 1372                   	;LD BC,128	; logical sector length
 1373                   	;LDIR		; (DE++) <- (HL++), BC--
 1374                   			; (IOD) <- (PHSBUF+offset), 128 Byte
 1375                   	;XOR A
 1376                   	;RET		; -> finished without error
 1377                   
 1378                   	ENDIF
