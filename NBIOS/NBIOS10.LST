  434                   
  435         0000      	IF NOT DG01
  444                   	ELSE
  445                   
  446 E2FA  1A          	DB 26
  447 E2FB  0D 0A 43 50 	DB CR,LF,'CP/M '
  448 E302  32 2E 32    	DB CPMVERS/10+'0','.',CPMVERS MOD 10+'0'
  449 E305  20 66 6F 72 	DB ' for MC-Computer '
  450 E316  35 38       	DB MSIZE/10+'0',MSIZE MOD 10+'0'
  451 E318  4B 20 42 49 	DB 'K BIOS 260709-04 BOOT='
  452 E32E  30          	DB BTDRV+'0'
  453 E32F  0D 0A 00    	DB CR,LF,0
  454                   	
  455                   	ENDIF
