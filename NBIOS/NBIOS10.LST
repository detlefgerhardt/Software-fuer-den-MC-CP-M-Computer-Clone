 1021                   ; DBANK, IOT     C
 1022                   ;  0     F    -> 0
 1023                   ;  1     F    -> 2
 1024                   ;  0     B    -> 1
 1025                   ;  1     B    -> 3
 1026                   
 1027                   ; muss fuer Minidisk C und D erweitert werden
 1028                   
 1029                   ; calculates physical sector from logical sector, IOS -> E
 1030                   ; logical sector 0..39 -> physical sector 1..5
 1031                   
 1032                   ; calculates logical track from physical track, IOT -> D
 1033                   ; 0..159 -> 0..79 (max 127)
 1034                   
 1035 E4F4              MINCAL:
 1036                   
 1037         0000      	IF NOT DG01	; ----------
 1076                   	ELSE	; ----------
 1077                   
 1078                   	; logical sector (128 byte) to physical sector
 1079                   	
 1080         0000      	IF FALSE
 1092                   	ELSE
 1093                   	
 1094 E4F4  3A E791     	LD A,(IOS)	; 0..39 IST DER BEREICH (logic sector)
 1095                   	; hier den Maximalwert pruefen
 1096                   
 1097 E4F7  1E 03       	LD E,SECPOW
 1098 E4F9  B3          	OR E
 1099 E4FA  CA E505     	JP Z,MINIC3
 1100                   
 1101 E4FD  C5          	PUSH BC
 1102 E4FE  43          	LD B,E
 1103                   	
 1104 E4FF  0F          MINIC2:	RRCA
 1105 E500  10 FD       	DJNZ MINIC2
 1106                   
 1107 E502  C1          	POP BC
 1108                   
 1109 E503  E6 07       	AND 00000111b	; important because of rotate command
 1110                   
 1111 E505  3C          MINIC3:	INC A		; sector number starts with 1
 1112 E506  5F          	LD E,A		; save in E
 1113                   
 1114                   	ENDIF
 1115                   
 1116                   	; drive A,B,C -> 001,010,100
 1117 E507  E5          	PUSH HL
 1118 E508  3A E78D     	LD A,(DBANK)
 1119 E50B  21 E524     	LD HL,CALCTB
 1120 E50E  CD E529     	CALL LOOKUP
 1121 E511  E1          	POP HL
 1122                   
 1123 E512  4F          	LD C,A		; physical drive
 1124                   
 1125 E513  3A E790     	LD A,(IOT)
 1126 E516  0F          	RRCA		; Track / 2,  = Phys Track, carry=backside
 1127                   	;AND 7FH	; Bereich Track 0..79 real
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  16
