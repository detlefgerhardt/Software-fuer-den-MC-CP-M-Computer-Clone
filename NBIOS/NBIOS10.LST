  787                   
  788         0000      	IF NOT DG01
  799                   	ELSE
  800                   	
  801 E456  FE 08       	CP 8
  802 E458  DA E629     	JP C,IDERD	; A < 8 -> IDE disks 4,5,6,7
  803                   	
  804                   	ENDIF
