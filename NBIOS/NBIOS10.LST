  434                   
  435                   ;-----------------------------------------------------------------------------
  436                   ; CP/M message after cold start
  437                   
  438 E2FA              SIGNON:
  439                   
  440         0000      	IF NOT DG01
  449                   	ELSE
  450                   
  451 E2FA  1A          	DB 26
  452 E2FB  0D 0A 43 50 	DB CR,LF,'CP/M '
  453 E302  32 2E 32    	DB CPMVERS/10+'0','.',CPMVERS MOD 10+'0'
  454 E305  20 66 6F 72 	DB ' for MC-Computer '
  455 E316  35 38       	DB MSIZE/10+'0',MSIZE MOD 10+'0'
  456 E318  4B 20 4E 42 	DB 'K NBIOS 260711-03 BOOT='
  457 E32F  30          	DB BTDRV+'0'
  458 E330  0D 0A 00    	DB CR,LF,0
  459                   	
  460                   	ENDIF
  461                   
  462                   ;-----------------------------------------------------------------------------
  463                   ; Monitor routines and addresses
  464                   
  465 E333  C3 F012     CONST:	JP 0F012H	; DIESE ROUTINE LIEFERT DEN STATUS DER
  466                   			; EINGABETASTATUR. WURDE EIN ZEICHEN
  467                   			; EINGEGEBEN, SO LIEFERT DIE ROUTINE 0FFH. 
  468                   	
  469 E336  CD F003     CONIN:	CALL 0F003H	; DIE ROUTINE HOLT EIN ZEICHEN VON DER
  470                   			; TASTATUR AB UND SETZT DAS HOECHSTE BIT
  471                   			; (PARITY BIT) AUF NULL
  472 E339  E6 7F       	AND 7FH
  473 E33B  C9          	RET
  474                   
  475         F01E      MON80	EQU 0F01EH	; Neustart des Monitors
  476                   
  477         F009      CONOUT	EQU 0F009H	; ROUTINE ZUR AUSGABE EINES ZEICHENS IM
  478                   			; C-REGISTER AN DIE KONSOLE. DAZU SPRUNG 
  479                   			; IN DEN MONITOR IM EPROM
  480                   
  481         F00F      LIST	EQU 0F00FH	; ADRESSE FUER DEN SPRUNG IN DIE AUSGABEROUTINE,
  482                   			; UM EIN ZEICHEN IM C-REGISTER AN DIE DRUCKER-
  483                   			; SCHNITTSTELLE ZU LIEFERN
  484                   
  485         F00C      PUNCH	EQU 0F00CH	; ADRESSE FUER DEN SPRUNG IN DIE AUSGABEROUTINE,
  486                   			; UM EIN ZEICHEN IM C-REGISTER AN DIE STANZ-
  487                   			; SCHNITTSTELLE ZU LIEFERN
  488                   
  489         F006      READER	EQU 0F006H	; ADRESSE FUER DEN SPRUNG IN DIE EINGABEROUTINE,
  490                   			; UM EIN ZEICHEN VON LESER-KANAL ZU HOLEN,
  491                   			; UND DAS ZEICHEN IM A-REGISTER ABZULIEFERN (RI)	
  492                   
  493                   ;-----------------------------------------------------------------------------
  494                   ; Cold boot
  495                   
  496 E33C  31 0100     BOOT:	LD SP,BUFF+80H	; output start message
  497 E33F  21 E2FA     	LD HL,SIGNON
  498 E342  CD E44A     	CALL PRMSG
  499                   	
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   7
NBIOS10 Z80

  500                   	; clear / set last used drive
  501         0000      	IF NOT MINI3
  503                   	ELSE
  504 E345  3E 00       	LD A,BTDRV
  505                   	ENDIF
  506 E347  32 0004     	LD (CDISK),A
  507                   	
  508                   	; sector buffer is empty, set to physical sector buffer not changed
  509 E34A  AF          	XOR A
  510 E34B  32 E6C9     	LD (BUFCHG),A
  511                   	
  512                   	; drive is undefined
  513 E34E  3E FF       	LD A,0FFH
  514 E350  32 E6CA     	LD (CURDRV),A
  515                   
  516                   	; disable monitor entries, set to WBOOT
  517 E353  21 E362     	LD HL,WBOOT
  518 E356  22 F034     	LD (0F033H+1),HL
  519 E359  22 F037     	LD (0F036H+1),HL
  520                   	
  521         FFFF      	IF DG01
  522                   	; patch BDOS avtive drive
  523 E35C  CD E693     	CALL PATA
  524                   	;CALL PATB
  525                   	ENDIF
  526                   	
  527 E35F  C3 E3BB     	JP GOCPM	; start CP/M
  528                   
  529                   ;-----------------------------------------------------------------------------
  530                   ; Warm boot
  531                   
  532 E362              WBOOT:	; write physical sector buffer to disk if changed
  533 E362  3A E6C9     	LD A,(BUFCHG)
  534 E365  B7          	OR A
  535 E366  CA E36C     	JP Z,WBOO1
  536                   
  537                   	;IF NOT MINI3
  538                   	
  539 E369  CD E61A     	CALL PUTPHS	; normalerweise ist Schreibvorgang
  540                   			; nach einem Direktoryzugriff abgeschlossen
  541                   			; ACHTUNG BUG!? PUTPHS nur fuer Mini/DD-Laufwerke
  542                   			; Bei einem anderen Laufwerk geht das wohl schief
  543                   			
  544                   	;ENDIF
  545                   			
  546 E36C  3E FF       WBOO1:	LD A,0FFH	; alle Tracks ungueltig, bei Diskettenwechsel wichtig
  547 E36E  32 E6CA     	LD (CURDRV),A
  548                   
  549 E371  31 0080     	LD SP,BUFF	; Stack zuweisen
  550 E374  0E 05       	LD C,RETRY	; Anzahl der Versuche
  551 E376  C5          	PUSH BC		; und dann anfangen zu booten
  552                   
  553 E377              WBOO2:	; loop, load CP/M
  554                   	; hier ist noch das Format des Boot-Laufwerks hardkodiert !!!
  555 E377  01 CC00     	LD BC,CPMB	; Boot von MINI-Diskette / Boot drive
  556 E37A  CD E444     	CALL SETDMA	; auf der Startadresse des CP/Ms
  557 E37D  0E 00       	LD C,BTDRV	; Laufwerk A (or BTDRV)
  558 E37F  CD E40D     	CALL SELDSK	; auswaehlen
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   8
NBIOS10 Z80

  559 E382  0E 00       	LD C,0		; Track 0
  560 E384  CD E423     	CALL SETTRK	; und den zweiten phys. Sektor, (Nr 8 logisch)
  561 E387  0E 08       	LD C,8		; entspricht Nr 2 bei 1024 Bytes
  562 E389  CD E428     	CALL SETSEC	; wichtig, da andere Zaehlweise
  563 E38C  C1          	POP BC		; und von da an n Sektoren einlesen
  564 E38D  06 2C       	LD B,NSECTS	; aber das BIOS nicht ueberschreiben
  565                   			; damit Patches leicht moeglich sind
  566                   
  567                   	;LD C,'*'
  568                   	;CALL MCONOUT
  569                   
  570 E38F              WBOO3:	; sector read loop
  571 E38F  C5          	PUSH BC		; Anzahl merken
  572 E390  CD E457     	CALL READ	; LESEN ausfuehren
  573 E393  C2 E3ED     	JP NZ,BOOTERR	; Fehler: defekter Sektor
  574                   	
  575 E396  2A E6D5     	LD HL,(IOD)	; Zieladresse laden
  576 E399  11 0080     	LD DE,128	; um logische Sektorgroesser erhoehen
  577 E39C  19          	ADD HL,DE	; dazu addieren,
  578 E39D  22 E6D5     	LD (IOD),HL	; und dann wieder zurueckspeichern.
  579 E3A0  3A E6D4     	LD A,(IOS)	; Sektor laden
  580 E3A3  FE 27       	CP 39		; Mini 0..39 Sektoren a 128 Bytes
  581                   			; Anzahl der Sektoren hardcodiert !!!
  582 E3A5  DA E3B2     	JP C,WBOO4	; solange auf der gleichen Spur bleiben
  583                   
  584                   	; next track, Spurzuordnung hardcodert !!!
  585 E3A8  3A E6D3     	LD A,(IOT)	; Dann neue Spur anwaehlen,
  586 E3AB  3C          	INC A	  	; jedoch im Verfahren 0,2,...
