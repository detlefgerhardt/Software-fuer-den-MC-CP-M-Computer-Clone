 1487                   
 1488                   ; Read one sector from disk.
 1489                   ; Return a 00h in A if the operation completes properly, and 01h if an error occurs during the read.
 1490                   ; Disk number in 'diskno' (4..7)
 1491                   ; Track number in 'track' (0..255)
 1492                   ; Sector number in 'sector' (0..63)
 1493                   ; DMA address in 'dmaad' (0-65535)
 1494                   ; 
 1495                   ; LBA
 1496                   ; 00000000 00000000 00000000
 1497                   ; 00000000 tttttttt ssssssdd
 1498                   ;        E        B        C
 1499                   
 1500         FC00      HSTBUF	EQU PHSBUF	; buffer for phyiscal sector
 1501         E6D0      DISKNO	EQU DBANK
 1502         E6D3      TRACK	EQU IOT
