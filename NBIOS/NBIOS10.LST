  457                   ;-----------------------------------------------------------------------------
  458                   ; Monitor routines and addresses
  459                   
  460 E332  C3 F012     CONST:	JP 0F012H	; DIESE ROUTINE LIEFERT DEN STATUS DER
  461                   			; EINGABETASTATUR. WURDE EIN ZEICHEN
  462                   			; EINGEGEBEN, SO LIEFERT DIE ROUTINE 0FFH. 
  463                   	
  464 E335  CD F003     CONIN:	CALL 0F003H	; DIE ROUTINE HOLT EIN ZEICHEN VON DER
  465                   			; TASTATUR AB UND SETZT DAS HOECHSTE BIT
  466                   			; (PARITY BIT) AUF NULL
  467 E338  E6 7F       	AND 7FH
  468 E33A  C9          	RET
  469                   
  470         F01E      MON80	EQU 0F01EH	; Neustart des Monitors
  471                   
  472         F009      CONOUT	EQU 0F009H	; ROUTINE ZUR AUSGABE EINES ZEICHENS IM
  473                   			; C-REGISTER AN DIE KONSOLE. DAZU SPRUNG 
  474                   			; IN DEN MONITOR IM EPROM
  475                   
  476         F00F      LIST	EQU 0F00FH	; ADRESSE FUER DEN SPRUNG IN DIE AUSGABEROUTINE,
  477                   			; UM EIN ZEICHEN IM C-REGISTER AN DIE DRUCKER-
  478                   			; SCHNITTSTELLE ZU LIEFERN
  479                   
  480         F00C      PUNCH	EQU 0F00CH	; ADRESSE FUER DEN SPRUNG IN DIE AUSGABEROUTINE,
  481                   			; UM EIN ZEICHEN IM C-REGISTER AN DIE STANZ-
  482                   			; SCHNITTSTELLE ZU LIEFERN
  483                   
  484         F006      READER	EQU 0F006H	; ADRESSE FUER DEN SPRUNG IN DIE EINGABEROUTINE,
  485                   			; UM EIN ZEICHEN VON LESER-KANAL ZU HOLEN,
  486                   			; UND DAS ZEICHEN IM A-REGISTER ABZULIEFERN (RI)	
  487                   
  488                   ;-----------------------------------------------------------------------------
  489                   ; Cold boot
  490                   
  491 E33B  31 0100     BOOT:	LD SP,BUFF+80H	; output start message
  492 E33E  21 E2FA     	LD HL,SIGNON
  493 E341  CD E448     	CALL PRMSG
  494                   	
  495                   	; clear / set last used drive
  496 E344  3E 00       	LD A,BTDRV
  497 E346  32 0004     	LD (CDISK),A
  498                   	
  499                   	; sector buffer is empty, set to physical sector buffer not changed
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   7
NBIOS10 Z80

  500 E349  AF          	XOR A
  501 E34A  32 E792     	LD (BUFCHG),A
  502                   	
  503                   	; drive is undefined
  504 E34D  3E FF       	LD A,0FFH
  505 E34F  32 E793     	LD (CURDRV),A
  506                   
  507                   	; disable monitor entries, set to WBOOT
  508 E352  21 E35E     	LD HL,WBOOT
  509 E355  22 F034     	LD (0F033H+1),HL
  510 E358  22 F037     	LD (0F036H+1),HL
  511                   	
  512         FFFF      	IF DG01
  513                   	; patch BDOS avtive drive
  514                   	;CALL PATA
  515                   	;CALL PATB
  516                   	ENDIF
  517                   	
  518 E35B  C3 E3B9     	JP GOCPM	; start CP/M
  519                   
  520                   ;-----------------------------------------------------------------------------
  521                   ; Warm boot
  522                   
  523 E35E              WBOOT:	; write physical sector buffer to disk if changed
  524 E35E  3A E792     	LD A,(BUFCHG)
  525 E361  B7          	OR A
  526 E362  CA E365     	JP Z,WBOO1
  527                   
  528         0000      	IF NOT MINI3
  535                   	ENDIF
  536                   			
  537 E365  3E FF       WBOO1:	LD A,0FFH	; alle Tracks ungueltig, bei Diskettenwechsel wichtig
  538 E367  32 E793     	LD (CURDRV),A
  539                   
  540 E36A  31 0080     	LD SP,BUFF	; Stack zuweisen
  541 E36D  0E 05       	LD C,RETRY	; Anzahl der Versuche
  542 E36F  C5          	PUSH BC		; und dann anfangen zu booten
  543                   
  544 E370              WBOO2:	; loop, load CP/M
  545                   	; hier ist noch das Format des Boot-Laufwerks hardkodiert !!!
  546 E370  01 CC00     	LD BC,CPMB	; Boot von MINI-Diskette / Boot drive
  547 E373  CD E442     	CALL SETDMA	; auf der Startadresse des CP/Ms
  548 E376  0E 00       	LD C,BTDRV	; Laufwerk A (or BTDRV)
  549 E378  CD E40B     	CALL SELDSK	; auswaehlen
  550 E37B  0E 00       	LD C,0		; Track 0
  551 E37D  CD E421     	CALL SETTRK	; und den zweiten phys. Sektor, (Nr 8 logisch)
  552 E380  0E 08       	LD C,8		; entspricht Nr 2 bei 1024 Bytes
  553 E382  CD E426     	CALL SETSEC	; wichtig, da andere Zaehlweise
  554 E385  C1          	POP BC		; und von da an n Sektoren einlesen
  555 E386  06 2C       	LD B,NSECTS	; aber das BIOS nicht ueberschreiben
  556                   			; damit Patches leicht moeglich sind
  557                   
  558 E388  0E 2A       	LD C,'*'
  559 E38A  CD F009     	CALL MCONOUT
  560                   
  561 E38D              WBOO3:	; sector read loop
  562 E38D  C5          	PUSH BC		; Anzahl merken
  563 E38E  CD E455     	CALL READ	; LESEN ausfuehren
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   8
NBIOS10 Z80

  564 E391  C2 E3EB     	JP NZ,BOOTERR	; Fehler: defekter Sektor
  565                   	
  566 E394  2A E79E     	LD HL,(IOD)	; Zieladresse laden
  567 E397  11 0080     	LD DE,128	; um logische Sektorgroesser erhoehen
  568 E39A  19          	ADD HL,DE	; dazu addieren,
  569 E39B  22 E79E     	LD (IOD),HL	; und dann wieder zurueckspeichern.
  570 E39E  3A E79D     	LD A,(IOS)	; Sektor laden
  571 E3A1  FE 27       	CP 39		; Mini 0..39 Sektoren a 128 Bytes
  572                   			; Anzahl der Sektoren hardcodiert !!!
  573 E3A3  DA E3B0     	JP C,WBOO4	; solange auf der gleichen Spur bleiben
  574                   
  575                   	; next track, Spurzuordnung hardcodert !!!
  576 E3A6  3A E79C     	LD A,(IOT)	; Dann neue Spur anwaehlen,
  577 E3A9  3C          	INC A	  	; jedoch im Verfahren 0,2,...
  578 E3AA  3C          	INC A		; SPUR 0, dann SPUR 2, wegen BOOT.ASM
  579 E3AB  32 E79C     	LD (IOT),A	; denn 1,3,5 ist die Rueckseite des Laufwerks
  580 E3AE  3E FF       	LD A,0FFH	; 0,1,2,3.... nach Increment A=0
  581                   	
  582 E3B0  3C          WBOO4:	INC A		; dann 0
  583 E3B1  32 E79D     	LD (IOS),A	; und auch neuesn Sektor anwaehlen
  584 E3B4  C1          	POP BC		; Schleifenzaehler zuruech
  585 E3B5  05          	DEC B		; und immer weiter lesen
  586 E3B6  C2 E38D     	JP NZ,WBOO3	; -> read next sector
  587                   	
  588                   	;---------------------------------------------------------------------
  589                   
  590 E3B9  01 0080     GOCPM:	LD BC,BUFF	; Buffer auf Default einstellen
  591 E3BC  CD E442     	CALL SETDMA	; so wie es CP/M braucht
