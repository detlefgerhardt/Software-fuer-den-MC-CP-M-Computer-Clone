  744                   ;=============================================================================
  745                   ; Read and write sector using FEXEC into monitor
  746                   
  747                   ;-----------------------------------------------------------------------------
  748                   ; Read sector
  749                   
  750                   ; Buffer (DMA address) in IOD
  751                   ; Drive in DBANK (0..n-1)
  752                   ; Track in IOT (0..n-1)
  753                   ; Sector in IOS (0..n-1)
  754                   
  755 E455              READ:
  756         0000      	IF NOT DG01
  765                   	ELSE
  766                   
  767                   	;POP HL
  768                   	;PUSH HL
  769                   	;CALL DEBDRV	; debug output (DBANK)
  770                   
  771 E455  3A E799     	LD A,(DBANK)	; drive 0..5
  772 E458  FE 03       	CP 3
  773 E45A  DA E53D     	JP C,MINIRD	; A < 3 -> drive 0,1,2 (Mini disks)
  774                   	
  775 E45D  FE 04       	CP 4
  776 E45F  DA E4AB     	JP C,MAXIRD	; A < 4 -> drive 3 (Maxi disks)
  777                   	
  778                   	ENDIF
  779                   
  780                   	;---------------------------------------------------------------------
  781                   	; A >= 5, Read RAM disk
  782                   
  783         0000      	IF NOT DG01
  794                   	ELSE
  795                   	
  796 E462  FE 08       	CP 8
  797 E464  DA E635     	JP C,IDERD	; A < 8 -> IDE disks 4,5,6,7
  798                   	
  799                   	ENDIF
  800                   	
  801                   	; error
  802 E467  3E 01       	LD A,1		; Fehler da, Bank nicht vorhanden,
  803 E469  C9          	RET		; wirkt wie BAD-Sektor
  804                   
  805                   	;---------------------------------------------------------------------
  806                   	
  807 E46A  AF          NOERR:	XOR A		; sonst ok.
  808 E46B  C9          	RET
  809                   
