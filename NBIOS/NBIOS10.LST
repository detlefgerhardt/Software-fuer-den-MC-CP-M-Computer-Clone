 1021                   
 1022                   ; muss fuer Minidisk C und D erweitert werden
 1023                   
 1024                   ; calculates physical sector from logical sector, IOS -> E
 1025                   ; logical sector 0..39 -> physical sector 1..5
 1026                   
 1027                   ; calculates logical track from physical track, IOT -> D
 1028                   ; 0..159 -> 0..79 (max 127)
 1029                   
 1030 E500              MINCAL:
 1031                   
 1032         0000      	IF NOT DG01	; ----------
 1071                   	ELSE	; ----------
 1072                   
 1073                   	; logical sector (128 byte) to physical sector
 1074                   	
 1075         0000      	IF FALSE
 1087                   	ELSE
 1088                   	
 1089 E500  3A E79D     	LD A,(IOS)	; 0..39 IST DER BEREICH (logic sector)
 1090                   	; hier den Maximalwert pruefen
 1091                   
 1092 E503  1E 03       	LD E,SECPOW
 1093 E505  B3          	OR E
 1094 E506  CA E511     	JP Z,MINIC3
 1095                   
 1096 E509  C5          	PUSH BC
 1097 E50A  43          	LD B,E
 1098                   	
 1099 E50B  0F          MINIC2:	RRCA
 1100 E50C  10 FD       	DJNZ MINIC2
