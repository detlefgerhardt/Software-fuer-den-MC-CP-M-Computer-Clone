 1123 E519  21 E532     	LD HL,CALCTB
 1124 E51C  CD E537     	CALL LOOKUP
 1125 E51F  E1          	POP HL
 1126                   
 1127 E520  4F          	LD C,A		; physical drive
 1128                   
 1129 E521  3A E6D3     	LD A,(IOT)
 1130 E524  0F          	RRCA		; Track / 2,  = Phys Track, carry=backside
 1131                   	;AND 7FH	; Bereich Track 0..79 real
 1132 E525  57          	LD D,A		; Track merken
 1133 E526  D2 E52D     	JP NC,MINC4	; -> side 0
