    1                   	;MACLIB DISKDEF1	; LOAD DEFINTION FOR DISKS
    2                   
    3                   ;*****************************************************************************
    4                   ; Version 1.0   Version 80 Spur-Laufwerk                                     *
    5                   ; gebootet wird vom 80 Spur-Laufwerk                                         *
    6                   ; basiert auf der Version 3.1 1984 Rolf-Dieter Klein 841220                  *
    7                   ; ****************************************************************************
    8                   ;
    9                   ; 24.06.2026 *dg* Kommentare hinzugefuegt
   10                   ;                 Binaer identisch zur Origial-Version
   11                   ; 06.07.2026 *dg* Erste Aenderungen am BIOS. Alte Monnitor-Routinen werden
   12                   ;                 nich mehr verwendet. Laufwerksumrechnung gedndert.
   13                   ;                 Version getestet.
   14                   ;                 Alle Aenderungen mit bedingter Assemblierung (Flag MINI3)
   15                   ;                 Testweise den Speicherbereich fuer das BIOS auf E200..EFFF
   16                   ;		  geaendert. CP/M startet dann bei CC00 (58K)
   17                   ; 09.07.2026 *dg* Erweitert um 4 IDE/CF-Laufwerke - funktioniert nicht
   18                   ;                 System bootet aber Schreiben auf die IDE-Laufwerke schldgt fehl.
   19                   
   20         0016      CPMVERS	EQU 22		; CP/M version
   21         0000      FALSE	EQU 0
   22         FFFF      TRUE	EQU NOT FALSE
   23         FFFF      TEST	EQU TRUE
   24         000D      CR	EQU 0DH		; carriage return
   25         000A      LF	EQU 0AH		; line feed
   26                   
   27                   ;------------------------------------------------------------------------------
   28                   ; Variant switches
   29                   
   30                   ; aktiviert alle bisherigen Aenderungen gegenueber der Originalversion 3.1
   31         FFFF      DG01	EQU TRUE
   32                   
   33                   ; aendert die Laufwerksdefinition:
   34                   ; 3 Mini drives
   35                   ; A = Mini drive 0
   36                   ; B = Mini drive 1
   37                   ; C = Mini drive 2
   38                   ; D = Maxi drive 3 Side 0
   39                   ; E = Maxi drive 3 Side 1
   40                   ; F = RAM disk
   41         FFFF      MINI3	EQU TRUE
   42                   
   43                   ; logical drive to boot from
   44         0000      	IF NOT MINI3
   46                   	ELSE
   47                   ;BTDRV	EQU 4		; drive E: (CF)
   48         0000      BTDRV	EQU 0		; drive A:
   49                   	ENDIF
   50                   
   51                   ;------------------------------------------------------------------------------
   52                   ; Monitor functions
   53                   
   54         FFFF      	IF DG01
   55                   
   56         F009      MCONOUT	EQU 0F009h	; character in C
   57                   
   58                   	ENDIF
   59                   
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   2
NBIOS10 Z80

   60                   ;------------------------------------------------------------------------------
   61                   
   62                   ;MSIZE 	EQU 60		; Speichergroesse, hier 60K
   63         003A      MSIZE 	EQU 58		; Speichergroesse, hier 58K
   64                   
   65         9800      BIAS	EQU (MSIZE-20)*1024	; min=20K
   66         CC00      CCP	EQU 3400H+BIAS	; Start des CCP
   67         D406      BDOS	EQU CCP+806H	; dort beginnt das BDOS
   68         E200      BIOS	EQU CCP+1600H	; und dort das BIOS
   69                   
   70         CC00      CPMB	EQU CCP		; Start CP/M-Boot
   71                   
   72         1600      CPML	EQU BIOS-CPMB	; Laenge des CP/Ms
   73         002C      NSECTS	EQU CPML/128	; Anzahl der von CP/M belegten Sektoren
   74                   
   75                   
   76         E200      	ORG BIOS	; regular start of BIOS
   77                   	;ORG BIOS-4000H	; for debugging
   78                   
   79                   
   80         0004      CDISK	EQU 0004H	; address for last used drive
   81         0080      BUFF	EQU 0080H	; buffer address
   82         0005      RETRY	EQU 5		; Fehlerversuche bei BOOT und Maxi Read/Write
   83                   
   84                   ;-----------------------------------------------------------------------------
   85                   
   86                   ; VEKTORTABELLE der BIOS-Einspruenge
   87                   
   88 E200  C3 E33B     	JP BOOT	; Kalt-Start
   89                   	
   90 E203  C3 E35E     WBOOTE:	JP WBOOT	; Warm-Start, bei CTRL-C
   91 E206  C3 E332     	JP CONST	; Consol Status, Ergebnis in A
   92 E209  C3 E335     	JP CONIN	; Consol Eingabe, nach A	
   93 E20C  C3 F009     	JP CONOUT	; Consol Ausgabe von C
   94 E20F  C3 F00F     	JP LIST		; Ausgabe auf den Drucker, von C
   95 E212  C3 F00C     	JP PUNCH	; Ausgabe auf PO, C-Register
   96 E215  C3 F006     	JP READER	; Eingabe nach RI, A-Register
   97                   
   98 E218  C3 E406     	JP HOME		; Laufwerk nur Track 0
   99 E21B  C3 E40B     	JP SELDSK	; Select drive, returns disk parameter header block in HL
  100 E21E  C3 E421     	JP SETTRK	; Spur auswaehlen
  101 E221  C3 E426     	JP SETSEC	; Sektor auswaehlen
  102 E224  C3 E442     	JP SETDMA	; Adresse festlegen                     
  103 E227  C3 E455     	JP READ		; Sektor lesen
  104 E22A  C3 E4CB     	JP WRITE	; Sektor schreiben
  105 E22D  C3 E403     	JP LISTST	; Drucker fertig ?
  106 E230  C3 E42B     	JP SECTRAN	; sector translation (skew only)
  107                   
