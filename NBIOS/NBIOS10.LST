Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   1
NBIOS10 Z80

    1                   ;*****************************************************************************
    2                   ; NBIOS.Z80								     *
    3                   ; basiert auf der Version 3.1 1984 Rolf-Dieter Klein 841220                  *
    4                   ; Version fuer 2 Mini und 2 Maxi Laufwerke				     *
    5                   ; ****************************************************************************
    6                   ;
    7                   ; PLEASE NOTE THE CHANGED BIOS START ADDRESS !!!
    8                   ;
    9                   ; 24.06.2026 *dg* Kommentare hinzugefuegt
   10                   ;                 Binaer identisch zur Origial-Version
   11                   ; 06.07.2026 *dg* Erste Aenderungen am BIOS. Alte Monnitor-Routinen werden
   12                   ;                 nich mehr verwendet. Laufwerksumrechnung gedndert.
   13                   ;                 Version getestet.
   14                   ;                 Alle Aenderungen mit bedingter Assemblierung (Flag MINI3)
   15                   ;                 Testweise den Speicherbereich fuer das BIOS auf E200..EFFF
   16                   ;		  geaendert. CP/M startet dann bei CC00 (58K)
   17                   ; 09.07.2026 *dg* Erweitert um 4 IDE/CF-Laufwerke - funktioniert nicht
   18                   ;                 System bootet aber Schreiben auf die IDE-Laufwerke schldgt fehl.
   19                   
   20                   ;------------------------------------------------------------------------------
   21                   
   22                   	;MACLIB DISKDEF1	; LOAD DEFINTION FOR DISKS
   23                   
   24         0016      CPMVERS	EQU 22		; CP/M version
   25         0000      FALSE	EQU 0
   26         FFFF      TRUE	EQU NOT FALSE
   27         FFFF      TEST	EQU TRUE
   28         000D      CR	EQU 0DH		; carriage return
   29         000A      LF	EQU 0AH		; line feed
   30                   
   31                   ;------------------------------------------------------------------------------
   32                   ; Variant switches
   33                   
   34                   ; aktiviert alle bisherigen Aenderungen gegenueber der Originalversion 3.1
   35         FFFF      DG01	EQU TRUE
   36                   
   37                   ; aendert die Laufwerksdefinition:
   38                   ; 3 Mini drives
   39                   ; A = Mini drive 0
   40                   ; B = Mini drive 1
   41                   ; C = Mini drive 2
   42                   ; D = Maxi drive 3 Side 0
   43                   ; E = Maxi drive 3 Side 1
   44                   ; F = RAM disk
   45         FFFF      MINI3	EQU TRUE
   46                   
   47                   ; logical drive to boot from
   48         0000      	IF NOT MINI3
   50                   	ELSE
   51                   ;BTDRV	EQU 4		; drive E: (CF)
   52         0000      BTDRV	EQU 0		; drive A:
   53                   	ENDIF
   54                   
   55                   ;------------------------------------------------------------------------------
   56                   ; Monitor functions
   57                   
   58         FFFF      	IF DG01
   59                   
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   2
NBIOS10 Z80

   60         F009      MCONOUT	EQU 0F009h	; character in C
   61                   
   62                   	ENDIF
   63                   
   64                   ;------------------------------------------------------------------------------
   65                   
   66                   ;MSIZE 	EQU 60		; Speichergroesse, hier 60K
   67         003A      MSIZE 	EQU 58		; Speichergroesse, hier 58K
   68                   
   69         9800      BIAS	EQU (MSIZE-20)*1024	; min=20K
   70         CC00      CCP	EQU 3400H+BIAS	; Start des CCP
   71         D406      BDOS	EQU CCP+806H	; dort beginnt das BDOS
   72         E200      BIOS	EQU CCP+1600H	; und dort das BIOS
   73                   
   74         CC00      CPMB	EQU CCP		; Start CP/M-Boot
   75                   
   76         1600      CPML	EQU BIOS-CPMB	; Laenge des CP/Ms
   77         002C      NSECTS	EQU CPML/128	; Anzahl der von CP/M belegten Sektoren
   78                   
   79                   
   80         0004      CDISK	EQU 0004H	; address for last used drive
   81         0080      BUFF	EQU 0080H	; buffer address
   82         0005      RETRY	EQU 5		; Fehlerversuche bei BOOT und Maxi Read/Write
   83                   
   84                   ;-----------------------------------------------------------------------------
   85                   
   86         E200      	ORG BIOS	; regular start of BIOS
   87                   	;ORG BIOS-4000H	; for debugging
   88                   
   89                   ; VEKTORTABELLE der BIOS-Einspruenge
   90                   
   91 E200              STARTBIOS:
   92                   
   93 E200  C3 E33C     	JP BOOT	; Kalt-Start
   94                   	
   95 E203  C3 E362     WBOOTE:	JP WBOOT	; Warm-Start, bei CTRL-C
   96 E206  C3 E333     	JP CONST	; Consol Status, Ergebnis in A
   97 E209  C3 E336     	JP CONIN	; Consol Eingabe, nach A	
   98 E20C  C3 F009     	JP CONOUT	; Consol Ausgabe von C
   99 E20F  C3 F00F     	JP LIST		; Ausgabe auf den Drucker, von C
  100 E212  C3 F00C     	JP PUNCH	; Ausgabe auf PO, C-Register
  101 E215  C3 F006     	JP READER	; Eingabe nach RI, A-Register
  102                   
  103 E218  C3 E408     	JP HOME		; Laufwerk nur Track 0
  104 E21B  C3 E40D     	JP SELDSK	; Select drive, returns disk parameter header block in HL
  105 E21E  C3 E423     	JP SETTRK	; Spur auswaehlen
  106 E221  C3 E428     	JP SETSEC	; Sektor auswaehlen
  107 E224  C3 E444     	JP SETDMA	; Adresse festlegen                     
  108 E227  C3 E457     	JP READ		; Sektor lesen
  109 E22A  C3 E4CD     	JP WRITE	; Sektor schreiben
  110 E22D  C3 E405     	JP LISTST	; Drucker fertig ?
  111 E230  C3 E42D     	JP SECTRAN	; sector translation (skew only)
  112                   
  113                   ;-----------------------------------------------------------------------------
  114                   
  115         0000      	IF NOT MINI3
  258                   	ELSE	; ------------------------------------------------------------
  259                   
