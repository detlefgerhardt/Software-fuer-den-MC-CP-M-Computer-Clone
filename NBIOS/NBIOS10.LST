  376 E2D2  07           	DB	7		
  377 E2D3  0D           	DB	13		
  378 E2D4  13           	DB	19		
  379 E2D5  19           	DB	25		
  380 E2D6  05           	DB	5		
  381 E2D7  0B           	DB	11		
  382 E2D8  11           	DB	17		
  383 E2D9  17           	DB	23		
  384 E2DA  03           	DB	3		
  385 E2DB  09           	DB	9		
  386 E2DC  0F           	DB	15		
  387 E2DD  15           	DB	21		
  388 E2DE  02           	DB	2		
  389 E2DF  08           	DB	8		
  390 E2E0  0E           	DB	14		
  391 E2E1  14           	DB	20		
  392 E2E2  1A            	DB	26		
  393 E2E3  06           	DB	6		
  394 E2E4  0C           	DB	12		
  395 E2E5  12           	DB	18		
  396 E2E6  18           	DB	24		
  397 E2E7  04           	DB	4		
  398 E2E8  0A           	DB	10		
  399 E2E9  10           	DB	16		
  400 E2EA  16           	DB	22	
  401                   
  402                   	; Disk 4 (E), IDE partition 0 ----------------------------------------
  403                   	; 64-sector tracks, numbering starting at zero (sectors 0 to 63)
  404                   	; Block size 2048
  405                   	; Disk size 2 mb, DSM 1023, yields 256 tracks (0 to 255)
  406 E2EB              DPB4:	;disk parameter block for all disks.
  407 E2EB  0040        	DW	64		;sectors per track
  408 E2ED  04          	DB	4		;block shift factor
  409 E2EE  0F          	DB	15		;block mask - with block shift, sets block size to 1024
  410 E2EF  00          	DB	0		;null mask
  411 E2F0  03FF        	DW	1023		;disk size-1 = number of blocks in a disk - 1
  412 E2F2  0100        	DW	256		;directory max = no. directory entries/disk, arbitrary
  413 E2F4  F0          	DB	240		;alloc 0 -- need 4 bits (blocks) for 256 directory entries -- 
  414 E2F5  00          	DB	0		;alloc 1 -- no. bits = (directory max x 32)/block size	
  415 E2F6  0000        	DW	0		;check size -- no checking, so zero
  416 E2F8  0001        	DW	1		;track offset -- first track for system
  417                   
  418                   	; Disk 5 (F), IDE partition 1 ----------------------------------------
  419         E2EB      DPB5	EQU	DPB4	;EQUIVALENT PARAMETERS
  420                   ;ALS3	EQU	ALS2	;SAME ALLOCATION VECTOR SIZE
  421                   ;CSS3	EQU	CSS2	;SAME CHECKSUM VECTOR SIZE
  422                   
  423                   	; Disk 6 (G), IDE partition 2 ----------------------------------------
  424         E2EB      DPB6	EQU	DPB4	;EQUIVALENT PARAMETERS
  425                   ;ALS3	EQU	ALS2	;SAME ALLOCATION VECTOR SIZE
  426                   ;CSS3	EQU	CSS2	;SAME CHECKSUM VECTOR SIZE
  427                   
  428                   	; Disk 7 (H), IDE partition 3 ----------------------------------------
  429         E2EB      DPB7	EQU	DPB4	;EQUIVALENT PARAMETERS
  430                   ;ALS3	EQU	ALS2	;SAME ALLOCATION VECTOR SIZE
  431                   ;CSS3	EQU	CSS2	;SAME CHECKSUM VECTOR SIZE
  432                   
  433                   	ENDIF	; MINI3
