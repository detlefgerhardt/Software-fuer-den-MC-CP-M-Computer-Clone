  109                   
  110         0000      	IF NOT MINI3
  253                   	ELSE	; ------------------------------------------------------------
  254                   
  255                   	; size of mini disks A, B, C
  256                   	; TRUNC(5 logical sectors * 1024 logical sector size * (2*80 tracks - 4 offset) / 2048 block size) - 1 = ca. 780 KB
  257                   	; TRUNC (5 * 1024 * (160-4)/2048) - 1 = ca. 780 K
  258         0185      SIZEAB	EQU 389
  259                   
