  694 E429  71          	LD (HL),C
  695 E42A  C9          	RET
  696                   
  697                   ;-----------------------------------------------------------------------------
  698                   ; Sector translation (used by BDOS)
  699                   ; sector in C
  700                   ; skew table in DE (or 0)
  701                   
  702 E42B  7A          SECTRAN:LD A,D		; wenn ein SKEW-Faktor verwendet wird,
  703 E42C  B3                  OR E		; wie z.B. bei 8 Zoll ueblich.
  704 E42D  CA E43A             JP Z,SECTR1	; =0, -> no skew
  705                   
  706 E430  06 00       	LD B,0		; sonst in DE Adresse der Skew-Tabelle
  707 E432  EB          	EX DE,HL	; skew table -> HL
  708 E433  09          	ADD HL,BC	; add BC
  709 E434  7E          	LD A,(HL)	; load skew value
  710 E435  32 E79D     	LD (IOS),A	; save in IOS 
  711 E438  6F          	LD L,A		; and in L
  712 E439  C9          	RET
  713                   
  714 E43A              SECTR1:	; no skew
  715 E43A  69          	LD L,C		; sonst nur einfache Wert
  716 E43B  79                  LD A,C		; uebernehmen, ohne Umrechnung.
  717 E43C  32 E79D             LD (IOS),A	; auch merken
  718 E43F  26 00               LD H,0		; se 0..255 max
  719 E441  C9                  RET
  720                   
