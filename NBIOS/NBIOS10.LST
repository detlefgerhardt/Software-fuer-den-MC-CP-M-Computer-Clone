 1149                   ; Lookup table, table in HL, offset in A
 1150                   
 1151         FFFF      	IF DG01
 1152                   
 1153 E535  D5          LOOKUP:	PUSH DE
 1154 E536  5F          	LD E,A
 1155 E537  16 00       	LD D,0
 1156 E539  19          	ADD HL,DE
 1157 E53A  7E          	LD A,(HL)
 1158 E53B  D1          	POP DE
 1159 E53C  C9          	RET
 1160                   	
 1161                   	ENDIF
