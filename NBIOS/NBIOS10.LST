  778 E44E  DA E531     	JP C,MINIRD	; A < 3 -> drive 0,1,2 (Mini disks)
  779                   	
  780 E451  FE 04       	CP 4
  781 E453  DA E49F     	JP C,MAXIRD	; A < 4 -> drive 3 (Maxi disks)
  782                   	
  783                   	ENDIF
