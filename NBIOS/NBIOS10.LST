  815                   	;---------------------------------------------------------------------
  816                   	; Calculate address for ram disk, source in HL
  817                   	; SEKTOR 0..E,  TRAck 0..5fh
  818                   	; SSSSTTTT T0000000   , adresse fuer RAM-Floppy
  819 E460  3A E790     ADRERZ:	LD A,(IOT)		; Track holen
  820 E463  0F           	RRCA 			; und umrechnen
  821 E464  E6 0F        	AND 0FH		; unterer Teil vom MSB
  822 E466  67           	LD H,A
  823 E467  3A E791      	LD A,(IOS)		; dann Sektor dazu
  824 E46A  07           	RLCA
  825 E46B  07           	RLCA
  826 E46C  07           	RLCA
  827 E46D  07           	RLCA
  828 E46E  E6 F0        	AND 0F0H
  829 E470  B4           	OR H
  830 E471  67           	LD H,A		; damit sssstttt ok
  831 E472  3A E790      	LD A,(IOT)
  832 E475  0F           	RRCA			; txxxxxxx
  833 E476  E6 80        	AND 80H
  834 E478  6F           	LD L,A		; t0000000
  835 E479  3A E790      	LD A,(IOT)		; nun noch bank bestimmen, in c und b	
  836 E47C  07           	RLCA			; und dazu msb-Teil des Tracks verwenden
  837 E47D  07           	RLCA			; 0mmttttt
  838 E47E  07           	RLCA			; Banknummer
  839 E47F  E6 03        	AND 03H		; 000000mm
  840 E481  C6 01       	ADD A,1			; erst ab Bank 1 starten
  841 E483  47           	LD B,A		; da BANK 0=CP/M RAM und TPA
  842 E484  4F           	LD C,A		; ok beide definiert
  843 E485  C9           	RET
