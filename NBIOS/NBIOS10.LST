 1164                   ; Read Mini disk
 1165                   ; DBANK, IOT, IOS,
 1166                   
 1167 E53D  CD E500     MINIRD:	CALL MINCAL	; calc physical drive and sector data for compare
 1168                   
 1169 E540  3A E793     	LD A,(CURDRV)
 1170 E543  B9          	CP C		; compare drive + side
 1171 E544  C2 E55D     	JP NZ,MINIR2	; -> drive not equal, load sector
 1172                   	
 1173 E547  3A E796     	LD A,(CURTRK)
 1174 E54A  BA          	CP D		; compare track
 1175 E54B  C2 E55D     	JP NZ,MINIR2	; -> track not equal, load sector
 1176                   	
 1177 E54E  3A E797     	LD A,(CURSEC)
 1178 E551  BB          	CP E		; compare sector
 1179 E552  C2 E55D     	JP NZ,MINIR2	; -> sector not equal, load sector
 1180                   
