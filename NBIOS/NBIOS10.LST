 1322                   ;-----------------------------------------------------------------------------
 1323                   ; Calculates the pointer into PHSBUF based on sector number in IOS
 1324                   ; (PHSBUF + offset) -> DE
 1325                   ; (IOD) -> HL
 1326                   ; 128 -> BC (logical sector length)
 1327                   
 1328         FFFF      	IF DG01
 1329                   
 1330         0003      SECPOW		EQU 3		; (1024 / 128) ^ 3 = 8
 1331                   ;SECPOW		EQU 2		; (1024 / 128) ^ 2 = 4
 1332                   ;SECPOW		EQU 1		; (1024 / 128) ^ 1 = 2
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  19
NBIOS10 Z80

 1333                   ;SECPOW		EQU 0		; (1024 / 128) ^ 0 = 1
 1334                   
 1335                   ; mask for modulo (n = IOS mod mask)
 1336         0007      SECMASK		EQU 00000111B	; phys. sector = 1024, modulo 0..7
 1337                   ;SECMASK	EQU 00000011B	; phys. sector = 512, modulo 0..3
 1338                   ;SECMASK	EQU 00000001B	; phys. sector = 256, modulo 0..1
 1339                   ;SECMASK	EQU 00000000B	; phys. sector = 128, modulo 0
 1340                   
 1341 E5E1              CALCPHS:
 1342 E5E1  3A E79D     	LD A,(IOS)	; logical sector number
 1343 E5E4  E6 07       	AND SECMASK
 1344 E5E6  57          	LD D,A		; load to high-byte (mul 256)
 1345 E5E7  1E 00       	LD E,0
 1346 E5E9  CB 2A       	SRA D		; div/2 by shift right
 1347 E5EB  CB 1B       	RR E
 1348                   	; now we have (IOS mod SECSIZE) * 128 in DE
 1349 E5ED  21 FC00     	LD HL,PHSBUF
 1350 E5F0  19          	ADD HL,DE	; pointer into PHSBUF in DE
 1351 E5F1  EB          	EX DE,HL
 1352 E5F2  2A E79E     	LD HL,(IOD)
 1353 E5F5  01 0080     	LD BC,128
 1354 E5F8  C9          	RET
 1355                   
 1356                   	;LD HL,PHSBUF
 1357                   	;LD A,(IOS)	; PHSBUF + ((0..39) MOD 8) * 128
 1358                   	;AND 00000111b	; 0..7 (mod 8)
 1359                   	;LD D,A		; * 256 (low byte is written into the high byte)
 1360                   	;LD E,0
 1361                   	;SRA D		; div/2 by shift right
 1362                   	;RR E
 1363                   	;ADD HL,DE	; HL = source (PHSBUF+offset)
 1364                   	;EX DE,HL	; DE = source
 1365                   	;LD HL,(IOD)	; HL = dest (IOD)
 1366                   	;EX DE,HL	; DE = dest, HL = source
 1367                   	;LD BC,128	; logical sector length
 1368                   	;LDIR		; (DE++) <- (HL++), BC--
 1369                   			; (IOD) <- (PHSBUF+offset), 128 Byte
 1370                   	;XOR A
 1371                   	;RET		; -> finished without error
 1372                   
 1373                   	ENDIF
