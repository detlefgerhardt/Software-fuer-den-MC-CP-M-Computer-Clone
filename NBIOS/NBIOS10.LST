 1128 E517  57          	LD D,A		; Track merken
 1129 E518  D2 E51F     	JP NC,MINC4	; -> side 0
 1130                   
 1131                   	; side
 1132 E51B  79          	LD A,C
 1133 E51C  F6 80       	OR 10000000B	; side 1 flag
 1134 E51E  4F          	LD C,A
 1135                   	
 1136 E51F  7A          MINC4:	LD A,D
 1137 E520  E6 7F       	AND 7FH		; limit to 0..127 tracks
 1138 E522  57          	LD D,A 
 1139                   
 1140                   	; D=track=D, E=sector, C=drive-code + side
 1141 E523  C9          	RET
 1142                   
 1143 E524              CALCTB:	; bit0..3=drive, bit4=density(0=DD), bit5=Mini/Maxi(1=Mini)
 1144                   	; bit7=side
 1145 E524  21          	DB	00100001B	; drive A -> drive0, dd, mini
 1146 E525  22          	DB	00100010B	; drive B -> drive1, dd, mini
 1147 E526  24          	DB	00100100B	; drive C -> drive2, dd, mini
 1148 E527  18          	DB	00011000B	; drive D -> drive3, sd, maxi
 1149 E528  18          	DB	00011000B	; drive E -> drive3, sd, maxi
