 1505 E63D  CB 27       	SLA A
 1506 E63F  47          	LD B,A
 1507 E640  3A E799     	LD A,(DISKNO)
 1508 E643  D6 04       	SUB A,4
 1509 E645  B0          	OR B
 1510 E646  4F          	LD C,A		; C = sector * 4 + (diskno - 4)
 1511                   	
 1512                   	; LBA8..15 -> B
 1513 E647  3A E79C     	LD A,(TRACK)
 1514 E64A  47          	LD B,A
 1515                   	
 1516                   	; LBA16..23) -> E
 1517 E64B  1E 00       	LD E,0
 1518                   
 1519                   	;LD A,'R'
 1520                   	;CALL DEBIDE	; debug output
 1521 E64D  CD F02A     	CALL MIDERD
 1522                   	
 1523         0000      	IF FALSE
 1573                   	ENDIF		; FALSE
 1574                   
 1575 E650  E6 01       	AND 01H
 1576 E652  C0          	RET NZ		; -> exit with error
 1577                   			
