  994                   ;=============================================================================
  995                   ; Read Mini disk, 80 Spur, DD, DS
  996                   
  997                   ;READ und WRITE unter Verwendung von MEXEC
  998                   ; HL=DMA ADR
  999                   ; DE=TRACK/SECTOR
 1000                   ; B=0 RSTORE
 1001                   ;   1 READ
 1002                   ;   2 WRITE
 1003                   ; C=DRIVE 0...3  10H,11H,12H,13H  DOUBMIN 0D0H,0D1H,0D2H,0D3H
 1004                   ;                                          A   C    B    D
 1005                   ; 1K BUFFER IN MONITORGEBIET
 1006                   ; WIRD DADURCH TEILWEISE UEBERSCHRIEBEN
 1007                   ; BEI WARMBOOT MUSS BUFFER GELEERT WERDEN
 1008                   ; DEBLOCK WIRD AUS SICHERHEITSGRUENDEN NICHT VERWENDET
 1009                   
 1010         FC00      PHSBUF	EQU 0FC00H	; Memory area of interactive Monitor for logical sector (1K)
 1011                   
 1012                   ;-----------------------------------------------------------------------------
 1013                   ; Calculates physical drive from DBANK and IOT -> C
 1014                   ; only for Mini disks 0 and 1
 1015                   
 1016                   ; DBANK, IOT     C
 1017                   ;  0     F    -> 0
 1018                   ;  1     F    -> 2
 1019                   ;  0     B    -> 1
 1020                   ;  1     B    -> 3
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  15
