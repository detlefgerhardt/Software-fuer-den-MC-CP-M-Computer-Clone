 1330                   
 1331                   ;-----------------------------------------------------------------------------
 1332                   ; Calculates the pointer into PHSBUF based on sector number in IOS
 1333                   ; (PHSBUF + offset) -> DE
 1334                   ; (IOD) -> HL
 1335                   ; 128 -> BC (logical sector length)
 1336                   
 1337         FFFF      	IF DG01
 1338                   
 1339         0003      SECPOW		EQU 3		; (1024 / 128) ^ 3 = 8
 1340                   ;SECPOW		EQU 2		; (1024 / 128) ^ 2 = 4
 1341                   ;SECPOW		EQU 1		; (1024 / 128) ^ 1 = 2
 1342                   ;SECPOW		EQU 0		; (1024 / 128) ^ 0 = 1
 1343                   
 1344                   ; mask for modulo (n = IOS mod mask)
 1345         0007      SECMASK		EQU 00000111B	; phys. sector = 1024, modulo 0..7
 1346                   ;SECMASK	EQU 00000011B	; phys. sector = 512, modulo 0..3
 1347                   ;SECMASK	EQU 00000001B	; phys. sector = 256, modulo 0..1
 1348                   ;SECMASK	EQU 00000000B	; phys. sector = 128, modulo 0
 1349                   
 1350 E5E3              CALCPHS:
 1351 E5E3  3A E6D4     	LD A,(IOS)	; logical sector number
 1352 E5E6  E6 07       	AND SECMASK
 1353 E5E8  57          	LD D,A		; load to high-byte (mul 256)
 1354 E5E9  1E 00       	LD E,0
 1355 E5EB  CB 2A       	SRA D		; div/2 by shift right
 1356 E5ED  CB 1B       	RR E
 1357                   	; now we have (IOS mod SECSIZE) * 128 in DE
 1358 E5EF  21 FC00     	LD HL,PHSBUF
 1359 E5F2  19          	ADD HL,DE	; pointer into PHSBUF in DE
 1360 E5F3  EB          	EX DE,HL
 1361 E5F4  2A E6D5     	LD HL,(IOD)
 1362 E5F7  01 0080     	LD BC,128
 1363 E5FA  C9          	RET
 1364                   
 1365                   	;LD HL,PHSBUF
 1366                   	;LD A,(IOS)	; PHSBUF + ((0..39) MOD 8) * 128
 1367                   	;AND 00000111b	; 0..7 (mod 8)
 1368                   	;LD D,A		; * 256 (low byte is written into the high byte)
 1369                   	;LD E,0
 1370                   	;SRA D		; div/2 by shift right
 1371                   	;RR E
 1372                   	;ADD HL,DE	; HL = source (PHSBUF+offset)
 1373                   	;EX DE,HL	; DE = source
 1374                   	;LD HL,(IOD)	; HL = dest (IOD)
 1375                   	;EX DE,HL	; DE = dest, HL = source
 1376                   	;LD BC,128	; logical sector length
 1377                   	;LDIR		; (DE++) <- (HL++), BC--
 1378                   			; (IOD) <- (PHSBUF+offset), 128 Byte
 1379                   	;XOR A
 1380                   	;RET		; -> finished without error
 1381                   
 1382                   	ENDIF
