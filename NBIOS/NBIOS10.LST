  588 E3AD  32 E6D3     	LD (IOT),A	; denn 1,3,5 ist die Rueckseite des Laufwerks
  589 E3B0  3E FF       	LD A,0FFH	; 0,1,2,3.... nach Increment A=0
  590                   	
