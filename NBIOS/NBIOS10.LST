 1006                   ;READ und WRITE unter Verwendung von MEXEC
 1007                   ; HL=DMA ADR
 1008                   ; DE=TRACK/SECTOR
 1009                   ; B=0 RSTORE
 1010                   ;   1 READ
 1011                   ;   2 WRITE
 1012                   ; C=DRIVE 0...3  10H,11H,12H,13H  DOUBMIN 0D0H,0D1H,0D2H,0D3H
