 1144                   	; D=track=D, E=sector, C=drive-code + side
 1145 E531  C9          	RET
 1146                   
 1147 E532              CALCTB:	; bit0..3=drive, bit4=density(0=DD), bit5=Mini/Maxi(1=Mini)
 1148                   	; bit7=side
 1149 E532  21          	DB	00100001B	; drive A -> drive0, dd, mini
 1150 E533  22          	DB	00100010B	; drive B -> drive1, dd, mini
 1151 E534  24          	DB	00100100B	; drive C -> drive2, dd, mini
 1152 E535  18          	DB	00011000B	; drive D -> drive3, sd, maxi
 1153 E536  18          	DB	00011000B	; drive E -> drive3, sd, maxi
 1154                   
 1155                   	ENDIF	; ----------
