 1103                   
 1104 E50F  E6 07       	AND 00000111b	; important because of rotate command
 1105                   
 1106 E511  3C          MINIC3:	INC A		; sector number starts with 1
 1107 E512  5F          	LD E,A		; save in E
 1108                   
 1109                   	ENDIF
 1110                   
 1111                   	; drive A,B,C -> 001,010,100
 1112 E513  E5          	PUSH HL
 1113 E514  3A E799     	LD A,(DBANK)
 1114 E517  21 E530     	LD HL,CALCTB
 1115 E51A  CD E535     	CALL LOOKUP
 1116 E51D  E1          	POP HL
 1117                   
 1118 E51E  4F          	LD C,A		; physical drive
 1119                   
 1120 E51F  3A E79C     	LD A,(IOT)
 1121 E522  0F          	RRCA		; Track / 2,  = Phys Track, carry=backside
 1122                   	;AND 7FH	; Bereich Track 0..79 real
 1123 E523  57          	LD D,A		; Track merken
 1124 E524  D2 E52B     	JP NC,MINC4	; -> side 0
 1125                   
 1126                   	; side
 1127 E527  79          	LD A,C
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  16
NBIOS10 Z80

 1128 E528  F6 80       	OR 10000000B	; side 1 flag
 1129 E52A  4F          	LD C,A
 1130                   	
 1131 E52B  7A          MINC4:	LD A,D
 1132 E52C  E6 7F       	AND 7FH		; limit to 0..127 tracks
 1133 E52E  57          	LD D,A 
 1134                   
 1135                   	; D=track=D, E=sector, C=drive-code + side
 1136 E52F  C9          	RET
 1137                   
 1138 E530              CALCTB:	; bit0..3=drive, bit4=density(0=DD), bit5=Mini/Maxi(1=Mini)
 1139                   	; bit7=side
 1140 E530  21          	DB	00100001B	; drive A -> drive0, dd, mini
 1141 E531  22          	DB	00100010B	; drive B -> drive1, dd, mini
 1142 E532  24          	DB	00100100B	; drive C -> drive2, dd, mini
 1143 E533  18          	DB	00011000B	; drive D -> drive3, sd, maxi
 1144 E534  18          	DB	00011000B	; drive E -> drive3, sd, maxi
 1145                   
 1146                   	ENDIF	; ----------
