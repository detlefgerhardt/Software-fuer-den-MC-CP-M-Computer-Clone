 1475         001F      IDESTAT	EQU 01Fh	; IDE Command/Status Register
 1476                   
 1477                   ;-----------------------------------------------------------------------------
 1478                   
 1479                   ; Read one sector from disk.
 1480                   ; Return a 00h in A if the operation completes properly, and 01h if an error occurs during the read.
 1481                   ; Disk number in 'diskno' (4..7)
 1482                   ; Track number in 'track' (0..255)
 1483                   ; Sector number in 'sector' (0..63)
 1484                   ; DMA address in 'dmaad' (0-65535)
 1485                   ; 
 1486                   ; LBA
 1487                   ; 00000000 00000000 00000000
 1488                   ; 00000000 tttttttt ssssssdd
 1489                   ;        E        B        C
 1490                   
 1491         FC00      HSTBUF	EQU PHSBUF	; buffer for phyiscal sector
 1492         E799      DISKNO	EQU DBANK
 1493         E79C      TRACK	EQU IOT
 1494         E79D      SECTOR	EQU IOS
 1495         E79E      DMAAD	EQU IOD
 1496                   
 1497         F02A      MIDERD	EQU 0F02Ah
 1498         F02D      MIDEWR	EQU 0F02Dh
 1499                   
 1500 E635  21 FC00     IDERD:	LD HL,HSTBUF
 1501                   
 1502                   	; LBA0..7 -> C
 1503 E638  3A E79D     	LD A,(SECTOR)
