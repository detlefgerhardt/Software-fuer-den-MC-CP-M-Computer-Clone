  434                   
  435                   ;-----------------------------------------------------------------------------
  436                   ; CP/M message after cold start
  437                   
  438 E2FA              SIGNON:
  439                   
  440         0000      	IF NOT DG01
  449                   	ELSE
  450                   
  451 E2FA  1A          	DB 26
  452 E2FB  0D 0A 43 50 	DB CR,LF,'CP/M '
  453 E302  32 2E 32    	DB CPMVERS/10+'0','.',CPMVERS MOD 10+'0'
  454 E305  20 66 6F 72 	DB ' for MC-Computer '
  455 E316  35 38       	DB MSIZE/10+'0',MSIZE MOD 10+'0'
  456 E318  4B 20 4E 42 	DB 'K NBIOS 260710-01 BOOT='
  457 E32F  30          	DB BTDRV+'0'
  458 E330  0D 0A 00    	DB CR,LF,0
  459                   	
  460                   	ENDIF
  461                   
  462                   ;-----------------------------------------------------------------------------
  463                   ; Monitor routines and addresses
  464                   
  465 E333  C3 F012     CONST:	JP 0F012H	; DIESE ROUTINE LIEFERT DEN STATUS DER
  466                   			; EINGABETASTATUR. WURDE EIN ZEICHEN
  467                   			; EINGEGEBEN, SO LIEFERT DIE ROUTINE 0FFH. 
  468                   	
  469 E336  CD F003     CONIN:	CALL 0F003H	; DIE ROUTINE HOLT EIN ZEICHEN VON DER
  470                   			; TASTATUR AB UND SETZT DAS HOECHSTE BIT
  471                   			; (PARITY BIT) AUF NULL
  472 E339  E6 7F       	AND 7FH
  473 E33B  C9          	RET
  474                   
  475         F01E      MON80	EQU 0F01EH	; Neustart des Monitors
  476                   
  477         F009      CONOUT	EQU 0F009H	; ROUTINE ZUR AUSGABE EINES ZEICHENS IM
  478                   			; C-REGISTER AN DIE KONSOLE. DAZU SPRUNG 
  479                   			; IN DEN MONITOR IM EPROM
  480                   
  481         F00F      LIST	EQU 0F00FH	; ADRESSE FUER DEN SPRUNG IN DIE AUSGABEROUTINE,
  482                   			; UM EIN ZEICHEN IM C-REGISTER AN DIE DRUCKER-
  483                   			; SCHNITTSTELLE ZU LIEFERN
  484                   
  485         F00C      PUNCH	EQU 0F00CH	; ADRESSE FUER DEN SPRUNG IN DIE AUSGABEROUTINE,
  486                   			; UM EIN ZEICHEN IM C-REGISTER AN DIE STANZ-
  487                   			; SCHNITTSTELLE ZU LIEFERN
  488                   
  489         F006      READER	EQU 0F006H	; ADRESSE FUER DEN SPRUNG IN DIE EINGABEROUTINE,
  490                   			; UM EIN ZEICHEN VON LESER-KANAL ZU HOLEN,
  491                   			; UND DAS ZEICHEN IM A-REGISTER ABZULIEFERN (RI)	
  492                   
  493                   ;-----------------------------------------------------------------------------
  494                   ; Cold boot
  495                   
  496 E33C  31 0100     BOOT:	LD SP,BUFF+80H	; output start message
  497 E33F  21 E2FA     	LD HL,SIGNON
  498 E342  CD E43C     	CALL PRMSG
  499                   	
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   7
NBIOS10 Z80

  500                   	; clear / set last used drive
  501 E345  3E 00       	LD A,BTDRV
  502 E347  32 0004     	LD (CDISK),A
  503                   	
  504                   	; sector buffer is empty, set to physical sector buffer not changed
  505 E34A  AF          	XOR A
  506 E34B  32 E786     	LD (BUFCHG),A
  507                   	
  508                   	; drive is undefined
  509 E34E  3E FF       	LD A,0FFH
  510 E350  32 E787     	LD (CURDRV),A
  511                   
  512                   	; disable monitor entries, set to WBOOT
  513 E353  21 E35F     	LD HL,WBOOT
  514 E356  22 F034     	LD (0F033H+1),HL
  515 E359  22 F037     	LD (0F036H+1),HL
  516                   	
  517         FFFF      	IF DG01
  518                   	; patch BDOS avtive drive
  519                   	;CALL PATA
  520                   	;CALL PATB
  521                   	ENDIF
  522                   	
  523 E35C  C3 E3B5     	JP GOCPM	; start CP/M
  524                   
  525                   ;-----------------------------------------------------------------------------
  526                   ; Warm boot
  527                   
  528 E35F              WBOOT:	; write physical sector buffer to disk if changed
  529 E35F  3A E786     	LD A,(BUFCHG)
  530 E362  B7          	OR A
  531 E363  CA E366     	JP Z,WBOO1
  532                   
  533         0000      	IF NOT MINI3
  540                   	ENDIF
  541                   			
  542 E366  3E FF       WBOO1:	LD A,0FFH	; alle Tracks ungueltig, bei Diskettenwechsel wichtig
  543 E368  32 E787     	LD (CURDRV),A
  544                   
  545 E36B  31 0080     	LD SP,BUFF	; Stack zuweisen
  546 E36E  0E 05       	LD C,RETRY	; Anzahl der Versuche
  547 E370  C5          	PUSH BC		; und dann anfangen zu booten
  548                   
  549 E371              WBOO2:	; loop, load CP/M
  550                   	; hier ist noch das Format des Boot-Laufwerks hardkodiert !!!
  551 E371  01 CC00     	LD BC,CPMB	; Boot von MINI-Diskette / Boot drive
  552 E374  CD E436     	CALL SETDMA	; auf der Startadresse des CP/Ms
  553 E377  0E 00       	LD C,BTDRV	; Laufwerk A (or BTDRV)
  554 E379  CD E3FF     	CALL SELDSK	; auswaehlen
  555 E37C  0E 00       	LD C,0		; Track 0
  556 E37E  CD E415     	CALL SETTRK	; und den zweiten phys. Sektor, (Nr 8 logisch)
  557 E381  0E 08       	LD C,8		; entspricht Nr 2 bei 1024 Bytes
  558 E383  CD E41A     	CALL SETSEC	; wichtig, da andere Zaehlweise
  559 E386  C1          	POP BC		; und von da an n Sektoren einlesen
  560 E387  06 2C       	LD B,NSECTS	; aber das BIOS nicht ueberschreiben
  561                   			; damit Patches leicht moeglich sind
  562                   
  563                   	;LD C,'*'
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   8
NBIOS10 Z80

  564                   	;CALL MCONOUT
  565                   
  566 E389              WBOO3:	; sector read loop
  567 E389  C5          	PUSH BC		; Anzahl merken
  568 E38A  CD E449     	CALL READ	; LESEN ausfuehren
  569 E38D  C2 E3DF     	JP NZ,BOOTERR	; Fehler: defekter Sektor
  570                   	
  571 E390  2A E792     	LD HL,(IOD)	; Zieladresse laden
  572 E393  11 0080     	LD DE,128	; um logische Sektorgroesser erhoehen
  573 E396  19          	ADD HL,DE	; dazu addieren,
  574 E397  22 E792     	LD (IOD),HL	; und dann wieder zurueckspeichern.
  575 E39A  3A E791     	LD A,(IOS)	; Sektor laden
  576 E39D  FE 27       	CP 39		; Mini 0..39 Sektoren a 128 Bytes
  577                   			; Anzahl der Sektoren hardcodiert !!!
  578 E39F  DA E3AC     	JP C,WBOO4	; solange auf der gleichen Spur bleiben
  579                   
  580                   	; next track, Spurzuordnung hardcodert !!!
  581 E3A2  3A E790     	LD A,(IOT)	; Dann neue Spur anwaehlen,
  582 E3A5  3C          	INC A	  	; jedoch im Verfahren 0,2,...
  583 E3A6  3C          	INC A		; SPUR 0, dann SPUR 2, wegen BOOT.ASM
  584 E3A7  32 E790     	LD (IOT),A	; denn 1,3,5 ist die Rueckseite des Laufwerks
  585 E3AA  3E FF       	LD A,0FFH	; 0,1,2,3.... nach Increment A=0
  586                   	
