NMON    Z80

  938 F2E4  E6 03       	AND 3  			; 0,1,2,3 zulaessig
  939 F2E6  B0          	OR B  			; 
  940 F2E7  D3 C0       	OUT (FLO),A 		; execute Seek together with steprate
  941                   
  942 F2E9  76          	HALT  			; wait for INT
  943                   
  944                   ;------------------------------------------------------------------------------
  945                   ; Kopf auf Spur 0 stellen
  946                   			
  947 F2EA  CD F2C3     RSTORE:	CALL WAWA		; short delay (4 ms)
  948                   
  949 F2ED  79          	LD A,C  		; Laufwerkscode (drive)
  950 F2EE  D3 C4       	OUT (FLO+4),A 		; mit Dichtecode etc. ausgeben -> REG4-Latch
  951                   
  952                   	; Command "Restore" 0000hvrr, h=head load, v=verify, rr=steprate
  953 F2F0  06 08       	LD B,00001000B 		; only head load, no verify
  954 F2F2  3A F3FA     	LD A,(STEPRATE)
  955 F2F5  E6 03       	AND 3  			; 0..3
  956 F2F7  B0          	OR B  			; als Befehl kombiniert
  957 F2F8  D3 C0       	OUT (FLO),A 		; und ausfuehren
  958                   
  959 F2FA  76          	HALT  			; wait for INT
  960                   
  961                   ;------------------------------------------------------------------------------
  962                   ; Floppy Kernal Routines
  963                   
  964                   ; HL = buffer address
  965                   ; D = track (0..?) or parameter for set steprate
  966                   ; E = sector (1..n)
  967                   ; B = command (0=set steprate+SSO, 1=read, 2=write)
  968                   ; C = drive code
  969                   ;   REG4-Latch format
  970                   ;   7   6   5   4   3   2   1   0
  971                   ;   sid mot min den d   d   d   d
  972                   ;   sid: 0=side, 1=side1
  973                   ;   mot: motor on code (std=0)
  974                   ;   min: 0=maxi drive, 1=mini drive
  975                   ;   den: 0=dd, 1=ss
  976                   ;   d=binary drive code
  977                   ;     normalerweise nur 1,2,4,8 moeglich
  978                   ;     Kombinationen moeglich, wenn binaere
  979                   ;     Dekodierung beim Laufwerk verwendet wird
  980                   
  981 F2FB  78          EXFLO:	LD A,B			; B = command
  982 F2FC  B7          	OR A
  983 F2FD  20 08       	JR NZ,EXFL1
  984                   
  985                   	;---------------------------------------------------------------------
  986                   	; B=0: set steprate and SSO
  987                   	; steprate in D, Bit0/1=steprate, bit7=SSO
  988                   	
  989 F2FF  7A          	LD A,D   		; (+80h =SSO verwenden und pruefen).
  990 F300  E6 83       	AND 83h  		; Bit 7=SSO-Flag bei Zugriffen wichtig
  991 F302  32 F3FA     	LD (STEPRATE),A		; die die zweite Seite verwenden.
  992 F305  AF          	XOR A
  993 F306  C9          	RET
  994                   
