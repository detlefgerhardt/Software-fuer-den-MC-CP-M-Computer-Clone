  639                   
  640                   ; Old MINI routine
  641                   
  642                   ; Routinen fuer MC-Kompatibilitaet
  643                   ; wie floppy, jedoch Drive-Codierung anders
  644                   ; nur fuer bestehende BIOS-Routinen gedacht
  645                   ;
  646                   ; HL = block buffer address
  647                   ; B = 0=set step-rate and SSO, 1=read, 2=write
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  12
NMON    Z80

  648                   ; C = bit0=drive 0/1 (A/B), bit1=side 0/1, bit6=density
  649                   ; D = track
  650                   ; E = physical sector (1..n)
  651                   
  652 F1E4  79          MINI:	LD A,C		; drive code
  653 F1E5  E6 7F       	AND 7FH 	; bit 7 interessiert nicht
  654 F1E7  4F          	LD C,A		; C value is used and overwritten by SCODB
  655                   
  656                   	; value for REG4-Latch -> C
  657 F1E8  F5          	PUSH AF
  658 F1E9  CD F1CA     	CALL SCODB 	; drive-code + side A -> C (value for REG4-Latch)
  659 F1EC  F1          	POP AF
  660 F1ED  E6 40       	AND 40H 	; density
  661 F1EF  C2 F1F9     	JP NZ,MINI1
  662                   	
  663                   	; single-density
  664 F1F2  79          	LD A,C
  665 F1F3  F6 30       	OR 00110000B 	; Bit5=Mini, Bit4=density (0=DD)
  666 F1F5  4F          	LD C,A
  667 F1F6  C3 F1FD     	JP MINI2
  668                   
  669 F1F9              MINI1:	; double-density
  670 F1F9  79          	LD A,C
  671 F1FA  F6 20       	OR 00100000B 	; Bit5=Mini, Bit4=density (0=DD)
  672 F1FC  4F          	LD C,A
  673                   
  674 F1FD  3E 02       MINI2:	LD A,2  	; set SSO flag
  675 F1FF  C3 F214     	JP FLOP1 	; ok ausfuehren
  676                   
