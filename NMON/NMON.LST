  252                   ;==============================================================================
  253                   ; IO Routines
  254                   ;==============================================================================
  255                   ; Output 0-terminated string, address in HL
  256                   
  257 F074  DB 21       WRSTR:	IN  A,(CO_STS)	; read status
  258 F076  E6 01       	AND CO_TXB	; check TxRDY bit
  259 F078  CA F074     	JP Z,WRSTR	; wait if not set
  260                   	
  261 F07B  7E          	LD A,(HL)	; get char from string
  262 F07C  A7          	AND A		; check if 0
  263 F07D  C8          	RET Z		; -> end of string
  264                   	
  265 F07E  D3 20       	OUT (CO_DAT),A	; write char to output
  266 F080  23          	INC HL		; next char in string
  267 F081  C3 F074     	JP WRSTR	; start over
