    1                   	.Z80
    2                   ;*****************************************************************************
    3                   ;* NMON.Z80								     *
    4                   ;*									     *
    5                   ;* based on Mon80V1 by Ulrich Haumann 05/2026	        	             *
    6                   ;* V7.2 851216, sowie Teile aus dem Monitor von Donn Stewart ("CPU-Ville"    *
    7                   ;* Z80 Computer.)                 					     *
    8                   ;* based on RDK Monitor 1.1 850129					     *
    9                   ;*****************************************************************************
   10                   ; Monitor for MC-Computer board SYS-80 and SYS-80s
   11                   ; Assembliert mit Z80ASM von SLR Systems wegen der langen
   12                   ;
   13                   ; Ulrich Haumann:
   14                   ; Treiber fuer Serielle Schnittstelle auf CPU-Platine mit UART 8251
   15                   ; implementiert.
   16                   ; Flo1 und Flo2 waehlber auf Hardware Basis Adresse 0C0h.
   17                   ; Der Mointor erwartet 64KB Ram Memory. Er darf selbst nicht
   18                   ; groesser als 4KB werden, es sein denn man schiebt die ROMSTRT
   19                   ; und CCP weiter nach unten. Der CPM Bereich verkleinert sich dann.
   20                   ; Der Monitor kopiert sich nach Reset an das Speicherende
   21                   ; auf den Wert in ROMSTRT und gibt den unteren RAM Bereich frei.
   22                   ; Dies wird auf der SYS CPU Platine mit einem Lesebefehl auf
   23                   ; Adresse 7000h erreicht. Das Eprom ist dann ausgeblendet.
   24                   ; Somit steht der Speicher durchgaengig ab 0000h bis zu ROMSTRT
   25                   ; zur Verfuehgung.
   26                   ; Das CPM BIOS fuer den MC-Computer ueberschreibt den Monitorbereich
   27                   ; ab FC00h. Alle relevanten Teile fuer den Betrieb des Rechners 
   28                   ; muessen vor FC00h plaziert werden.
   29                   ; Ergaenzung: Das betrifft alle Teile des interaktiven Monitors, der
   30                   ; dann nicht mehr funktionsfaehig ist. Funktionsfaehig bleiben nur
   31                   ; die Ein-/Ausgabe-Routinen und die Floppy-Routinen, die vom BIOS
   32                   ; benoetigt werden.
   33                   ;
   34                   ; NMON Version history
   35                   ;
   36                   ; 01.07.2026 *dg* Komplette Ueberarbeitung der Kommentate ohne funktionale Aenderungen
   37                   
   38                   ;------------------------------------------------------------------------------
   39                   ; Mapping of REG4-Latch
   40                   
   41                   ; write
   42                   ; Bit0 = Drive Select 1
   43                   ; Bit1 = Drive Select 1
   44                   ; Bit2 = Drive Select 3
   45                   ; Bit3 = Drive Select 4
   46                   ; Bit4 = FDC9239 Dens (0=DD, 1=SS)
   47                   ; Bit5 = FDC9239 Mini (0=Maxi, 1=Mini)
   48                   ; Bit6 = Motor On (Jumper) (0=Motor on, 1=Motor off)
   49                   ; Bit7 = Side Select (Jumper) (0=Side 0, 1=Side 1)
   50                   
   51                   ; read
   52                   ; Bit5 = Headload Status (0=head loaded, 1=head unloaded)
   53                   ; Bit6 = FD197x INTREQ (0=not active, 1=active)
   54                   ; Bit7 = FD197x DRQ (0=not active, 1=actice)
   55                   
   56                   ;------------------------------------------------------------------------------
   57                   ; Constants
   58                   
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   2
NMON    Z80

   59         0000      FALSE	EQU 0
   60         FFFF      TRUE	EQU NOT FALSE
   61         000D      CR 	EQU 0DH		; carriage return
   62         000A      LF 	EQU 0AH		; line feed
   63         0007      BELL	EQU 07H		; bell
   64         00FF      RUB 	EQU 0FFH	; rub out
   65                   ;FIL 	EQU 0
   66                   ;MAX	EQU 7
   67         001B      ESC	EQU 1BH
   68                   
   69         0038      RST7	EQU 38H		; der Vektor RST7 wird fuer Breakpoints gebraucht
   70                   
   71                   ;------------------------------------------------------------------------------
   72                   ; Variant switches
   73                   
   74         0015      VERSION	EQU 21
   75                   
   76                   ; aktiviert alle bisherigen Aenderungen gegenueber der Originalversion 7.x
   77         0000      DG01	EQU FALSE
   78                   
   79                   ; 3 Mini drives (A..C), 1 Maxi drives (D), 1 RAM-Disk (E)
   80         0000      MINI3	EQU FALSE
   81                   
   82                   ; version for CPU80/S with UART 8251
   83         FFFF      SYS80S	EQU TRUE
   84                   
   85                   ;------------------------------------------------------------------------------
   86                   ; I/O addresses
   87                   
   88                   ; SYS80S = TRUE:  serial port of SYS-80S card ist used for console
   89                   ; SYS80S = FALSE: serial port SIO A at OUT-80 card is used for console
   90                   
   91                   ; OUT-80 card SIO B is used for reader, punch and lister
   92                   
   93                   ; Addresses of serial port UART 8251 at SYS-80s CPU card
   94         0020      SU_DAT	EQU 020H	; UART 8251 Daten
   95         0021      SU_STS	EQU 021H	; UART 8251 Control
   96         0002      SU_RXB	EQU 002h	; RX Ready Bit UART 8251
   97         0001      SU_TXB	EQU 001h	; TX Ready Bit UART 8251
   98                   
   99                   ; Addresses of serial port MC Computer OUT-80 card with SIO
  100         00F0      SA_DAT	EQU 0F0H	; SIO A Daten
  101         00F1      SA_STS	EQU 0F1H	; SIO A Control
  102         00F2      SB_DAT	EQU 0F2H	; SIO B Daten
  103         00F3      SB_STS	EQU 0F3H	; SIO B Control
  104         0001      SI_RXB	EQU 01h		; SIO RX Ready Bit
  105         0004      SI_TXB	EQU 04h		; SIO TX Ready Bit
  106                   
  107         FFFF      	IF SYS80S
  108                   
  109                   ; Console is redirected to UART on SYS-80s
  110         0020      CO_DAT	EQU SU_DAT
  111         0021      CO_STS	EQU SU_STS
  112         0002      CO_RXB	EQU SU_RXB
  113         0001      CO_TXB	EQU SU_TXB
  114                   
  115                   	ELSE
  123                   	ENDIF
