  558                   
  559                   ; Floppy Interface Paket Rev 1.0   841031
  560                   ; (C) 1984 Muenchen, Rolf-Dieter Klein
  561                   
  562                   ; Routinen fuer MC-Kompatibilitaet
  563                   ; wie floppy, jedoch Drive-Codierung anders
  564                   ; nur fuer bestehende BIOS-Routinen gedacht
  565                    
  566                   ; bei Maxi wird die Seite 1 mit Seitenpruefung auf 0
  567                   ; angesprochen, bei Mini mit Seitenpruefung auf 1.
  568                   ; nur fuer SD
  569                   
  570                   ; c=0,1,2,3
  571                   ; 	0,2 gekoppelt  1,3 gekoppelt					
  572                   
  573 F1A9  CD F1AF     MAXI:	CALL SCODA	; coding 1
  574 F1AC  C3 F213     	JP FLOP		; sso-flag auf 0 setzen, jedoch stepflag
  575                   			; gueltig wenn bit 7 gesetzt.
  576                   
  577                   ;------------------------------------------------------------------------------
  578                   ; Maxi Disk recoding of drive and side for Special Register 4
  579                   ; 0 -> 11 (drive 1, side 0, Maxi)
  580                   ; 1 -> 91 (drive 1, side 1, Maxi)
  581                   ; 2 -> 12 (drive 2, side 0, Maxi)
  582                   ; 3 -> 92 (drive 2, side 1, Maxi)
  583                   
  584 F1AF  79          SCODA:	LD A,C  	; SD MAXI
  585 F1B0  E6 03       	AND 3  		; muss Bereich 0..3 sein
  586 F1B2  FE 00       	CP 0  		; 0 seite 0
  587 F1B4  20 03       	JR NZ,SCODA1
  588                   	
  589 F1B6  0E 11       	LD C,00010001B 	; LW 1
