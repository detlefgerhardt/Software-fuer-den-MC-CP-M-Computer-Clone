  607                   ;------------------------------------------------------------------------------
  608                   ; Mini Disk recoding of drive and side for Special Register 4
  609                   ; 0 -> 01 (drive 1, side 0, Mini)
  610                   ; 1 -> 81 (drive 1, side 1, Mini)
  611                   ; 2 -> 02 (drive 2, side 0, Mini)
  612                   ; 3 -> 82 (drive 2, side 1, Mini)
  613                   
  614                   ; hier ist eine Erweiterung fuer Laufwerke C und D notwendig
  615                   
