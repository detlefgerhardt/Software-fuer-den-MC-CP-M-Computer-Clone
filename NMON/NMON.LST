  768                   
  769 F213  AF          FLOP:	XOR A  			; SSO-Flag auf 0 setzen
  770                   
  771                   ; Entry SSO in A
  772                   ; called only from old MINI routine
  773                   
  774 F214              FLOP1:	; SSO flag in A, only 0 and 2 allowed
  775 F214  32 F3FB     	LD (SSOFLAG),A
  776                   
  777 F217  F5          	PUSH AF
  778 F218  3A F587     	LD A,(FLOTYP)
