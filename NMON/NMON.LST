  793 F230  D3 C0       	OUT (FLO),A 		; reset floppy controller
  794                   	
  795                   	; set interrupt vector to INTEX
  796 F232  3A 0038     	LD A,(INTVEK)
  797 F235  32 F3FE     	LD (SAVINT),A
  798 F238  3E C3       	LD A,0C3H 		; JP-Befehl
  799 F23A  32 0038     	LD (INTVEK),A
  800 F23D  E5          	PUSH HL
  801 F23E  2A 0039     	LD HL,(INTVEK+1)
  802 F241  22 F3FF     	LD (SAVINT+1),HL
  803 F244  21 F202     	LD HL,INTEX 		; set to JP INTEX
  804 F247  22 0039     	LD (INTVEK+1),HL
  805 F24A  E1          	POP HL
  806                   	
  807 F24B  DB C0       	IN A,(FLO)		; Status - Port
  808 F24D  ED 56       	IM 1  			; set interrupt mode 1 ->  execure at 38h
  809 F24F  FB          	EI  			; Interrupt freigeben
  810 F250  CD F2FB     	CALL EXFLO
  811 F253  F3          	DI  			; disable interrupt
  812                   	
  813                   	; restore interrupt vector
  814 F254  F5          	PUSH AF 		; Status
  815 F255  3A F3FE     	LD A,(SAVINT)
  816 F258  32 0038     	LD (INTVEK),A 		; zurueckspeichern
  817 F25B  E5          	PUSH HL
  818 F25C  2A F3FF     	LD HL,(SAVINT+1)
  819 F25F  22 0039     	LD (INTVEK+1),HL
  820 F262  E1          	POP HL
  821 F263  F1          	POP AF
