  780 F21D  C2 F226     	JP NZ,FLOP2		; -> FLO2
  781                   	
  782                   	; FLO1
  783 F220  79          	LD A,C
  784 F221  E6 BF       	AND 10111111B 		; kein autowait 
  785 F223  EE 10       	XOR 10H 		; invertieren Dichtebit fuer FLO1
  786 F225  4F          	LD C,A
  787                   
  788 F226  F1          FLOP2:	POP AF
