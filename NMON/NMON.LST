  143                   ;------------------------------------------------------------------------------
  144                   
  145                   ; Addresses of IDE-80 CF-Adapter card
  146                   
  147         0018      IDEDATA	EQU 018h	; IDE Data Register
  148         001A      SECCND	EQU 01Ah	; Sector Count Register
  149         001B      LBA7	EQU 01Bh	; LBA Bits 0-7
  150         001C      LBA15	EQU 01Ch	; LBA Bits 8-15
  151         001D      LBA23	EQU 01Dh	; LBA Bits 16-23
  152         001E      IDEHEAD	EQU 01Eh	; IDE Drive Head Register
  153         001F      IDESTAT	EQU 01Fh	; IDE Command/Status Register
  154                   
  155                   ;------------------------------------------------------------------------------
  156                   
  157         0000      	ORG 0000h		; start address in ROM
  158                   
  159                   	; Copy Monitor from address ROMSTRT in ROM to address F000 in RAM
  160                   
  161 0000  31 FFFF     BEGIN:	LD SP,0FFFFh 		; set Stack to end of memory
  162 0003  3E C9       	LD A,0C9h 		; place RET command at F000h
  163 0005  32 F000     	LD (0F000h),A 		; 
  164 0008  CD F000     	CALL 0F000h 		; and call it
  165                   
  166 000B  3B          OFFS:	DEC SP  		; get return address from Stack to calculate
  167 000C  3B          	DEC SP  		; Monitor location in ROM
  168 000D  D1          	POP DE
  169 000E  21 0012     	LD HL,ROMSTRT-OFFS	; offset from BEG to ROMSTRT
  170 0011  19          	ADD HL,DE		; actual Montor address in ROM as source address in HL
  171 0012  11 F000     	LD DE,0F000h 		; dest address in DE
  172 0015  01 0FFF     	LD BC,0FFFh 		; length in BC (4KB - 1)
  173 0018  ED B0       	LDIR  			; copy
  174 001A  C3 F000     	JP 0F000h 		; jump to Monitor in RAM
  175                   
  176                   ;------------------------------------------------------------------------------
  177                   ; Start of Monitor program, ROM address 0F000h
  178                   
  179 001D              ROMSTRT:
  180                   	; Start address of Monitor in ROM
  181                   	; label must be located before .PHASE
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   4
NMON    Z80

  182                   
  183                   	.PHASE 0F000H	; monitor start address in RAM
  184                   
  185 F000  C3 F071     	JP INIT
  186 F003  C3 F084     	JP CONIN	; Console In
  187 F006  C3 F097     	JP READIN	; Reader In (<- SIO B)
  188 F009  C3 F0AD     	JP CONOUT	; Console Out
  189 F00C  C3 F0C1     	JP PUNOUT	; Punch Out (-> SIO B)
  190 F00F  C3 F0D8     	JP LSTOUT	; List Out (-> SIO B)
  191 F012  C3 F0EF     	JP CONSTS	; Get console status, 0FFh in A, if character available
  192 F015  C3 F102     	JP IOGET	; Get iobyte, current configuration in A
  193 F018  C3 F106     	JP IOSET	; Set iobyte, new configuration in C
  194 F01B  C3 F10B     	JP MEMCHK	; High memory in B, low memory in A
  195                   
  196 F01E              TRAP:	; trap/breakpoint entry -> RSTRT
  197                   
  198 F01E  C3 F06E     	JP RSTRT
  199                   	
  200 F021  C3 F213     	JP FLOP	 	; new floppy interface rev 1.0 (used by BIOS 3.1)
  201                   	
  202         FFFF      	IF NOT DG01
  203 F024  C3 F1A9     	JP MAXI		; FLOPPY EXEC VEKTOR SOFT (old)
  204 F027  C3 F1E4     	JP MINI		; FLOPPY EXEC VEKTOR MINI (used by BIOS 3.1)
  205                   	ELSE
  208                   	ENDIF
  209                   	
  210 F02A  C3 F588     	JP IDERD	; Read IDE sector
  211 F02D  C3 F5C7     	JP IDEWR	; Write IDE Sector
  212 F030  C3 F6CA     	JP COLD		; Monitor Cold Start (no Hardware init)
  213 F033  C3 F6FB     	JP WARM		; Monitor Warm Start
  214 F036  C3 F074     	JP WRSTR	; gibt einen 0-terminierten String aus
  215                   
  216 F039  F13A        TABPTR:	DEFW TABSTART 	; Start of user jump table
  217 F03B  FE30        ENDPTR:	DEFW LASTMON 	; End address of Monitor
  218 F03D  F606        FREPTR:	DEFW FREEMEM 	; End of Monitor driver section. The area behind it can be overwritten by CP/M.
  219                   
  220                   	; Jump table for compatibility to FLOMON (NDR-Klein-Computer)
  221                   	
  222 F03F    000D      	DEFS 13 	; f033,34,35,36,37,38,39,3a,3b,3c,3d,3e,3f
  223                   			; BASIS F040h
  224 F04C  C3 F06A     	JP ILLEGAL 	; loeschen alle seiten
  225 F04F  C3 F06A     	JP ILLEGAL     	; loeschen unsichtbar
  226 F052  C3 F06A     	JP ILLEGAL 	; moveto hl=x de=y
  227 F055  C3 F06A     	JP ILLEGAL 	; drawto hl=x de=y
  228 F058  C3 F06A     	JP ILLEGAL 	; c=schreibseite 0,1,2,3
  229 F05B  C3 F06A     	JP ILLEGAL 	; c=leseseite    0,1,2,3
  230 F05E  C3 F06A     	JP ILLEGAL      ; c=rmwmode      0=norm 1=rmw
  231 F061  C3 F06A     	JP ILLEGAL 	; warten bis gdp fertig
  232 F064  C3 F06A     	JP ILLEGAL      ; c=befehl fuer gdp  ACHTUNG in C-Register nicht A
  233 F067  C3 F06A     	JP ILLEGAL 	; hl=quelle,de=ziel,c=bank quelle, b=bank ziel
  234                   			; carry wenn bankram auf f000h nicht da ist
  235                   
  236                   ; End of area of tables and fixed addresses, that are used by CP/M BIOS, UFORMAT etc.
  237                   
  238                   ;------------------------------------------------------------------------------
  239                   
  240 F06A              ILLEGAL:
  241 F06A  3E FF       	LD A,0FFh
