  391                   ;------------------------------------------------------------------------------
  392                   ; prueft den Speicherbereich und gibt die hoechste verfuegbare Zelle an
  393                   ; MEMCHK IN B HIGH IN A LOW MEMORY
  394                   
  395 F10B  E5          MEMCHK:	PUSH HL
  396 F10C  CD F118     	CALL MEMSIZ
  397 F10F  7D          	LD A,L
  398 F110  D6 3C       	SUB 3CH
  399 F112  30 01       	JR NC,MEMCK1
  400                   
  401 F114  25          	DEC H
  402                   	
  403 F115  44          MEMCK1:	LD B,H
  404 F116  E1          	POP HL
  405 F117  C9          	RET
  406                   
  407                   ;------------------------------------------------------------------------------
  408                   ; Detect end of memory from 0000h to EFFFh
  409                   
  410 F118  C5          MEMSIZ:	PUSH BC
  411                   
  412                   	; entry point
  413 F119              MEMSIZB:
  414 F119  21 FFFF     	LD HL,-1
  415                   
