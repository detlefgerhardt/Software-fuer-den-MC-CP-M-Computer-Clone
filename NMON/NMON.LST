  826                   ;------------------------------------------------------------------------------
  827                   ; Diverse Unterprogramme
  828                   ;------------------------------------------------------------------------------
  829                   ; Prepare command byte for floppy controller
  830                   
  831 F269              SETCMD:				; testet ob der Kopf noch
  832                   				; geladen ist und setzt die
  833 F269  06 00       	LD B,0  		; Flag fuer SSO-Bit
  834 F26B  3A F402     	LD A,(DRVCOD) 		; wenn Bit 7 gesetzt, dann abfragen
  835 F26E  E6 80       	AND 80H
  836 F270  28 11       	JR Z,SETC2 		; Seite 0, immer mit SSO=0
  837                   	
  838 F272  3A F3FA     	LD A,(STEPRATE) 	; jetzt pruefen ob flags da
  839 F275  E6 80       	AND 80H 		; <>0, dann SSO setzen, wenn seite 1
  840 F277  28 04       	JR Z,SETC1 		; =0, dann code 0, oder SSOFLAG
  841                   	
  842 F279  06 02       	LD B,2  		; SSO setzen 
  843 F27B  18 06       	JR SETC2
  844                   
  845 F27D              SETC1:	; pruefen ob SSO-Flag
  846 F27D  3A F3FB     	LD A,(SSOFLAG) 		; ok, 2=Flag
  847 F280  E6 02       	AND 2  			; SSO-Bit
  848 F282  47          	LD B,A  		; 0,2 erlaubt 
  849                   
  850 F283              SETC2:	; entsprechenden Bits
  851 F283  DB C4       	IN A,(FLO+4) 		; REG4-Status
  852 F285  E6 20       	AND 20H 		; Head-Load Bit
  853 F287  20 04       	JR NZ,SETC3 		; =1 dann Kopf auf Diskette
  854                   	
  855 F289  78          	LD A,B
  856 F28A  F6 04       	OR 04h 			; sonst Bitmaske fuer headdown
  857 F28C  C9          	RET
  858                   
  859 F28D              SETC3:	; noset
  860 F28D  78          	LD A,B
  861 F28E  C9          	RET 			; Code belassen
  862                   
  863                   ;------------------------------------------------------------------------------
  864                   ; Read one sector
  865                   ; sector number in E
  866                   ; buffer addr in HL
  867                   
  868 F28F  79          RDFLP:	LD A,C
  869 F290  D3 C4       	OUT (FLO+4),A 		; density + side -> REG4-Latch
  870 F292  7B          	LD A,E
  871 F293  D3 C2       	OUT (FLO+2),A 		; ins Sektorregister
  872 F295  0E C3       	LD C,FLO+3 		; Adresse Datenport dann nach C
  873 F297  CD F269     	CALL SETCMD 		; Register A vorbereiten
  874 F29A  C6 88       	ADD A,10001000B		; Command "Read Sector", without SSO
  875 F29C  D3 C0       	OUT (FLO),A 		; Befehl ausfuehren
  876                   
  877 F29E              RDFLP1:	; wait for DRQ = 1
  878 F29E  DB C4       	IN A,(FLO+4) 		; DRQ schon da ?
  879 F2A0  07          	RLCA  			; bit7 = DRQ, bit6 = int
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  16
NMON    Z80

  880 F2A1  D2 F29E     	JP NC,RDFLP1 		; -> DRQ = 0
  881                   	
  882 F2A4  ED A2       	INI  			; IN (C) -> (HL), HL++, B--
  883 F2A6  C3 F29E     	JP RDFLP1  		; verlassen nur durch INT
  884                   
  885                   ;------------------------------------------------------------------------------
  886                   ; Write one sector
  887                   
  888 F2A9  79          WRFLP:	LD A,C
  889 F2AA  D3 C4       	OUT (FLO+4),A 		; density + side -> REG4-Latch
  890 F2AC  7B          	LD A,E  		; Sektorregister setzen
  891 F2AD  D3 C2       	OUT (FLO+2),A
  892 F2AF  0E C3       	LD C,FLO+3		; Adresse Datenport laden
  893 F2B1  CD F269     	CALL SETCMD		; E-Code in A laden
  894 F2B4  C6 A8       	ADD A,0A8H		; Befehl Schreibe-Sektor
  895 F2B6  D3 C0       	OUT (FLO),A 		; und Befehl ausfuehren
  896                   
  897 F2B8              WRFLP1:	; wait for DRQ = 1
  898 F2B8  DB C4       	IN A,(FLO+4) 		; DRQ schon da ?
  899 F2BA  07          	RLCA  			; bit7 = DRQ, bit6 = int
  900 F2BB  D2 F2B8     	JP NC,WRFLP1
  901                   	
  902 F2BE  ED A3       	OUTI  			; (HL) -> OUT (C), HL++, B--
  903 F2C0  C3 F2B8     	JP WRFLP1  		; verlassen nur durch INT
  904                   
  905                   ;------------------------------------------------------------------------------
  906                   ; delay: 4 ms at 4 MHz
  907                   
  908 F2C3  C5          WAWA:	PUSH BC 		; pro Schleife ca 6us bei 4MHz
  909 F2C4  01 01F4     	LD BC,500 		; 500*6us Dauer
  910 F2C7  CD F2CC     	CALL DELAY
  911 F2CA  C1          	POP BC
  912 F2CB  C9          	RET
  913                   
  914                   ;------------------------------------------------------------------------------
  915                   ; delay: 6 microseconds at 4 MHz
  916                   
  917 F2CC  0B          DELAY:	DEC BC
  918 F2CD  78          	LD A,B
  919 F2CE  B1          	OR C
  920 F2CF  C2 F2CC     	JP NZ,DELAY
  921                   	
  922 F2D2  C9          	RET
  923                   
  924                   ;------------------------------------------------------------------------------
  925                   ; Seek to track
  926                   ; C=Drive D=Track E=Sector
  927                   
  928 F2D3  CD F2C3     SEEK:	CALL WAWA 		; short delay (4 ms)
  929                   
  930 F2D6  79          	LD A,C
  931 F2D7  D3 C4       	OUT (FLO+4),A 		; drive code, density and side -> REG4-Latch
  932 F2D9  7B          	LD A,E
  933 F2DA  D3 C2       	OUT (FLO+2),A 		; Sector
  934 F2DC  7A          	LD A,D
  935 F2DD  D3 C3       	OUT (FLO+3),A 		; track
  936 F2DF  06 1C       	LD B,1CH 		; seek command
  937 F2E1  3A F3FA     	LD A,(STEPRATE)
