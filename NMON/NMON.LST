  681                   ;==============================================================================
  682                   ; Floppy-Unterprogramme fuer FLO2
  683                   ; verwendet 1797 als Controller
  684                   ; Version 1.0   840506
  685                   ; Rolf-Dieter Klein (C) 1984 Muenchen
  686                   ;
  687                   ; Die Routinen ermoeglichen sowohl den Anschluss von Mini-,Mikro- als auch
  688                   ; von Maxi-Laufwerken. Die Routinen muessen im RAM stehen, da die Buffer
  689                   ; am Ende stehen. Alle Buffer sind jedoch gesammelt.
  690                   
  691                   ; FLO4    als Leseport
  692                   ;
  693                   ; 7 6 5 4 3 2 1 0
  694                   ;
  695                   ; DRQ   INTRQ   headld x      x x x x
  696                   ; 0=request
  697                   ;      0=request
  698                   ;  1=head down
  699                   ;
  700                   
  701                   ; FLO4    als Schreibport
  702                   ;
  703                   ; 7 6 5 4 3 2 1 0
  704                   ;
  705                   ; sso moton mini dense d c b a
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  13
NMON    Z80

  706                   ;
  707                   ; 1=Seite 1
  708                   ; 0=Motor an
  709                   ;  1=Minilaufwerk
  710                   ;   1=Single Dense
  711                   ;    -------------------------
  712                   ;      1=Laufwerk an
  713                   
  714         00C0      FLO	EQU 0C0H 		; Basisadresse Floppy-Controller
  715                   ;FLO0	EQU 0C0H   	
  716                   ;FLO1	EQU 0C1H
  717                   ;FLO2	EQU 0C2H
  718                   ;FLO3	EQU 0C3H
  719                   ;FLO4	EQU 0C4H 		; Port fuer Zusatzstatus etc.
  720                   				; write REG4-Latch
  721                   				; read REG4-Status
  722                   
  723                   ;------------------------------------------------------------------------------
  724                   ; Bei einem Interrupt wird an diese Stelle gesprungen
  725                   ; Der Interrupt erfolgt vom Floppy-Controller
  726                   
  727 F202              INTEX:	; Das INT-Program arbeitet nicht als Unterprogramm
  728 F202  F1          	POP AF  		; alte Ret-Adresse vernichten
  729 F203  DB C0       	IN A,(FLO) 		; Status lesen und INT loeschen
  730 F205  FB          	EI  			; Interrupt wieder freigeben
  731 F206  ED 4D       	RETI  			; zurueck zum vorherigen Aufrufer
  732                   
  733                   ;------------------------------------------------------------------------------
  734                   ; Floppy Routinen Init
  735                   
  736 F208  3E 02       INIFLP:	LD A,2  		; 3 = langsamste Steprate, kein SSO
  737 F20A  32 F3FA     	LD (STEPRATE),A
  738                   	
  739 F20D  3E FF       	LD A,0FFH
  740 F20F  32 F403     	LD (CURDRV),A 		; no current drive
  741 F212  C9          	RET 
  742                   
  743                   ;------------------------------------------------------------------------------
  744                   
  745         0038      INTVEK	EQU 38h 		; Interruptziel
  746                   
  747                   ;------------------------------------------------------------------------------
  748                   ; Haupteingang der Floppy-Routinen
  749                   ; HL = Buffer address
  750                   ; E = Physical sector (1..n)
  751                   ; D = Track
  752                   ; C = Drive-code + Density + Side (REG4-Latch)
  753                   ;   7    6    5    4    3    2    1    0
  754                   ;   sso  mot  min  dens d    d    d    d
  755                   ;   sso  = seitenauswahl (0=side 0, 1=side 1)
  756                   ;   mot  = motor on code (std=0)
  757                   ;   min  = 1 bei Minilaufwerken
  758                   ;   dens = 1 bei Single Dense Aufzeichnung
  759                   ;   d = binary drive code
  760                   ;     normalerweise nur 1,2,4,8 moeglich
  761                   ;     Kombinationen moeglich, wenn binaere
  762                   ;     Dekodierung beim Laufwerk verwendet wird
  763                   ; B = 0 Set steprate and SSO-Flag
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  14
NMON    Z80

  764                   ;   = 1 Read sector
  765                   ;   = 2 Write sector
  766                   
