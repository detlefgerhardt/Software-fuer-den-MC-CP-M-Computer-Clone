  144                   ;------------------------------------------------------------------------------
  145                   
  146                   ; Addresses of IDE-80 CF-Adapter card
  147                   
  148         0018      IDEDATA	EQU 018h	; IDE Data Register
  149         001A      SECCND	EQU 01Ah	; Sector Count Register
  150         001B      LBA7	EQU 01Bh	; LBA Bits 0-7
  151         001C      LBA15	EQU 01Ch	; LBA Bits 8-15
  152         001D      LBA23	EQU 01Dh	; LBA Bits 16-23
  153         001E      IDEHEAD	EQU 01Eh	; IDE Drive Head Register
  154         001F      IDESTAT	EQU 01Fh	; IDE Command/Status Register
  155                   
  156                   ;------------------------------------------------------------------------------
  157                   
  158         0000      	ORG 0000h		; start address in ROM
  159                   
  160                   	; Copy Monitor from address ROMSTRT in ROM to address F000 in RAM
  161                   
  162 0000  31 FFFF     BEGIN:	LD SP,0FFFFh 		; set Stack to end of memory
  163 0003  3E C9       	LD A,0C9h 		; place RET command at F000h
  164 0005  32 F000     	LD (0F000h),A 		; 
  165 0008  CD F000     	CALL 0F000h 		; and call it
  166                   
  167 000B  3B          OFFS:	DEC SP  		; get return address from Stack to calculate
  168 000C  3B          	DEC SP  		; Monitor location in ROM
  169 000D  D1          	POP DE
  170 000E  21 0012     	LD HL,ROMSTRT-OFFS	; offset from BEG to ROMSTRT
  171 0011  19          	ADD HL,DE		; actual Montor address in ROM as source address in HL
  172 0012  11 F000     	LD DE,0F000h 		; dest address in DE
  173 0015  01 0FFF     	LD BC,0FFFh 		; length in BC (4KB - 1)
  174 0018  ED B0       	LDIR  			; copy
  175 001A  C3 F000     	JP 0F000h 		; jump to Monitor in RAM
  176                   
  177                   ;------------------------------------------------------------------------------
  178                   ; Start of Monitor program, ROM address 0F000h
  179                   
  180 001D              ROMSTRT:
  181                   	; Start address of Monitor in ROM
  182                   	; label must be located before .PHASE
"MC CPM-Computer Mon80V2"       			    Z80ASM 1.32 Page   4
