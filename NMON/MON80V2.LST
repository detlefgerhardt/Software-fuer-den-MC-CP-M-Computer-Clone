  997                   
  998 F307  AF          EXFL1:	XOR A
  999 F308  32 F401     	LD (ERRCNT),A 		; Fehlerzahl 0
 1000 F30B  79          	LD A,C
 1001 F30C  32 F402     	LD (DRVCOD),A 		; drive-code
 1002 F30F  E6 0F       	AND 0FH 		; in bit 0..3
 1003 F311  4F          	LD C,A
 1004 F312  3A F403     	LD A,(CURDRV)
 1005 F315  FE FF       	CP 0FFH 		; current drive invalid -> set
 1006 F317  28 14       	JR Z,EXFL2
 1007                   	
 1008                   	; check if drive change
 1009 F319  E6 0F       	AND 0FH 		; bit 0..3
 1010 F31B  B9          	CP C
