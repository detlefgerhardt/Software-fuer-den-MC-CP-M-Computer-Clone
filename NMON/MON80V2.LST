  183                   
  184                   	.PHASE 0F000H	; monitor start address in RAM
  185                   
  186 F000  C3 F071     	JP INIT
  187 F003  C3 F084     	JP CONIN	; Console In
  188 F006  C3 F097     	JP READIN	; Reader In (<- SIO B)
  189 F009  C3 F0AD     	JP CONOUT	; Console Out
  190 F00C  C3 F0C1     	JP PUNOUT	; Punch Out (-> SIO B)
  191 F00F  C3 F0D8     	JP LSTOUT	; List Out (-> SIO B)
  192 F012  C3 F0EF     	JP CONSTS	; Get console status, 0FFh in A, if character available
  193 F015  C3 F102     	JP IOGET	; Get iobyte, current configuration in A
  194 F018  C3 F106     	JP IOSET	; Set iobyte, new configuration in C
  195 F01B  C3 F10B     	JP MEMCHK	; High memory in B, low memory in A
  196                   
  197 F01E              TRAP:	; trap/breakpoint entry -> RSTRT
  198                   
  199 F01E  C3 F06E     	JP RSTRT
  200                   	
  201 F021  C3 F213     	JP FLOP	 	; new floppy interface rev 1.0 (used by BIOS 3.1)
  202                   	
  203         FFFF      	IF NOT DG01
  204 F024  C3 F1A9     	JP MAXI		; FLOPPY EXEC VEKTOR SOFT (old)
  205 F027  C3 F1E4     	JP MINI		; FLOPPY EXEC VEKTOR MINI (used by BIOS 3.1)
  206                   	ELSE
  209                   	ENDIF
  210                   	
  211 F02A  C3 F588     	JP IDERD	; Read IDE sector
  212 F02D  C3 F5C7     	JP IDEWR	; Write IDE Sector
  213 F030  C3 F6CA     	JP COLD		; Monitor Cold Start (no Hardware init)
  214 F033  C3 F6FB     	JP WARM		; Monitor Warm Start
  215 F036  C3 F074     	JP WRSTR	; gibt einen 0-terminierten String aus
  216                   
  217 F039  F13A        TABPTR:	DEFW TABSTART 	; Start of user jump table
  218 F03B  FE30        ENDPTR:	DEFW LASTMON 	; End address of Monitor
  219 F03D  F606        FREPTR:	DEFW FREEMEM 	; End of Monitor driver section. The area behind it can be overwritten by CP/M.
  220                   
  221                   	; Jump table for compatibility to FLOMON (NDR-Klein-Computer)
  222                   	
  223 F03F    000D      	DEFS 13 	; f033,34,35,36,37,38,39,3a,3b,3c,3d,3e,3f
  224                   			; BASIS F040h
  225 F04C  C3 F06A     	JP ILLEGAL 	; loeschen alle seiten
  226 F04F  C3 F06A     	JP ILLEGAL     	; loeschen unsichtbar
  227 F052  C3 F06A     	JP ILLEGAL 	; moveto hl=x de=y
  228 F055  C3 F06A     	JP ILLEGAL 	; drawto hl=x de=y
  229 F058  C3 F06A     	JP ILLEGAL 	; c=schreibseite 0,1,2,3
  230 F05B  C3 F06A     	JP ILLEGAL 	; c=leseseite    0,1,2,3
  231 F05E  C3 F06A     	JP ILLEGAL      ; c=rmwmode      0=norm 1=rmw
  232 F061  C3 F06A     	JP ILLEGAL 	; warten bis gdp fertig
  233 F064  C3 F06A     	JP ILLEGAL      ; c=befehl fuer gdp  ACHTUNG in C-Register nicht A
  234 F067  C3 F06A     	JP ILLEGAL 	; hl=quelle,de=ziel,c=bank quelle, b=bank ziel
  235                   			; carry wenn bankram auf f000h nicht da ist
  236                   
  237                   ; End of area of tables and fixed addresses, that are used by CP/M BIOS, UFORMAT etc.
