 1071 F378  3A F402     	LD A,(DRVCOD)
 1072 F37B  4F          	LD C,A
 1073 F37C  CD F3F0     	CALL EXSEEK 		; und Track anfahren Reg retten
 1074 F37F  E6 90       	AND 10010000B 		; Fehlermaske
 1075 F381  28 1F       	JR Z,EXFL9 		; -> ja dann R/W moeglich
 1076                   	
 1077 F383              EXFL7:	; Laufwerk normieren und RSTORE
 1078 F383  3A F402     	LD A,(DRVCOD)
 1079 F386  4F          	LD C,A
 1080 F387  E5          	PUSH HL
 1081 F388  D5          	PUSH DE
 1082 F389  C5          	PUSH BC
 1083 F38A  CD F2EA     	CALL RSTORE		; track 0
 1084 F38D  C1          	POP BC
 1085 F38E  D1          	POP DE
 1086 F38F  E1          	POP HL
 1087 F390  3A F401     	LD A,(ERRCNT) 		; Fehler erhoehen
 1088 F393  3C          	INC A
 1089 F394  32 F401     	LD (ERRCNT),A
 1090 F397  FE 0A       	CP 10  			; bei 10 Fatal-Fehler
