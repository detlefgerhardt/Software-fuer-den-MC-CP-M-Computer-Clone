 1055 F361  3A F402     	LD A,(DRVCOD)
 1056 F364  4F          	LD C,A
 1057 F365  CD F3F0     	CALL EXSEEK 		; seek select dummy nur fuer ready-test
 1058 F368  DB C0       	IN A,(FLO)		; test Status
