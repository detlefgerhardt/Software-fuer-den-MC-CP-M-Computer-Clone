  558                   ;------------------------------------------------------------------------------
  559                   
  560                   ; Floppy Interface Paket Rev 1.0   841031
  561                   ; (C) 1984 Muenchen, Rolf-Dieter Klein
  562                   
  563                   ; Routinen fuer MC-Kompatibilitaet
  564                   ; wie floppy, jedoch Drive-Codierung anders
  565                   ; nur fuer bestehende BIOS-Routinen gedacht
  566                    
  567                   ; bei Maxi wird die Seite 1 mit Seitenpruefung auf 0
  568                   ; angesprochen, bei Mini mit Seitenpruefung auf 1.
  569                   ; nur fuer SD
  570                   
  571                   ; c=0,1,2,3
  572                   ; 	0,2 gekoppelt  1,3 gekoppelt					
  573                   
  574 F1A9  CD F1AF     MAXI:	CALL SCODA	; coding 1
  575 F1AC  C3 F213     	JP FLOP		; sso-flag auf 0 setzen, jedoch stepflag
  576                   			; gueltig wenn bit 7 gesetzt.
  577                   
  578                   ;------------------------------------------------------------------------------
  579                   ; Maxi Disk recoding of drive and side for Special Register 4
  580                   ; 0 -> 11 (drive 1, side 0, Maxi)
  581                   ; 1 -> 91 (drive 1, side 1, Maxi)
  582                   ; 2 -> 12 (drive 2, side 0, Maxi)
  583                   ; 3 -> 92 (drive 2, side 1, Maxi)
  584                   
  585 F1AF  79          SCODA:	LD A,C  	; SD MAXI
  586 F1B0  E6 03       	AND 3  		; muss Bereich 0..3 sein
  587 F1B2  FE 00       	CP 0  		; 0 seite 0
  588 F1B4  20 03       	JR NZ,SCODA1
  589                   	
  590 F1B6  0E 11       	LD C,00010001B 	; LW 1
"MC CPM-Computer Mon80V2"       			    Z80ASM 1.32 Page  11
MON80V2 Z80

  591 F1B8  C9          	RET
  592                   
  593 F1B9  FE 01       SCODA1:	CP 1
  594 F1BB  20 03       	JR NZ,SCODA2
  595                   	
  596 F1BD  0E 12       	LD C,00010010B 	; LW 2 seite 0
  597 F1BF  C9          	RET
  598                   
  599 F1C0  FE 02       SCODA2:	CP 2
  600 F1C2  20 03       	JR NZ,SCODA3
  601                   	
  602 F1C4  0E 91       	LD C,10010001B 	; LW 1 seite 1
  603 F1C6  C9          	RET
  604                   
  605 F1C7  0E 92       SCODA3:	LD C,10010010B 	; LW 2 seite 1
  606 F1C9  C9          	RET
  607                   
  608                   ;------------------------------------------------------------------------------
  609                   ; Mini Disk recoding of drive and side for Special Register 4
  610                   ; 0 -> 01 (drive 1, side 0, Mini)
  611                   ; 1 -> 81 (drive 1, side 1, Mini)
  612                   ; 2 -> 02 (drive 2, side 0, Mini)
  613                   ; 3 -> 82 (drive 2, side 1, Mini)
  614                   
  615                   ; hier ist eine Erweiterung fuer Laufwerke C und D notwendig
  616                   
  617 F1CA  E6 03       SCODB:	AND 3  		; 0,1,2,3 erlaubt
  618 F1CC  FE 00       	CP 0
  619 F1CE  20 03       	JR NZ,SCODB1
  620                   	
  621 F1D0  0E 01       	LD C,00000001B 	; LW 1 seite 0
  622 F1D2  C9          	RET
  623                   
  624 F1D3  FE 01       SCODB1:	CP 1
  625 F1D5  20 03       	JR NZ,SCODB2
  626                   	
  627 F1D7  0E 81       	LD C,10000001B 	; LW 1 seite 1
  628 F1D9  C9          	RET
  629                   
  630 F1DA  FE 02       SCODB2:	CP 2
  631 F1DC  20 03       	JR NZ,SCODB3
  632                   	
  633 F1DE  0E 02       	LD C,00000010B 	; LW 2 seite 0
  634 F1E0  C9          	RET
  635                   
  636 F1E1  0E 82       SCODB3:	LD C,10000010B 	; LW 2 seite 1 
  637 F1E3  C9          	RET
