 1263 F5BD  77          	LD	(HL),A
 1264 F5BE  23          	INC	HL
 1265 F5BF  DB 1F       	IN	A,(IDESTAT)	; check status
 1266 F5C1  E6 08       	AND	08H		; DRQ bit
 1267 F5C3  C2 F5BB     	JP	NZ,IDERD5	; loop until cleared
 1268                   	
 1269 F5C6  C9          	RET
