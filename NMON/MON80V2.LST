 1218                   ; IDE/CF card interface
 1219                   ;
 1220                   ; Read one IDE/CF card sector (256 bytes)
 1221                   ;
 1222                   ; Address for data in HL
 1223                   ; LBA bits 0 to 7 passed in C
 1224                   ; LBA bits 8 to 15 passed in B
 1225                   ; LBA bits 16 to 23 passed in E
 1226                   
 1227 F588              IDERD:
 1228 F588  DB 1F       IDERD1:	IN	A,(IDESTAT)	; check status
"MC CPM-Computer Mon80V2"       			    Z80ASM 1.32 Page  22
MON80V2 Z80

 1229 F58A  E6 80       	AND	80H		; check BSY bit
 1230 F58C  C2 F588     	JP	NZ,IDERD1	; loop until not busy
 1231                   
 1232 F58F  DB 1F       IDERD2:	IN	A,(IDESTAT)	; check	status
 1233 F591  E6 40       	AND	40H		; check DRDY bit
 1234 F593  CA F58F     	JP	Z,IDERD2	; loop until ready
 1235                   
 1236 F596  3E 01       	LD	A,01H		; number of sectors = 1
 1237 F598  D3 1A       	OUT	(SECCND),A	; sector count register
 1238 F59A  79          	LD	A,C
 1239 F59B  D3 1B       	OUT	(LBA7),A	; lba bits 0 - 7
 1240 F59D  78          	LD	A,B
 1241 F59E  D3 1C       	OUT	(LBA15),A	; lba bits 8 - 15
 1242 F5A0  7B          	LD	A,E
 1243 F5A1  D3 1D       	OUT	(LBA23),A	; lba bits 16 - 23
 1244 F5A3  3E E0       	LD	A,11100000B	; LBA mode, select drive 0
 1245 F5A5  D3 1E       	OUT	(IDEHEAD),A	; drive/head register
 1246 F5A7  3E 20       	LD	A,20H		; Read sector command
 1247 F5A9  D3 1F       	OUT	(IDESTAT),A
 1248                   
 1249 F5AB              IDERD3:	; wait for drq set
 1250 F5AB  DB 1F       	IN	A,(IDESTAT)	; read status
 1251 F5AD  E6 08       	AND	08H		; DRQ bit
 1252 F5AF  CA F5AB     	JP	Z,IDERD3	; loop until bit set
 1253                   	
 1254 F5B2              IDERD4:	; wait for busy clear
 1255 F5B2  DB 1F       	IN	A,(IDESTAT)
 1256 F5B4  E6 80       	AND	80H
 1257 F5B6  C2 F5B2     	JP	NZ,IDERD4
 1258                   	
 1259 F5B9  DB 1F       	IN	A,(IDESTAT)	; clear INTRQ
 1260                   
