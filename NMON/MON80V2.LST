 1012                   
 1013 F31F  E5          	PUSH HL
 1014 F320  C5          	PUSH BC
 1015 F321  21 F404     	LD HL,DRVTAB 		; Basisadresse
 1016 F324  4F          	LD C,A
 1017 F325  06 00       	LD B,0  		; alten Laufwerktrack merken
 1018 F327  09          	ADD HL,BC
 1019 F328  DB C1       	IN A,(FLO+1) 		; Tracknr
 1020 F32A  77          	LD (HL),A 		; und dort ablegen
 1021 F32B  C1          	POP BC
 1022 F32C  E1          	POP HL
 1023                   
 1024 F32D  E5          EXFL2:	PUSH HL
 1025 F32E  C5          	PUSH BC
 1026 F32F  3A F402     	LD A,(DRVCOD) 		; neues Laufwerk
 1027 F332  E6 0F       	AND 0FH 		; nur Laufwerkscode
 1028 F334  4F          	LD C,A
 1029 F335  06 00       	LD B,0
 1030 F337  21 F404     	LD HL,DRVTAB 		; Tabellenstart
 1031 F33A  09          	ADD HL,BC 		; HL zeigt auf Laufwerkstrack
 1032 F33B  7E          	LD A,(HL)
 1033 F33C  D3 C1       	OUT (FLO+1),A 		; und ins Register des FDs
 1034 F33E  C1          	POP BC
 1035 F33F  E1          	POP HL
 1036 F340  3A F402     	LD A,(DRVCOD)
 1037 F343  32 F403     	LD (CURDRV),A 		; ist nun neues Laufwerk
 1038 F346  C5          	PUSH BC
 1039 F347  01 00FA     	LD BC,1000*3/12		; ca 1ms warten
 1040 F34A  CD F2CC     	CALL DELAY
 1041 F34D  3A F402     	LD A,(DRVCOD) 		; Dann neues Laufwerk ansprechen
 1042 F350  D3 C4       	OUT (FLO+4),A		; -> REG4-Latch
 1043 F352  01 0B65     	LD BC,2917		; ca 35ms .. 15ms
 1044 F355  CD F2CC     	CALL DELAY		; um headload-Zeit zu beruecksichtigen 
 1045 F358  C1          	POP BC  		; alte Codes zurueck
 1046 F359  18 06       	JR EXFL4 		; Immer auf ready pruefen, da
 1047                   				; head down sein kann und dennoch nicht ready
 1048                   
 1049 F35B              EXFL3:	; seek only
 1050 F35B  DB C4       	IN A,(FLO+4)
 1051 F35D  E6 20       	AND 20H
 1052 F35F  20 0D       	JR NZ,EXFL5		; -> head down, no dummy seek
 1053                   
 1054 F361              EXFL4:	; repeat seek command (ready test only)
"MC CPM-Computer Mon80V2"       			    Z80ASM 1.32 Page  19
