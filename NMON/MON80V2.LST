    2                   	
    3                   	.Z80
    4                   ;---------------------------------------------------------------
    5                   ; Monitor fuer MC-Computer Platine SYS-80 und SYS-80s
    6                   ; Assembliert mit Z80ASM von SLR Systems wegen der langen
    7                   ; Label die mit einigen anderen Assemblern nicht moeglich sind.
    8                   ;
    9                   ; Erstellt 05/2026 von U. Haumann
   10                   ; Enthaelt weitgehend Routinen aus RDK Monitor 1.1 850129
   11                   ; V7.2 851216, sowie Teile aus dem Monitor von Donn Stewart 
   12                   ; fuer den "CPU-Ville" Z80 Computer.
   13                   ; Treiber fuer Serielle Schnittstelle auf CPU-Platine mit UART 8251
   14                   ; implementiert.
   15                   ; Flo1 und Flo2 waehlber auf Hardware Basis Adresse 0C0h.
   16                   ; Der Mointor erwartet 64KB Ram Memory. Er darf selbst nicht
   17                   ; groesser als 4KB werden, es sein denn man schiebt die MON_ADR
   18                   ; und CCP weiter nach unten. Der CPM Bereich verkleinert sich dann.
   19                   ; Der Monitor kopiert sich nach Reset an das Speicherende
   20                   ; auf den Wert in MON_ADR und gibt den unteren RAM Bereich frei.
   21                   ; Dies wird auf der SYS CPU Platine mit einem Lesebefehl auf
   22                   ; Adresse 7000h erreicht. Das Eprom ist dann ausgeblendet.
   23                   ; Somit steht der Speicher durchgaengig ab 0000h bis zu MON_ADR
   24                   ; zur Verfuehgung.
   25                   ; Das CPM BIOS fuer den MC-Computer ueberschreibt den Monitorbereich
   26                   ; ab FC00h. Alle relevanten Teile fuer den Betrieb des Rechners 
   27                   ; muessen vor FC00h plaziert werden.
   28                   ; Ergaenzung: Das betrifft alle Teile des interaktiven Monitors, der
   29                   ; dann nicht mehr funktionsfaehig ist. Funktionsfaehig bleiben nur
   30                   ; die Ein-/Ausgabe-Routinen und die Floppy-Routinen, die vom BIOS
   31                   ; benoetigt werden.
   32                   
   33                   ; 07/2026 Ueberarbeitet von Detlef Gerhardt
   34                   ; komplette Ueberarbeitung der Labels und sukzessive Kommentierung des Quellcodes
   35                   ; um nach und nach moeglichst viele Routinen zu verstehen.
   36                   ; Diese Version ist bis auf die Versionsnummer noch binaerkompatibel zu Version 8.0v1
   37                   ; --- Work in progress ---
   38                   
   39                   ;------------------------------------------------------------------------------
   40                   ; Mapping of REG4-Latch
   41                   
   42                   ; write
   43                   ; Bit0 = Drive Select 1
   44                   ; Bit1 = Drive Select 1
   45                   ; Bit2 = Drive Select 3
   46                   ; Bit3 = Drive Select 4
   47                   ; Bit4 = FDC9239 Dens (0=DD, 1=SS)
   48                   ; Bit5 = FDC9239 Mini (0=Maxi, 1=Mini)
   49                   ; Bit6 = Motor On (Jumper) (0=Motor on, 1=Motor off)
   50                   ; Bit7 = Side Select (Jumper) (0=Side 0, 1=Side 1)
   51                   
   52                   ; read
   53                   ; Bit5 = Headload Status (0=head loaded, 1=head unloaded)
   54                   ; Bit6 = FD197x INTREQ (0=not active, 1=active)
   55                   ; Bit7 = FD197x DRQ (0=not active, 1=actice)
   56                   
   57                   ;------------------------------------------------------------------------------
   58                   ; Constants
   59                   
"MC CPM-Computer Mon80V2"       			    Z80ASM 1.32 Page   2
MON80V2 Z80

   60         0000      FALSE	EQU 0
   61         FFFF      TRUE	EQU NOT FALSE
   62         000D      CR 	EQU 0DH		; carriage return
   63         000A      LF 	EQU 0AH		; line feed
   64         0007      BELL	EQU 07H		; bell
   65         00FF      RUB 	EQU 0FFH	; rub out
   66                   ;FIL 	EQU 0
   67                   ;MAX	EQU 7
   68         001B      ESC	EQU 1BH
   69                   
   70         0038      RST7	EQU 38H		; der Vektor RST7 wird fuer Breakpoints gebraucht
   71                   
   72                   ;------------------------------------------------------------------------------
   73                   ; Variant switches
   74                   
   75         0015      VERSION	EQU 21
   76                   
   77                   ; aktiviert alle bisherigen Aenderungen gegenueber der Originalversion 7.x
   78         0000      DG01	EQU FALSE
   79                   
   80                   ; 3 Mini drives (A..C), 1 Maxi drives (D), 1 RAM-Disk (E)
   81         0000      MINI3	EQU FALSE
   82                   
   83                   ; version for CPU80/S with UART 8251
   84         FFFF      SYS80S	EQU TRUE
   85                   
   86                   ;------------------------------------------------------------------------------
   87                   ; I/O addresses
   88                   
   89                   ; SYS80S = TRUE:  serial port of SYS-80S card ist used for console
   90                   ; SYS80S = FALSE: serial port SIO A at OUT-80 card is used for console
   91                   
   92                   ; OUT-80 card SIO B is used for reader, punch and lister
   93                   
   94                   ; Addresses of serial port UART 8251 at SYS-80s CPU card
   95         0020      SU_DAT	EQU 020H	; UART 8251 Daten
   96         0021      SU_STS	EQU 021H	; UART 8251 Control
   97         0002      SU_RXB	EQU 002h	; RX Ready Bit UART 8251
   98         0001      SU_TXB	EQU 001h	; TX Ready Bit UART 8251
   99                   
  100                   ; Addresses of serial port MC Computer OUT-80 card with SIO
  101         00F0      SA_DAT	EQU 0F0H	; SIO A Daten
  102         00F1      SA_STS	EQU 0F1H	; SIO A Control
  103         00F2      SB_DAT	EQU 0F2H	; SIO B Daten
  104         00F3      SB_STS	EQU 0F3H	; SIO B Control
  105         0001      SI_RXB	EQU 01h		; SIO RX Ready Bit
  106         0004      SI_TXB	EQU 04h		; SIO TX Ready Bit
  107                   
  108         FFFF      	IF SYS80S
  109                   
  110                   ; Console is redirected to UART on SYS-80s
  111         0020      CO_DAT	EQU SU_DAT
  112         0021      CO_STS	EQU SU_STS
  113         0002      CO_RXB	EQU SU_RXB
  114         0001      CO_TXB	EQU SU_TXB
  115                   
  116                   	ELSE
  124                   	ENDIF
