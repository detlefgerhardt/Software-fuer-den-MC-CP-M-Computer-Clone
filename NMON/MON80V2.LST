 1063 F36E  DB C1       	IN A,(FLO+1) 		; nun pruefen ob Tracks gleich sind
 1064 F370  FE FF       	CP 0FFH 		; nicht definiert
 1065 F372  28 0F       	JR Z,EXFL7 		; dann zuerst RESTORE
 1066                   
 1067 F374  BA          	CP D  			; oder schon auf dem Track
