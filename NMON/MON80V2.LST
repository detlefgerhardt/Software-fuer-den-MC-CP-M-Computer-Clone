  682                   ;==============================================================================
  683                   ; Floppy-Unterprogramme fuer FLO2
  684                   ; verwendet 1797 als Controller
  685                   ; Version 1.0   840506
  686                   ; Rolf-Dieter Klein (C) 1984 Muenchen
  687                   ;
  688                   ; Die Routinen ermoeglichen sowohl den Anschluss von Mini-,Mikro- als auch
  689                   ; von Maxi-Laufwerken. Die Routinen muessen im RAM stehen, da die Buffer
  690                   ; am Ende stehen. Alle Buffer sind jedoch gesammelt.
  691                   
  692                   ; FLO4    als Leseport
  693                   ;
  694                   ; 7 6 5 4 3 2 1 0
  695                   ;
  696                   ; DRQ   INTRQ   headld x      x x x x
  697                   ; 0=request
  698                   ;      0=request
  699                   ;  1=head down
  700                   ;
  701                   
  702                   ; FLO4    als Schreibport
  703                   ;
  704                   ; 7 6 5 4 3 2 1 0
  705                   ;
  706                   ; sso moton mini dense d c b a
"MC CPM-Computer Mon80V2"       			    Z80ASM 1.32 Page  13
MON80V2 Z80

  707                   ;
  708                   ; 1=Seite 1
  709                   ; 0=Motor an
  710                   ;  1=Minilaufwerk
  711                   ;   1=Single Dense
  712                   ;    -------------------------
  713                   ;      1=Laufwerk an
  714                   
  715         00C0      FLO	EQU 0C0H 		; Basisadresse Floppy-Controller
  716                   ;FLO0	EQU 0C0H   	
  717                   ;FLO1	EQU 0C1H
  718                   ;FLO2	EQU 0C2H
  719                   ;FLO3	EQU 0C3H
  720                   ;FLO4	EQU 0C4H 		; Port fuer Zusatzstatus etc.
  721                   				; write REG4-Latch
  722                   				; read REG4-Status
  723                   
  724                   ;------------------------------------------------------------------------------
  725                   ; Bei einem Interrupt wird an diese Stelle gesprungen
  726                   ; Der Interrupt erfolgt vom Floppy-Controller
  727                   
  728 F202              INTEX:	; Das INT-Program arbeitet nicht als Unterprogramm
  729 F202  F1          	POP AF  		; alte Ret-Adresse vernichten
  730 F203  DB C0       	IN A,(FLO) 		; Status lesen und INT loeschen
  731 F205  FB          	EI  			; Interrupt wieder freigeben
  732 F206  ED 4D       	RETI  			; zurueck zum vorherigen Aufrufer
  733                   
  734                   ;------------------------------------------------------------------------------
  735                   ; Floppy Routinen Init
  736                   
  737 F208  3E 02       INIFLP:	LD A,2  		; 3 = langsamste Steprate, kein SSO
  738 F20A  32 F3FA     	LD (STEPRATE),A
  739                   	
  740 F20D  3E FF       	LD A,0FFH
  741 F20F  32 F403     	LD (CURDRV),A 		; no current drive
  742 F212  C9          	RET 
  743                   
  744                   ;------------------------------------------------------------------------------
  745                   
  746         0038      INTVEK	EQU 38h 		; Interruptziel
  747                   
  748                   ;------------------------------------------------------------------------------
  749                   ; Haupteingang der Floppy-Routinen
  750                   ; HL = Buffer address
  751                   ; E = Physical sector (1..n)
  752                   ; D = Track
  753                   ; C = Drive-code + Density + Side (REG4-Latch)
  754                   ;   7    6    5    4    3    2    1    0
  755                   ;   sso  mot  min  dens d    d    d    d
  756                   ;   sso  = seitenauswahl (0=side 0, 1=side 1)
  757                   ;   mot  = motor on code (std=0)
  758                   ;   min  = 1 bei Minilaufwerken
  759                   ;   dens = 1 bei Single Dense Aufzeichnung
  760                   ;   d = binary drive code
  761                   ;     normalerweise nur 1,2,4,8 moeglich
  762                   ;     Kombinationen moeglich, wenn binaere
  763                   ;     Dekodierung beim Laufwerk verwendet wird
  764                   ; B = 0 Set steprate and SSO-Flag
"MC CPM-Computer Mon80V2"       			    Z80ASM 1.32 Page  14
MON80V2 Z80

  765                   ;   = 1 Read sector
  766                   ;   = 2 Write sector
  767                   
  768                   ; Entry SSO = 0
  769                   
  770 F213  AF          FLOP:	XOR A  			; SSO-Flag auf 0 setzen
  771                   
  772                   ; Entry SSO in A
  773                   ; called only from old MINI routine
  774                   
  775 F214              FLOP1:	; SSO flag in A, only 0 and 2 allowed
  776 F214  32 F3FB     	LD (SSOFLAG),A
  777                   
  778 F217  F5          	PUSH AF
  779 F218  3A F587     	LD A,(FLOTYP)
  780 F21B  FE 01       	CP 1  
  781 F21D  C2 F226     	JP NZ,FLOP2		; -> FLO2
  782                   	
  783                   	; FLO1
  784 F220  79          	LD A,C
  785 F221  E6 BF       	AND 10111111B 		; kein autowait 
  786 F223  EE 10       	XOR 10H 		; invertieren Dichtebit fuer FLO1
  787 F225  4F          	LD C,A
  788                   
  789 F226  F1          FLOP2:	POP AF
  790 F227  ED 73 F3FC  	LD (SP0),SP 		; save user-stack, maybe to deep for BDOS
  791 F22B  31 F478     	LD SP,TSTACK 		;
  792                   
  793 F22E  3E D0       	LD A,11010000B		; Command "Force interrupt"
  794 F230  D3 C0       	OUT (FLO),A 		; reset floppy controller
  795                   	
  796                   	; set interrupt vector to INTEX
  797 F232  3A 0038     	LD A,(INTVEK)
  798 F235  32 F3FE     	LD (SAVINT),A
  799 F238  3E C3       	LD A,0C3H 		; JP-Befehl
  800 F23A  32 0038     	LD (INTVEK),A
  801 F23D  E5          	PUSH HL
  802 F23E  2A 0039     	LD HL,(INTVEK+1)
  803 F241  22 F3FF     	LD (SAVINT+1),HL
  804 F244  21 F202     	LD HL,INTEX 		; set to JP INTEX
  805 F247  22 0039     	LD (INTVEK+1),HL
  806 F24A  E1          	POP HL
  807                   	
  808 F24B  DB C0       	IN A,(FLO)		; Status - Port
  809 F24D  ED 56       	IM 1  			; set interrupt mode 1 ->  execure at 38h
  810 F24F  FB          	EI  			; Interrupt freigeben
  811 F250  CD F2FB     	CALL EXFLO
  812 F253  F3          	DI  			; disable interrupt
  813                   	
  814                   	; restore interrupt vector
  815 F254  F5          	PUSH AF 		; Status
  816 F255  3A F3FE     	LD A,(SAVINT)
  817 F258  32 0038     	LD (INTVEK),A 		; zurueckspeichern
  818 F25B  E5          	PUSH HL
  819 F25C  2A F3FF     	LD HL,(SAVINT+1)
  820 F25F  22 0039     	LD (INTVEK+1),HL
  821 F262  E1          	POP HL
  822 F263  F1          	POP AF
"MC CPM-Computer Mon80V2"       			    Z80ASM 1.32 Page  15
MON80V2 Z80

  823                   	
  824 F264  ED 7B F3FC  	LD SP,(SP0) 		; restore user-stack
  825 F268  C9          	RET
  826                   
  827                   ;------------------------------------------------------------------------------
  828                   ; Diverse Unterprogramme
  829                   ;------------------------------------------------------------------------------
  830                   ; Prepare command byte for floppy controller
  831                   
  832 F269              SETCMD:				; testet ob der Kopf noch
  833                   				; geladen ist und setzt die
  834 F269  06 00       	LD B,0  		; Flag fuer SSO-Bit
  835 F26B  3A F402     	LD A,(DRVCOD) 		; wenn Bit 7 gesetzt, dann abfragen
  836 F26E  E6 80       	AND 80H
  837 F270  28 11       	JR Z,SETC2 		; Seite 0, immer mit SSO=0
  838                   	
  839 F272  3A F3FA     	LD A,(STEPRATE) 	; jetzt pruefen ob flags da
  840 F275  E6 80       	AND 80H 		; <>0, dann SSO setzen, wenn seite 1
  841 F277  28 04       	JR Z,SETC1 		; =0, dann code 0, oder SSOFLAG
  842                   	
  843 F279  06 02       	LD B,2  		; SSO setzen 
  844 F27B  18 06       	JR SETC2
  845                   
  846 F27D              SETC1:	; pruefen ob SSO-Flag
  847 F27D  3A F3FB     	LD A,(SSOFLAG) 		; ok, 2=Flag
  848 F280  E6 02       	AND 2  			; SSO-Bit
  849 F282  47          	LD B,A  		; 0,2 erlaubt 
  850                   
  851 F283              SETC2:	; entsprechenden Bits
  852 F283  DB C4       	IN A,(FLO+4) 		; REG4-Status
  853 F285  E6 20       	AND 20H 		; Head-Load Bit
  854 F287  20 04       	JR NZ,SETC3 		; =1 dann Kopf auf Diskette
  855                   	
  856 F289  78          	LD A,B
  857 F28A  F6 04       	OR 04h 			; sonst Bitmaske fuer headdown
  858 F28C  C9          	RET
  859                   
  860 F28D              SETC3:	; noset
  861 F28D  78          	LD A,B
  862 F28E  C9          	RET 			; Code belassen
  863                   
  864                   ;------------------------------------------------------------------------------
  865                   ; Read one sector
  866                   ; sector number in E
  867                   ; buffer addr in HL
  868                   
  869 F28F  79          RDFLP:	LD A,C
  870 F290  D3 C4       	OUT (FLO+4),A 		; density + side -> REG4-Latch
  871 F292  7B          	LD A,E
  872 F293  D3 C2       	OUT (FLO+2),A 		; ins Sektorregister
  873 F295  0E C3       	LD C,FLO+3 		; Adresse Datenport dann nach C
  874 F297  CD F269     	CALL SETCMD 		; Register A vorbereiten
  875 F29A  C6 88       	ADD A,10001000B		; Command "Read Sector", without SSO
  876 F29C  D3 C0       	OUT (FLO),A 		; Befehl ausfuehren
  877                   
  878 F29E              RDFLP1:	; wait for DRQ = 1
  879 F29E  DB C4       	IN A,(FLO+4) 		; DRQ schon da ?
  880 F2A0  07          	RLCA  			; bit7 = DRQ, bit6 = int
"MC CPM-Computer Mon80V2"       			    Z80ASM 1.32 Page  16
MON80V2 Z80

  881 F2A1  D2 F29E     	JP NC,RDFLP1 		; -> DRQ = 0
  882                   	
  883 F2A4  ED A2       	INI  			; IN (C) -> (HL), HL++, B--
  884 F2A6  C3 F29E     	JP RDFLP1  		; verlassen nur durch INT
  885                   
  886                   ;------------------------------------------------------------------------------
  887                   ; Write one sector
  888                   
  889 F2A9  79          WRFLP:	LD A,C
  890 F2AA  D3 C4       	OUT (FLO+4),A 		; density + side -> REG4-Latch
  891 F2AC  7B          	LD A,E  		; Sektorregister setzen
  892 F2AD  D3 C2       	OUT (FLO+2),A
  893 F2AF  0E C3       	LD C,FLO+3		; Adresse Datenport laden
  894 F2B1  CD F269     	CALL SETCMD		; E-Code in A laden
  895 F2B4  C6 A8       	ADD A,0A8H		; Befehl Schreibe-Sektor
  896 F2B6  D3 C0       	OUT (FLO),A 		; und Befehl ausfuehren
  897                   
  898 F2B8              WRFLP1:	; wait for DRQ = 1
  899 F2B8  DB C4       	IN A,(FLO+4) 		; DRQ schon da ?
  900 F2BA  07          	RLCA  			; bit7 = DRQ, bit6 = int
  901 F2BB  D2 F2B8     	JP NC,WRFLP1
  902                   	
  903 F2BE  ED A3       	OUTI  			; (HL) -> OUT (C), HL++, B--
  904 F2C0  C3 F2B8     	JP WRFLP1  		; verlassen nur durch INT
  905                   
  906                   ;------------------------------------------------------------------------------
  907                   ; delay: 4 ms at 4 MHz
  908                   
  909 F2C3  C5          WAWA:	PUSH BC 		; pro Schleife ca 6us bei 4MHz
  910 F2C4  01 01F4     	LD BC,500 		; 500*6us Dauer
  911 F2C7  CD F2CC     	CALL DELAY
  912 F2CA  C1          	POP BC
  913 F2CB  C9          	RET
  914                   
  915                   ;------------------------------------------------------------------------------
  916                   ; delay: 6 microseconds at 4 MHz
  917                   
  918 F2CC  0B          DELAY:	DEC BC
  919 F2CD  78          	LD A,B
  920 F2CE  B1          	OR C
  921 F2CF  C2 F2CC     	JP NZ,DELAY
  922                   	
  923 F2D2  C9          	RET
  924                   
  925                   ;------------------------------------------------------------------------------
  926                   ; Seek to track
  927                   ; C=Drive D=Track E=Sector
  928                   
  929 F2D3  CD F2C3     SEEK:	CALL WAWA 		; short delay (4 ms)
  930                   
  931 F2D6  79          	LD A,C
  932 F2D7  D3 C4       	OUT (FLO+4),A 		; drive code, density and side -> REG4-Latch
  933 F2D9  7B          	LD A,E
  934 F2DA  D3 C2       	OUT (FLO+2),A 		; Sector
  935 F2DC  7A          	LD A,D
  936 F2DD  D3 C3       	OUT (FLO+3),A 		; track
  937 F2DF  06 1C       	LD B,1CH 		; seek command
  938 F2E1  3A F3FA     	LD A,(STEPRATE)
"MC CPM-Computer Mon80V2"       			    Z80ASM 1.32 Page  17
MON80V2 Z80

  939 F2E4  E6 03       	AND 3  			; 0,1,2,3 zulaessig
  940 F2E6  B0          	OR B  			; 
  941 F2E7  D3 C0       	OUT (FLO),A 		; execute Seek together with steprate
  942                   
  943 F2E9  76          	HALT  			; wait for INT
  944                   
  945                   ;------------------------------------------------------------------------------
  946                   ; Kopf auf Spur 0 stellen
  947                   			
  948 F2EA  CD F2C3     RSTORE:	CALL WAWA		; short delay (4 ms)
  949                   
  950 F2ED  79          	LD A,C  		; Laufwerkscode (drive)
  951 F2EE  D3 C4       	OUT (FLO+4),A 		; mit Dichtecode etc. ausgeben -> REG4-Latch
  952                   
  953                   	; Command "Restore" 0000hvrr, h=head load, v=verify, rr=steprate
  954 F2F0  06 08       	LD B,00001000B 		; only head load, no verify
  955 F2F2  3A F3FA     	LD A,(STEPRATE)
  956 F2F5  E6 03       	AND 3  			; 0..3
  957 F2F7  B0          	OR B  			; als Befehl kombiniert
  958 F2F8  D3 C0       	OUT (FLO),A 		; und ausfuehren
  959                   
  960 F2FA  76          	HALT  			; wait for INT
  961                   
  962                   ;------------------------------------------------------------------------------
  963                   ; Floppy Kernal Routines
  964                   
  965                   ; HL = buffer address
  966                   ; D = track (0..?) or parameter for set steprate
  967                   ; E = sector (1..n)
  968                   ; B = command (0=set steprate+SSO, 1=read, 2=write)
  969                   ; C = drive code
  970                   ;   REG4-Latch format
  971                   ;   7   6   5   4   3   2   1   0
  972                   ;   sid mot min den d   d   d   d
  973                   ;   sid: 0=side, 1=side1
  974                   ;   mot: motor on code (std=0)
  975                   ;   min: 0=maxi drive, 1=mini drive
  976                   ;   den: 0=dd, 1=ss
  977                   ;   d=binary drive code
  978                   ;     normalerweise nur 1,2,4,8 moeglich
  979                   ;     Kombinationen moeglich, wenn binaere
  980                   ;     Dekodierung beim Laufwerk verwendet wird
  981                   
  982 F2FB  78          EXFLO:	LD A,B			; B = command
  983 F2FC  B7          	OR A
  984 F2FD  20 08       	JR NZ,EXFL1
  985                   
  986                   	;---------------------------------------------------------------------
  987                   	; B=0: set steprate and SSO
  988                   	; steprate in D, Bit0/1=steprate, bit7=SSO
  989                   	
  990 F2FF  7A          	LD A,D   		; (+80h =SSO verwenden und pruefen).
  991 F300  E6 83       	AND 83h  		; Bit 7=SSO-Flag bei Zugriffen wichtig
  992 F302  32 F3FA     	LD (STEPRATE),A		; die die zweite Seite verwenden.
  993 F305  AF          	XOR A
  994 F306  C9          	RET
  995                   
  996                   	;---------------------------------------------------------------------
