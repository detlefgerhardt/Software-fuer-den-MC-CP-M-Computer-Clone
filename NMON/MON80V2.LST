 1092                   
 1093 F39B              EXFL8:	; fatal error
 1094 F39B  3E FF       	LD A,0FFH
 1095 F39D  B7          	OR A
 1096 F39E  37          	SCF  			; A=0ffh, carry as error flag
 1097 F39F  C9          	RET  			; ABBRUCH FATAL
 1098                   
 1099 F3A0              NOERR:	; exit without error
 1100 F3A0  AF          	XOR A
 1101 F3A1  C9          	RET
