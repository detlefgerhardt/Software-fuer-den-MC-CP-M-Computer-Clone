  253                   ;==============================================================================
  254                   ; IO Routines
  255                   ;==============================================================================
  256                   ; Output 0-terminated string, address in HL
  257                   
  258 F074  DB 21       WRSTR:	IN  A,(CO_STS)	; read status
  259 F076  E6 01       	AND CO_TXB	; check TxRDY bit
  260 F078  CA F074     	JP Z,WRSTR	; wait if not set
  261                   	
  262 F07B  7E          	LD A,(HL)	; get char from string
  263 F07C  A7          	AND A		; check if 0
  264 F07D  C8          	RET Z		; -> send of string
  265                   	
  266 F07E  D3 20       	OUT (CO_DAT),A	; write char to output
  267 F080  23          	INC HL		; next char in string
  268 F081  C3 F074     	JP WRSTR	; start over
  269                   
