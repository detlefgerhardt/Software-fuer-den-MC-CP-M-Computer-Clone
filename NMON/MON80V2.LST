  399 F110  D6 3C       	SUB 3CH
  400 F112  30 01       	JR NC,MEMCK1
  401                   
  402 F114  25          	DEC H
  403                   	
  404 F115  44          MEMCK1:	LD B,H
  405 F116  E1          	POP HL
  406 F117  C9          	RET
