  639                   ;------------------------------------------------------------------------------
  640                   
  641                   ; Old MINI routine
  642                   
  643                   ; Routinen fuer MC-Kompatibilitaet
  644                   ; wie floppy, jedoch Drive-Codierung anders
  645                   ; nur fuer bestehende BIOS-Routinen gedacht
  646                   ;
  647                   ; HL = block buffer address
  648                   ; B = 0=set step-rate and SSO, 1=read, 2=write
"MC CPM-Computer Mon80V2"       			    Z80ASM 1.32 Page  12
MON80V2 Z80

  649                   ; C = bit0=drive 0/1 (A/B), bit1=side 0/1, bit6=density
  650                   ; D = track
  651                   ; E = physical sector (1..n)
  652                   
  653 F1E4  79          MINI:	LD A,C		; drive code
  654 F1E5  E6 7F       	AND 7FH 	; bit 7 interessiert nicht
  655 F1E7  4F          	LD C,A		; C value is used and overwritten by SCODB
  656                   
  657                   	; value for REG4-Latch -> C
  658 F1E8  F5          	PUSH AF
  659 F1E9  CD F1CA     	CALL SCODB 	; drive-code + side A -> C (value for REG4-Latch)
  660 F1EC  F1          	POP AF
  661 F1ED  E6 40       	AND 40H 	; density
  662 F1EF  C2 F1F9     	JP NZ,MINI1
  663                   	
  664                   	; single-density
  665 F1F2  79          	LD A,C
  666 F1F3  F6 30       	OR 00110000B 	; Bit5=Mini, Bit4=density (0=DD)
  667 F1F5  4F          	LD C,A
  668 F1F6  C3 F1FD     	JP MINI2
  669                   
  670 F1F9              MINI1:	; double-density
  671 F1F9  79          	LD A,C
  672 F1FA  F6 20       	OR 00100000B 	; Bit5=Mini, Bit4=density (0=DD)
  673 F1FC  4F          	LD C,A
  674                   
  675 F1FD  3E 02       MINI2:	LD A,2  	; set SSO flag
  676 F1FF  C3 F214     	JP FLOP1 	; ok ausfuehren
  677                   
