  533                   	
  534 F194              TSTF1:	; FLO2
  535 F194  79          	LD A,C
  536                   
  537 F195  D3 C4       TSTF2:	OUT (FLO+4),A 	; set REG4-Latch
  538 F197  3E 0F       	LD A,0FH 	; RSTORE command with Verify
  539 F199  D3 C0       	OUT (FLO),A 	; to controller
  540                   	
  541 F19B              TSTF3:	; wait for INT
  542 F19B  DB C4       	IN A,(FLO+4)
  543 F19D  E6 40       	AND 40H 	; Bit 6 pruefen
  544 F19F  28 FA       	JR Z,TSTF3 	; -> wait
  545                   	
  546 F1A1  DB C0       	IN A,(FLO) 	; read status, clear interrupt
  547 F1A3  E6 98       	AND  10011000B 	; mask critical bits
  548 F1A5  37          	SCF
  549 F1A6  C0          	RET NZ  	; return with carry se (error)
  550                   	
  551 F1A7  AF          	XOR A
  552 F1A8  C9          	RET  		; return with carry clear (no error)
