  502 F16D  E6 AF       	AND 10101111B
  503 F16F  4F          	LD C,A
  504 F170  CD F186     	CALL TSTFRM
  505 F173  D0          	RET NC		; -> ok
  506                   	
  507                   	; try Mini SD
  508 F174  79          	LD A,C
  509 F175  E6 8F       	AND 10001111B
  510 F177  F6 10       	OR  00010000B
  511 F179  4F          	LD C,A
  512 F17A  CD F186     	CALL TSTFRM
  513 F17D  D0          	RET NC		; -> ok
  514                   
  515                   	; try Maxi DD
  516 F17E  79          	LD A,C
  517 F17F  E6 8F       	AND 10001111B
  518 F181  4F          	LD C,A
  519 F182  CD F186     	CALL TSTFRM
  520 F185  C9          	RET  		; ok or error (carry=1)
  521                   
  522                   ;------------------------------------------------------------------------------
  523                   ; TSTFRM
  524                   
  525 F186  3A F587     TSTFRM:	LD A,(FLOTYP)
  526 F189  FE 01       	CP 1
  527 F18B  C2 F194     	JP NZ,TSTF1	; -> FLO2
  528                   
  529                   	; FLO1
  530 F18E  79          	LD A,C
  531 F18F  EE 10       	XOR 10H		; if FLO1 invert density bit
  532 F191  C3 F195     	JP TSTF2
