Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   1
PUTSY-CFZ80

    1                   ;*****************************************************************************
    2                   ; PUTYS-CF.Z80
    3                   ;
    4                   ; Writes CP/M and BIOS from memory (notice start addresses to the IDE/CF
    5                   ; Interface
    6                   ;
    7                   ; based on PUTSYS from Donn Stewart, June 2019
    8                   ; changed by Ulrich Haumann 04/2026
    9                   ;
   10                   ;*****************************************************************************
   11                   ;Image size is 6400 bytes, so need to save 6400/128 = 50 sectors
   12                   ;For system with 64-sector tracks, image can all be on track 0
   13                   ;Load and run from ROM monitor
   14                   ;Uses calls to cbios, in memory at EA00h
   15                   ;benuzt calls zum Monitor im oberen RAM F000h
   16                   ;Copies the memory image of CP/M loaded at CPM onto track 0 of the first CP/M disk
   17                   ;Writes track 0, sectors 1 to 50 (sector 0 has cpm loader)
   18                   ;
   19                   ; PLEASE NOTE THE CHANGED CP/M & BIOS START ADDRESS AND CF/IDE DRIVES !!!
   20                   ;
   21                   ; Version history
   22                   ;
   23                   ; 10.07.2026 *dg* Renamed to PUTSY-CF and reformatted
   24                   ;                 Changed BIOS address to E200
   25                   ;		  Changed for CF/IDE drives 4..7 (E..H)
   26                   
   27                   
   28         CC00      CPM	EQU 0D400H-800H
   29         E200      BIOS	EQU 0EA00H-800H
   30                   
   31                   ; Monitor calls
   32                   
   33         F033      MWARM	EQU 0F033H	; Monitor entry
   34                   
   35                   ; bios calls
   36                   
   37         E21B      SELDSK	EQU BIOS+01BH	; pass disk no. in c
   38         E224      SETDMA	EQU BIOS+024H	; pass address in bc
   39         E21E      SETTRK	EQU BIOS+01EH	; pass track in reg C
   40         E221      SETSEC	EQU BIOS+021H	; pass sector in reg c
   41         E22A      WRITE	EQU BIOS+02AH	; write one CP/M sector to disk
   42                   
   43         0004      STDRIVE	EQU 4		; first IDE/CF-drive
   44                   
   45                   ; sector count (1024 byte sectors)
   46                   ; on a IDE/CF disk 1 track is reserved: 64 sectors
   47                   ;SECCNT	EQU (0F000h-CPM)/128
   48         003F      SECCNT	EQU 63			; only 64 sectors per track
   49                   
   50                   ;-----------------------------------------------------------------------------
   51                   
   52         0100      	ORG 100H	; program starts at 100H
   53                   
   54                   ; write track 0, sectors 1 to 50
   55                   ; write track 0, sectors 1 to SECCNT
   56                   ; only one system track available
   57                   
   58 0100  0E 04       PUT:	LD C,STDRIVE	; first CF/IDE drive
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   2
PUTSY-CFZ80

   59 0102  CD E21B     	CALL SELDSK		
   60 0105  3E 01       	LD A,1		; starting with 2. sector (0..n-1) 
   61 0107  32 0142     	LD (SECTOR),A
   62 010A  21 CC00     	LD HL,CPM	; memory address to start
   63 010D  22 0143     	LD (ADDR),HL
   64 0110  0E 00       	LD C,0		; CP/M track
   65 0112  CD E21E     	CALL SETTRK
   66                   
   67 0115              PUT1:	; track loop
   68 0115  3A 0142     	LD A,(SECTOR)
   69 0118  4F          	LD C,A		; CP/M sector
   70 0119  CD E221     	CALL SETSEC
   71 011C  ED 4B 0143  	LD BC,(ADDR)	; memory location
   72 0120  CD E224     	CALL SETDMA
   73 0123  CD E22A     	CALL WRITE
   74 0126  3A 0142     	LD A,(SECTOR)
   75                   	;CP 50
   76 0129  FE 3F       	CP SECCNT
   77 012B  CA 013F     	JP Z,PUT2
   78                   		
   79 012E  3C          	INC A
   80 012F  32 0142     	LD (SECTOR),A
   81 0132  2A 0143     	LD HL,(ADDR)
   82 0135  11 0080     	LD DE,128
   83 0138  19          	ADD HL,DE
   84 0139  22 0143     	LD (ADDR),HL
   85 013C  C3 0115     	JP PUT1
   86                   
   87 013F  C3 F033     PUT2:	JP MWARM	; call Monitor
   88                   
   89                   ;-----------------------------------------------------------------------------
   90                   
   91 0142  00          SECTOR:	DB	00H
   92 0143  0000        ADDR:	DW	0000H
   93                   
   94                   ;-----------------------------------------------------------------------------
   95                   
   96                   	END
