Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   1
NBPUT-CFZ80

    1                   ;*****************************************************************************
    2                   ; NBOOT-CF.Z80
    3                   ;
    4                   ; Boot loader for MC CP/M-Computer IDE/CF drive
    5                   
    6                   ; based on BLOAD-CF von Ulrich Haumann from 05/2026
    7                   ;
    8                   ;*****************************************************************************
    9                   ; Writes Boot loader from address 8000h to IDE/Compact-Flash
   10                   ; Uses calls to Monitor
   11                   ;
   12                   ; DOES NOT USE BIOS or CP/M START ADDRESS !!!
   13                   ;
   14                   ; Writes track 0, sectors 0 
   15                   ; Subroutine to write one IDE/ATA Disk sector (256 bytes)
   16                   ; Address of data to write to disk passed in HL
   17                   ; LBA bits 0 to 7 passed in C, bits 8 to 15 passed in B
   18                   ; LBA bits 16 to 23 passed in E
   19                   ;
   20                   ; Version history
   21                   ;
   22                   ; 10.07.2026 *dg* Renamed to NBPUT-CF and reformatted
   23                   
   24                   ;-----------------------------------------------------------------------------
   25                   
   26         1000      BOOTADR	EQU 01000H	; the bootloader was loaded to this address before
   27                   
   28                   ; calls to Monitor
   29         F009      CONOUT	EQU 0F009h	; Output a chracter
   30         F02D      IDEWR	EQU 0F02DH	; IDE/CF write routine in Monitor
   31         F033      MWARM	EQU 0F033H	; goto Monitor
   32                   
   33         0100      	ORG 0100H	; start program here
   34                   
   35 0100  21 1000     START:	LD HL,BOOTADR
   36 0103  0E 00       	LD C,00H
   37 0105  06 00       	LD B,00H
   38 0107  1E 00       	LD E,00H
   39 0109  CD F02D     	CALL IDEWR
   40 010C  21 0120     	LD HL,MSG
   41 010F  CD 0115     	CALL WRSTR
   42                   	
   43 0112  C3 F033     	JP MWARM	;ZURUECk zum Monitor
   44                   
   45                   ;-----------------------------------------------------------------------------
   46                   ; Used monitor CONOUT to print 0-terminated string
   47                   ; address in HL
   48                   ; 00h = string end
   49                   
   50 0115  7E          WRSTR:	LD A,(HL)	; get char from string
   51 0116  A7          	AND A		; check if 0
   52 0117  C8          	RET Z		; -> end of string
   53                   	
   54 0118  4F          	LD C,A
   55 0119  CD F009     	CALL CONOUT
   56 011C  23          	INC HL		; next char in string
   57 011D  C3 0115     	JP WRSTR	; start over
   58                   
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   2
NBPUT-CFZ80

   59                   ;-----------------------------------------------------------------------------
   60                   
   61         000D      CR	EQU 0DH
   62         000A      LF	EQU 0AH
   63                   
   64                   
   65 0120  0D 0A       MSG:	DEFB CR,LF
   66 0122  2D 2D 2D 2D 	DEFM "------------------------------------",CR,LF
   67 0148  20 52 65 61 	DEFM " Ready - Bootloader written to disk",CR,LF
   68 016D  2D 2D 2D 2D 	DEFM "------------------------------------",CR,LF,LF
   69                   
   70                   	END
