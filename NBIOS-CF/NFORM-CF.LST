Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   1
NFORM-CFZ80

    1                   ;*****************************************************************************
    2                   ; NBOOT-CF.Z80
    3                   ;
    4                   ; Formats a physikal Disk at the IDE/CF interface as 4 partitions for 4
    5                   ; CP/M drives
    6                   ;
    7                   ; based on FORM-CF by Uli Haumann 05/2026
    8                   ;
    9                   ;*****************************************************************************
   10                   ; Writes E5h to 64 sectors on tracks 1 to 255 of each disk (track 0 is reserved for system)
   11                   ; Uses BIOS calls. Load a BIOS that supports CF-card to the BIOS address before starting the
   12                   ; format program.
   13                   ;
   14                   ; PLEASE NOTE THE CHANGED BIOS START ADDRESS !!!
   15                   ;
   16                   ; Version history
   17                   ;
   18                   ; 09.07.2026 *dg* Renamed to NFORM-CF and reformatted
   19                   ;                 Replaced Monitor write_string function because it might
   20                   ;                 be overwritten bei the BIOS
   21                   
   22         E200      BIOS	EQU 0EA00H-800H
   23                   
   24                   ; BIOS functions
   25         E21B      SELDSK	EQU BIOS+01BH		; pass disk no. in c
   26         E224      SETDMA	EQU BIOS+024H		; pass address in bc
   27         E21E      SETTRK	EQU BIOS+01EH		; pass track in reg C
   28         E221      SETSEC	EQU BIOS+021H		; pass sector in reg c
   29         E22A      WRITE	EQU BIOS+02AH		; write one CP/M sector to disk
   30                   
   31                   ; Monitor functions
   32                   ;PRMSG	EQU 0F036H		; does not exist after BIOS was called
   33         F009      CONOUT	EQU 0F009H		; print a character im Monitor
   34         F033      MWARM	EQU 0F033H
   35                   
   36         0004      STDISK	EQU 4			; first CF disk 
   37                   
   38         0100      	ORG 0100H
   39                   
   40 0100  31 037F     FORM:	LD SP,STACK
   41                   
   42 0103  21 01AB     	LD HL,STMSG
   43 0106  CD 01A0     	CALL WRSTR		; output start message
   44                   
   45 0109  3E 00       	LD A,0
   46 010B  32 01FF     	LD (CHAR_COUNT),A
   47                   	
   48 010E  3E 04       	LD A,STDISK		; first cf disk
   49 0110  32 01FC     	LD (DISK),A
   50                   
   51 0113              FORM1:	; disk loop
   52 0113  3A 01FC     	LD A,(DISK)
   53 0116  4F          	LD C,A			; set current disk
   54 0117  CD E21B     	CALL SELDSK
   55 011A  3E 01       	LD A,1			; starting track (offset = 1)
   56 011C  32 01FE     	LD (TRACK),A
   57                   
   58 011F              FORM2:	; track loop
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   2
NFORM-CFZ80

   59 011F  3E 00       	LD A,0			; starting sector 0
   60 0121  32 01FD     	LD (SECTOR),A
   61 0124  3A 01FE     	LD A,(TRACK)
   62 0127  4F          	LD C,A			; set track
   63 0128  CD E21E     	CALL SETTRK
   64                   
   65 012B              FORM3:	; sector loop
   66 012B  3A 01FD     	LD A,(SECTOR)
   67 012E  4F          	LD C,A			; set sector
   68 012F  CD E221     	CALL SETSEC
   69 0132  01 0200     	LD BC,DIR_SECTOR
   70 0135  CD E224     	CALL SETDMA
   71 0138  CD E22A     	CALL WRITE
   72 013B  3A 01FD     	LD A,(SECTOR)
   73 013E  FE 3F       	CP 63
   74 0140  CA 014A     	JP Z,FORM4
   75                   		
   76 0143  3C          	INC A
   77 0144  32 01FD     	LD (SECTOR),A
   78 0147  C3 012B     	JP FORM3		; -> next sector
   79                   
   80 014A              FORM4:	; next track
   81 014A  3A 01FE     	LD A,(TRACK)
   82 014D  FE FF       	CP 255
   83 014F  CA 017E     	JP Z,FORM6		; -> next disk
   84                   		
   85 0152  3C          	INC A
   86 0153  32 01FE     	LD (TRACK),A
   87 0156  3E 2E       	LD A,'.'		; print dot
   88 0158  4F          	LD C,A
   89 0159  CD F009     	CALL CONOUT
   90 015C  3A 01FF     	LD A,(CHAR_COUNT)
   91 015F  3C          	INC A
   92 0160  FE 50       	CP 80
   93 0162  CA 016B     	JP Z,FORM5
   94                   	
   95 0165  32 01FF     	LD (CHAR_COUNT),A
   96 0168  C3 011F     	JP FORM2		; -> next track
   97                   
   98 016B  AF          FORM5:	XOR A
   99 016C  32 01FF     	LD (CHAR_COUNT),A
  100 016F  3E 0D       	LD A,0DH		; CR ausgeben
  101 0171  4F          	LD C,A
  102 0172  CD F009     	CALL CONOUT
  103 0175  3E 0A       	LD A,0AH		; LF ausgeben
  104 0177  4F          	LD C,A
  105 0178  CD F009     	CALL CONOUT
  106 017B  C3 011F     	JP FORM2		; -> next track
  107                   
  108 017E              FORM6:	; next disk
  109 017E  AF          	XOR A
  110 017F  32 01FF     	LD (CHAR_COUNT),A
  111 0182  3A 01FC     	LD A,(DISK)		;naechste virtuelle Diskette
  112 0185  3C          	INC A
  113 0186  FE 08       	CP 8			;fertig ?
  114 0188  CA 0197     	JP Z,FORM7		; -> done
  115                   
  116 018B  32 01FC     	LD (DISK),A
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   3
NFORM-CFZ80

  117                   	;PUSH HL
  118 018E  21 01EE     	LD HL,DISK_STRING	;next Disk ausgeben
  119 0191  CD 01A0     	CALL WRSTR
  120                   	;POP HL
  121 0194  C3 0113     	JP FORM1		; -> next disk
  122                   
  123 0197              FORM7:	; done
  124 0197  21 01D4     	LD HL,END_STRING	; success message
  125 019A  CD 01A0     	CALL WRSTR
  126 019D  C3 F033     	JP MWARM
  127                   
  128                   ;-----------------------------------------------------------------------------
  129                   ; Used monitor CONOUT to print 0-terminated string
  130                   ; address in HL
  131                   ; 00h = string end
  132                   
  133 01A0  7E          WRSTR:	LD A,(HL)		; get char from string
  134 01A1  A7          	AND A			; check if 0
  135 01A2  C8          	RET Z			; -> end of string
  136                   	
  137 01A3  4F          	LD C,A
  138 01A4  CD F009     	CALL CONOUT
  139 01A7  23          	INC HL			; next char in string
  140 01A8  C3 01A0     	JP WRSTR		; start over
  141                   
  142                   ;-----------------------------------------------------------------------------
  143                   
  144 01AB  0D 0A 0A 46 STMSG:		DEFM	0dh,0ah,0ah,"Formatiere 4 virtuelle Disk",0dh,0ah,"Disk 1",0dh,0ah,0
  145 01D4  0D 0A 46 6F END_STRING:	DEFM	0dh,0ah,'Formatierung beendet',0dh,0dh,0ah,0
  146 01EE  0D 0A 6E 65 DISK_STRING:	DEFM	0dh,0ah,'next Disk',0dh,0ah,0
  147                   
  148 01FC    0001      DISK:		DEFS	1
  149 01FD    0001      SECTOR:		DEFS	1
  150 01FE    0001      TRACK:		DEFS	1
  151                   ;ADDRESS:	DEFS	2
  152 01FF    0001      CHAR_COUNT:	DEFS	1
  153 0200  E5 E5 E5 E5 DIR_SECTOR:	DS	128,0E5h	;byte for empty directory
  154 0280    00FF      		DS	0FFh		;stack space
  155                   
  156 037F              STACK:
  157                   
  158                   ;-----------------------------------------------------------------------------
  159                   
  160                   	END
