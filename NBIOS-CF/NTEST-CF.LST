  252                   ;-----------------------------------------------------------------------------
  253                   ; Used monitor CONOUT to print 0-terminated string
  254                   ; address in HL
  255                   ; 00h = string end
  256                   
  257 026A  7E          WRSTR:	LD A,(HL)	; get char from string
  258 026B  A7          	AND A		; check if 0
  259 026C  C8          	RET Z		; -> end of string
  260                   	
  261 026D  4F          	LD C,A
  262 026E  CD F009     	CALL CONOUT
